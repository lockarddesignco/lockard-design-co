---
interface Props {
  title?: string;
}

const { title = 'This Page' } = Astro.props;
---

<section class="flex items-center justify-center min-h-[80vh] pt-[clamp(200px,24vh,280px)] pb-[clamp(80px,10vw,140px)] px-[clamp(20px,5vw,48px)] bg-[#0a0a14] text-center">
  <div class="max-w-[600px] flex flex-col items-center gap-6">
    <div class="w-16 h-16 mb-2 opacity-90">
      <img src="/images/logo.svg" alt="Lockard Design Co." class="w-full h-full object-contain" width="64" height="64" />
    </div>
    <h1 class="font-[var(--font-display)] text-[clamp(1.8rem,4vw,2.8rem)] font-extrabold tracking-tight leading-[1.15] text-white">{title}</h1>
    <p class="font-[var(--font-body)] text-[clamp(1rem,1.5vw,1.15rem)] leading-[1.7] text-white/65 max-w-[480px]">
      This page is under routine maintenance. Check back shortly — or get in touch if you need something right away.
    </p>
    <a href="/" class="btn mt-2">Back to Homepage</a>
  </div>
</section>

<!-- ========== FINAL CTA ========== -->
<section class="cta-final section--blue" id="contact">
  <div class="container text-center">
    <h2>Ready to Own Your Growth?</h2>
    <p class="mx-auto" style="text-align:center;">
      Schedule a free strategy session and we'll build you a custom growth plan. No obligation, no pitch — just a clear path to predictable growth.
    </p>
    <div class="cta-final__actions">
      <a href="/contact/" class="btn btn--white">Get Your Growth Plan</a>
      <a href="https://wa.me/18567702456" class="btn--white-outline" style="display:inline-flex;align-items:center;gap:6px;" target="_blank" rel="noopener noreferrer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.019-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp Us
      </a>
    </div>
  </div>
</section>

<!-- ========== MAP ========== -->
<div class="map-section">
  <div class="map-card">
    <div class="map-card__logo">
      <img src="/images/logo.svg" alt="" width="36" height="36" />
      <span class="map-card__name">
        <strong>LOCKARD</strong>
        <span>DESIGN CO.</span>
      </span>
    </div>
    <div class="map-card__info">
      <div class="map-card__row">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Turnersville, NJ
      </div>
      <div class="map-card__row">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        (856) 770-2456
      </div>
      <div class="map-card__row">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Growing businesses Coast to Coast
      </div>
    </div>
    <a href="https://maps.app.goo.gl/7iepW7fBYRLb76Wf9" target="_blank" rel="noopener noreferrer" class="map-card__btn">
      Get Directions
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
    </a>
    <div class="map-card__stars">
      <svg viewBox="0 0 24 24" fill="#F5A623" width="18" height="18"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      <svg viewBox="0 0 24 24" fill="#F5A623" width="18" height="18"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      <svg viewBox="0 0 24 24" fill="#F5A623" width="18" height="18"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      <svg viewBox="0 0 24 24" fill="#F5A623" width="18" height="18"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      <svg viewBox="0 0 24 24" fill="#F5A623" width="18" height="18"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      <span>5.0 on Google</span>
    </div>
  </div>
  <iframe
    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d98000.0!2d-75.05073892402105!3d39.76668637155151!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c6d3c33f0ad269%3A0x65cd09a7ce31a611!2sLockard%20Design%20Co.!5e0!3m2!1sen!2sus!4v1773728359109!5m2!1sen!2sus"
    width="100%"
    height="450"
    style="border:0; display:block;"
    allowfullscreen=""
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    title="Lockard Design Co. — Turnersville, NJ"
  ></iframe>
</div>

<style>
  .cta-final {
    padding-block: clamp(80px, 10vw, 160px);
    position: relative;
    overflow: hidden;
  }
  .cta-final::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("/images/noise.png");
    background-repeat: repeat;
    background-size: 200px 200px;
    pointer-events: none;
    z-index: 0;
    opacity: 0.35;
    mix-blend-mode: overlay;
  }
  .cta-final > * {
    position: relative;
    z-index: 1;
  }
  .cta-final h2 {
    margin-bottom: clamp(12px, 2vw, 24px);
  }
  .cta-final p {
    max-width: 50ch;
  }
  .cta-final__actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: clamp(28px, 4vw, 40px);
  }
  .btn--white-outline {
    background-color: transparent;
    color: #FFFFFF;
    border: 2px solid rgba(255, 255, 255, 0.5);
    border-radius: var(--radius-full);
    padding: 14px 32px;
    font-weight: 600;
    text-decoration: none;
    display: inline-block;
    transition: all 0.25s ease;
  }
  .btn--white-outline:hover {
    background-color: rgba(255, 255, 255, 0.15);
    border-color: #FFFFFF;
  }

  .map-section {
    width: 100%;
    line-height: 0;
    position: relative;
  }
  .map-section iframe {
    width: 100%;
    height: 450px;
    filter: grayscale(1) contrast(1.1);
    transition: filter 0.4s ease;
  }
  .map-section:hover iframe {
    filter: grayscale(0) contrast(1);
  }
  .map-card {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    z-index: 10;
    background: #0a0a14;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    padding: clamp(32px, 3vw, 48px);
    width: clamp(300px, 26vw, 380px);
    box-shadow: 16px 0 48px rgba(0, 0, 0, 0.3);
    line-height: 1.5;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .map-card__logo {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .map-card__name {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }
  .map-card__name strong {
    font-size: 0.95rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: 0.06em;
  }
  .map-card__name span {
    font-size: 0.65rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.4);
    letter-spacing: 0.12em;
  }
  .map-card__info {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 20px;
  }
  .map-card__row {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.8);
  }
  .map-card__row svg {
    flex-shrink: 0;
    color: var(--color-blue);
  }
  .map-card__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 10px 20px;
    background: var(--color-blue);
    color: #fff;
    border-radius: var(--radius-full);
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 600;
    transition: all 0.25s ease;
  }
  .map-card__btn:hover {
    background: var(--color-bg-blue-dark);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(24, 119, 242, 0.3);
  }
  .map-card__stars {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3px;
    margin-top: 14px;
  }
  .map-card__stars span {
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.4);
    margin-left: 6px;
  }
  @media (max-width: 600px) {
    .map-card {
      position: relative;
      width: 100%;
      border-right: 0;
    }
  }
</style>
