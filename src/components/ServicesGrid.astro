---
const services = [
  {
    icon: 'desktop',
    name: 'Custom Website Design',
    description: 'We build professional, high-converting websites that work as your #1 salesperson, 24/7.',
    link: '/services/custom-website-design',
    cta: 'See Our Work',
  },
  {
    icon: 'search',
    name: 'Get Found on Google',
    description: 'Climb the search rankings and own your local market with our proven SEO strategies.',
    link: '/services/seo',
    cta: 'Rank Higher',
  },
  {
    icon: 'chart',
    name: 'Predictable Lead Flow',
    description: 'Turn on the faucet for qualified leads with precision-targeted digital advertising campaigns.',
    link: '/services/lead-generation',
    cta: 'Get More Leads',
  },
  {
    icon: 'sparkle',
    name: 'Professional Brand Identity',
    description: 'We craft a memorable brand that makes you the obvious and only choice for your ideal clients.',
    link: '/services/branding',
    cta: 'Build Your Brand',
  },
  {
    icon: 'shield',
    name: 'Website Care & Support',
    description: 'Your website is a valuable asset — we keep it secure, updated, and running at peak performance.',
    link: '/services/website-care',
    cta: 'Protect Your Site',
  },
  {
    icon: 'automation',
    name: 'Business Process Automation',
    description: 'Stop wasting time on repetitive tasks and let us build systems that run your business for you.',
    link: '/services/automation',
    cta: 'Save Time',
  },
  {
    icon: 'ai',
    name: 'AI-Powered Operations',
    description: 'Gain an unfair advantage by integrating intelligent AI systems into your daily workflow.',
    link: '/services/ai-integration',
    cta: 'Work Smarter',
  },
  {
    icon: 'outreach',
    name: 'B2B Outreach Systems',
    description: 'We build and manage direct outreach campaigns to land high-value B2B clients.',
    link: '/services/b2b-outreach',
    cta: 'Land Bigger Clients',
  },
];

const icons: Record<string, string> = {
  desktop: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
  search: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>`,
  chart: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
  sparkle: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l2.4 7.2L22 12l-7.6 2.8L12 22l-2.4-7.2L2 12l7.6-2.8z"/></svg>`,
  shield: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
  automation: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>`,
  ai: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="15" x2="23" y2="15"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="15" x2="4" y2="15"/></svg>`,
  outreach: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
};
---

<section class="section-padding bg-[#0a0a14] relative overflow-hidden" id="all-services">
  <!-- Radial glow -->
  <div class="absolute w-[900px] h-[900px] rounded-full bg-[radial-gradient(circle,rgba(24,119,242,0.08)_0%,transparent_70%)] -bottom-[300px] left-1/2 -translate-x-1/2 pointer-events-none"></div>

  <div class="container relative z-[1]">
    <div class="h-px bg-white/[0.08] mb-[var(--spacing-section)]"></div>
    <div class="text-center mb-[clamp(48px,6vw,72px)]">
      <div class="hero__badge inline-flex items-center gap-2 bg-[rgba(24,119,242,0.15)] text-[var(--color-blue)] border border-[rgba(24,119,242,0.25)] rounded-full px-4 py-1.5 text-[0.78rem] font-semibold mb-4">
        <span class="hero__badge-dot w-2 h-2 rounded-full bg-[var(--color-blue)]"></span>
        What We Do
      </div>
      <h2 class="text-white mb-4">Every Tool You Need to Win</h2>
      <p class="subheadline mx-auto text-white/50">A complete toolkit to build your foundation, fill your pipeline, and automate your growth.</p>
    </div>
    <div class="grid grid-cols-4 gap-[clamp(16px,2vw,24px)] max-[1024px]:grid-cols-2 max-[600px]:grid-cols-1">
      {services.map((service) => (
        <a href={service.link} class="group bg-white/[0.04] border border-white/[0.08] rounded-[var(--radius-lg)] p-[clamp(24px,2.5vw,32px)] flex flex-col no-underline transition-all duration-300 hover:bg-white/[0.08] hover:border-[rgba(24,119,242,0.3)] hover:-translate-y-1 hover:shadow-[0_12px_40px_rgba(24,119,242,0.1)]">
          <div class="w-12 h-12 flex items-center justify-center rounded-[var(--radius-sm)] bg-[rgba(24,119,242,0.1)] text-[var(--color-blue)] mb-5">
            <Fragment set:html={icons[service.icon]} />
          </div>
          <h3 class="text-[clamp(1rem,1.3vw,1.15rem)] font-semibold text-white mb-2">{service.name}</h3>
          <p class="text-[0.88rem] leading-[1.65] text-white/50 flex-1 mb-5">{service.description}</p>
          <span class="inline-flex items-center gap-1.5 text-[0.85rem] font-semibold text-[var(--color-blue)] mt-auto transition-[gap] duration-200 group-hover:gap-2.5">
            {service.cta}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
