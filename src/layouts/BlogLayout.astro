---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingCTA from '../components/FloatingCTA.astro';
import MapSection from '../components/MapSection.astro';
import BoltCursor from '../components/BoltCursor.astro';

interface Props {
  title: string;
  description?: string;
  hideFloatingCTA?: boolean;
}

const {
  title,
  description = 'Insights, strategies, and guides for service businesses looking to grow. From the team at Lockard Design Co.',
  hideFloatingCTA = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://lockarddesignco.com/images/og-default.jpg" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Lockard Design Co." />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://lockarddesignco.com/images/og-default.jpg" />

    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-TJBJSWB9');</script>
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TJBJSWB9" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

    <Header />

    <main>
      <slot />
    </main>

    {!hideFloatingCTA && <FloatingCTA />}

    <MapSection />
    <Footer />
    <BoltCursor />

    <!-- Full-page noise texture overlay -->
    <div class="fixed inset-0 pointer-events-none z-[9999] opacity-35 mix-blend-overlay bg-[url('/images/noise.png')] bg-repeat [background-size:200px_200px]"></div>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
  @import '../styles/legacy-vars.css';
</style>
