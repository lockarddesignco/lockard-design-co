---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Lockard Design Co. builds websites and growth systems for established service businesses. Stop buying marketing. Start owning your growth.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://lockarddesignco.com/images/og-default.jpg" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />

    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-TJBJSWB9');</script>

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Lockard Design Co.",
      "description": description,
      "url": "https://lockarddesignco.com",
      "telephone": "+18567702456",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "5051 NJ-42",
        "addressLocality": "Turnersville",
        "addressRegion": "NJ",
        "postalCode": "08012",
        "addressCountry": "US"
      },
      "areaServed": {
        "@type": "State",
        "name": "New Jersey"
      },
      "serviceType": ["Web Design", "SEO", "Digital Marketing"],
      "priceRange": "$$"
    })} />
  </head>
  <body class="relative">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TJBJSWB9" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

    <slot />

    <!-- Full-page noise texture overlay -->
    <div class="fixed inset-0 pointer-events-none z-[9999] opacity-35 mix-blend-overlay bg-[url('/images/noise.png')] bg-repeat [background-size:200px_200px]"></div>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
  @import '../styles/legacy-vars.css';
</style>
