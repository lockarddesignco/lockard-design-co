---
import BlogLayout from '../../layouts/BlogLayout.astro';

const title = 'SEO Services for Local Businesses | Lockard Design Co.';
const description = 'Stop losing customers to competitors who show up first. Our proven SEO strategies help local service businesses dominate search rankings and generate qualified leads on autopilot.';

const faqData = [
  {
    group: 'Investment & Value',
    items: [
      {
        q: 'How much does SEO cost for a local business?',
        a: 'Our SEO services range from $2,500 to $10,000 per month depending on your market\'s competitiveness, number of service areas, current site health, and the scope of content and link building needed. Most local service businesses fall in the $2,500\u2013$5,000 range. We provide a custom quote after analyzing your specific situation during a free SEO audit.'
      },
      {
        q: 'How long does SEO take to work?',
        a: 'Most clients begin seeing measurable improvements in rankings and traffic within 3 to 6 months. SEO is a compounding investment \u2014 the results get stronger over time as your site builds authority. We set clear monthly milestones so you always know what progress looks like, and we provide transparent reporting every month.'
      },
      {
        q: 'I\'ve been burned by an SEO agency before. How are you different?',
        a: 'We hear this constantly. Most agencies lock you into long contracts, send confusing reports full of vanity metrics, and rotate you through junior account managers. At Lockard Design Co., you get a dedicated senior strategist who knows your business inside and out, monthly video reviews of your results, and full access to our team through Basecamp. You\'ll always know exactly what we did, what changed, and what\'s next.'
      },
    ]
  },
  {
    group: 'Process & Results',
    items: [
      {
        q: 'Do I need SEO if I already get referrals?',
        a: 'Referrals are great, but they\'re unpredictable. What happens when a slow month hits? SEO builds a second pipeline of qualified leads that runs 24/7 \u2014 people actively searching for exactly what you do, ready to hire. The best businesses combine a strong referral network with a dominant search presence. That\'s how you go from surviving to scaling.'
      },
      {
        q: 'What\'s included in your monthly SEO service?',
        a: 'Every month includes: a full technical audit and ongoing optimization, keyword research and content strategy, on-page SEO for your service and location pages, Google Business Profile optimization and management, local citation building and link acquisition, a recorded monthly video review of your results, and a quarterly deep-dive video breakdown of your overall trajectory. You also get full access to our team through Basecamp where you can track progress and communicate directly. Everything is tied to results.'
      },
      {
        q: 'Can I see what you\'re doing each month?',
        a: 'Absolutely. Every month you get a recorded video review walking through your results, what we did, and what\'s coming next. Every quarter, we do a deeper video breakdown of your overall SEO trajectory. On top of that, you get full access to our team through Basecamp \u2014 our project management platform \u2014 where you can see tasks in progress, ask questions, and communicate directly with the people doing the work. No black box.'
      },
      {
        q: 'Do you guarantee first page rankings?',
        a: 'No \u2014 and any agency that does is lying. Google\'s algorithm considers hundreds of factors, and no one can guarantee a specific ranking. What we can guarantee is a proven process, transparent reporting, and a track record of getting results. If an agency promises you #1 rankings, that\'s a red flag, not a selling point.'
      },
      {
        q: 'What if I already have a website? Do I need a new one for SEO?',
        a: 'Not necessarily. If your current site is well-built and loads fast, we can optimize what you have. During our free audit, we\'ll assess your site\'s technical health, content quality, and conversion potential. If it needs work, we\'ll tell you exactly what and why \u2014 but we\'ll never recommend a rebuild unless it\'s genuinely the best path to results.'
      },
    ]
  }
];

const industries = [
  { name: 'Roofing', slug: 'roofing-seo' },
  { name: 'HVAC', slug: 'hvac-seo' },
  { name: 'Plumbing', slug: 'plumber-seo' },
  { name: 'Electrical', slug: 'electrician-seo' },
  { name: 'Contractors', slug: 'contractor-seo' },
  { name: 'Construction', slug: 'construction-seo' },
  { name: 'Landscaping', slug: 'landscaping-seo' },
  { name: 'Pest Control', slug: 'pest-control-seo' },
  { name: 'Remodeling', slug: 'remodeling-seo' },
  { name: 'Painting', slug: 'painting-company-seo' },
  { name: 'Moving Companies', slug: 'moving-company-seo' },
  { name: 'Auto Repair', slug: 'auto-repair-seo' },
  { name: 'Garage Doors', slug: 'garage-door-seo' },
  { name: 'Cleaning', slug: 'cleaning-company-seo' },
  { name: 'Tree Service', slug: 'tree-service-seo' },
  { name: 'Home Builders', slug: 'home-builder-seo' },
  { name: 'Carpet Cleaning', slug: 'carpet-cleaning-seo' },
  { name: 'Solar', slug: 'solar-seo' },
  { name: 'Locksmith', slug: 'locksmith-seo' },
  { name: 'Restoration', slug: 'restoration-seo' },
  { name: 'Chiropractor', slug: 'chiropractor-seo' },
  { name: 'Junk Removal', slug: 'junk-removal-seo' },
  { name: 'Dental', slug: 'dental-seo' },
  { name: 'Law Firms', slug: 'law-firm-seo' },
];

const services = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
    name: 'Local SEO',
    description: 'Dominate the map pack and local search results in your service area.',
    link: '/seo/local-seo/',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    name: 'Technical SEO',
    description: 'A fast, healthy site that Google loves to crawl and rank.',
    link: '/seo/technical-seo/',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    name: 'Content Strategy',
    description: 'The pages and articles that attract your ideal customers from search.',
    link: '/seo/content-strategy/',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`,
    name: 'Link Building',
    description: 'The authority signals that push you past your competition to page one.',
    link: '/seo/link-building/',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>`,
    name: 'SEO Audits',
    description: 'Know exactly where you stand and where the biggest opportunities are.',
    link: '/seo/seo-audits/',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/><circle cx="12" cy="10" r="3"/></svg>`,
    name: 'Google Business Profile',
    description: 'Own the map pack in your service area with an optimized GBP.',
    link: '/seo/google-business-profile/',
  },
];

const processSteps = [
  { num: '01', title: 'Audit', desc: 'We analyze your site, your competitors, and your market to find every opportunity and weakness.' },
  { num: '02', title: 'Strategy', desc: 'We build a custom SEO roadmap based on what will move the needle fastest for your specific business.' },
  { num: '03', title: 'Optimize', desc: 'We fix technical issues, optimize your pages, and build the content your customers are searching for.' },
  { num: '04', title: 'Build Authority', desc: 'We earn the backlinks and citations that tell Google you\'re the real authority in your market.' },
  { num: '05', title: 'Report & Refine', desc: 'You get clear monthly reports showing exactly what we did and what happened. We adjust and improve every month.' },
];
---

<BlogLayout title={title} description={description}>

  <!-- ========== BREADCRUMB ========== -->
  <nav class="bg-[#0a0a14] pt-36 pb-0" aria-label="Breadcrumb">
    <div class="container">
      <ol class="flex items-center gap-2 text-sm text-white/40">
        <li><a href="/" class="hover:text-white/70 transition-colors">Home</a></li>
        <li><span class="mx-1">/</span></li>
        <li class="text-white/70">SEO Services</li>
      </ol>
    </div>
  </nav>


  <!-- ========== HERO ========== -->
  <section class="bg-[#0a0a14] pt-12 pb-[var(--spacing-section)] relative overflow-hidden" id="hero">
    <!-- Hero background image -->
    <div class="absolute inset-0 -top-4">
      <img src="/images/seo-hero.jpg" alt="" class="w-full h-full object-cover object-center" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-r from-[#0a0a14] via-[#0a0a14]/80 to-[#0a0a14]/20"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a14] via-transparent to-[#0a0a14]"></div>
    </div>
    <!-- Radial glow -->
    <div class="absolute w-[800px] h-[800px] rounded-full bg-[radial-gradient(circle,rgba(24,119,242,0.06)_0%,transparent_70%)] -top-[200px] -right-[200px] pointer-events-none"></div>
    <div class="container relative z-[1]">
      <div class="max-w-[750px]">
        <div class="inline-flex items-center gap-2 bg-[rgba(24,119,242,0.15)] text-[var(--color-blue)] border border-[rgba(24,119,242,0.25)] rounded-full px-4 py-1.5 text-[0.78rem] font-semibold mb-6">
          <span class="w-2 h-2 rounded-full bg-[var(--color-blue)]"></span>
          SEO Services
        </div>
        <h1 class="text-white mb-6" style="font-size:clamp(2.25rem, 5vw, 3.75rem);">Stop Losing Customers to Competitors Who Show Up First.</h1>
        <p class="text-white/60 text-[clamp(1.05rem,1.4vw,1.25rem)] leading-[1.7] max-w-[55ch] mb-4">
          Right now, someone in your market is searching for exactly what you do. If they find your competitor first, that's money you'll never see. We build SEO strategies that put your business at the top of Google and keep it there.
        </p>
        <p class="text-[var(--color-blue)] text-sm font-medium mb-8">97% of consumers search online before choosing a local service provider.</p>
        <div class="flex flex-wrap gap-4 mb-10">
          <button class="btn btn--lg seo-cta-open">Get Your Free SEO Audit</button>
          <a href="#process" class="btn btn--outline btn--lg" style="border-color:rgba(255,255,255,0.2);color:#fff;">See How We Do It</a>
        </div>
        <div class="flex flex-wrap gap-6 max-[600px]:gap-4">
          <div class="flex items-center gap-2 text-white/50 text-sm">
            <div class="flex gap-0.5">
              <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            </div>
            <span>5.0 on Google</span>
          </div>
          <div class="text-white/50 text-sm"><strong class="text-white font-semibold">100's</strong> Businesses Served</div>
          <div class="text-white/50 text-sm"><strong class="text-white font-semibold">25+</strong> Industries</div>
        </div>
        <p class="text-white/30 text-xs mt-4">Free. No obligation. Takes 15 minutes.</p>
      </div>
    </div>
  </section>


  <!-- ========== PROBLEM ========== -->
  <section class="seo-problem relative overflow-hidden pt-0" id="problem">
    <canvas class="seo-stars absolute inset-0 z-[1] pointer-events-none" aria-hidden="true"></canvas>
    <div class="seo-lamp-glow"></div>
    <img src="/images/crescent-moon.png" alt="" class="seo-lamp" loading="lazy" />
    <div class="container relative z-[4]">
      <div class="h-px bg-white/[0.06] mb-[clamp(40px,5vw,64px)]"></div>
      <div class="text-center mb-[clamp(40px,5vw,64px)]">
        <div class="inline-flex items-center gap-2 bg-[rgba(24,119,242,0.15)] text-[var(--color-blue)] border border-[rgba(24,119,242,0.25)] rounded-full px-4 py-1.5 text-[0.78rem] font-semibold mb-4">
          <span class="w-2 h-2 rounded-full bg-[var(--color-blue)]"></span>
          The Problem
        </div>
        <h2 class="text-white">Sound Familiar?</h2>
      </div>
      <div class="grid grid-cols-3 gap-[clamp(16px,2vw,24px)] max-[900px]:grid-cols-1">
        <div class="bg-white/[0.04] border border-white/[0.08] rounded-[var(--radius-lg)] p-[clamp(24px,2.5vw,32px)] transition-all duration-300 hover:bg-white/[0.07] hover:border-white/[0.15] hover:-translate-y-1">
          <div class="flex items-center justify-between mb-5">
            <span class="text-[var(--color-blue)] text-sm font-bold opacity-50">01</span>
            <div class="w-10 h-10 flex items-center justify-center rounded-[var(--radius-sm)] bg-[rgba(24,119,242,0.1)] text-[var(--color-blue)]">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </div>
          </div>
          <h3 class="text-white text-[clamp(1rem,1.3vw,1.15rem)] font-semibold mb-2">Your Competitors Are Outranking You.</h3>
          <p class="text-white/50 text-[0.88rem] leading-[1.65]">You search your own service and your competitors show up first. Every day, customers who should be calling you are calling them instead.</p>
        </div>
        <div class="bg-white/[0.04] border border-white/[0.08] rounded-[var(--radius-lg)] p-[clamp(24px,2.5vw,32px)] transition-all duration-300 hover:bg-white/[0.07] hover:border-white/[0.15] hover:-translate-y-1">
          <div class="flex items-center justify-between mb-5">
            <span class="text-[var(--color-blue)] text-sm font-bold opacity-50">02</span>
            <div class="w-10 h-10 flex items-center justify-center rounded-[var(--radius-sm)] bg-[rgba(24,119,242,0.1)] text-[var(--color-blue)]">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
          </div>
          <h3 class="text-white text-[clamp(1rem,1.3vw,1.15rem)] font-semibold mb-2">You've Been Burned Before.</h3>
          <p class="text-white/50 text-[0.88rem] leading-[1.65]">You paid an agency thousands of dollars, got confusing reports full of jargon, and never saw real results. Now you're skeptical that SEO even works.</p>
        </div>
        <div class="bg-white/[0.04] border border-white/[0.08] rounded-[var(--radius-lg)] p-[clamp(24px,2.5vw,32px)] transition-all duration-300 hover:bg-white/[0.07] hover:border-white/[0.15] hover:-translate-y-1">
          <div class="flex items-center justify-between mb-5">
            <span class="text-[var(--color-blue)] text-sm font-bold opacity-50">03</span>
            <div class="w-10 h-10 flex items-center justify-center rounded-[var(--radius-sm)] bg-[rgba(24,119,242,0.1)] text-[var(--color-blue)]">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            </div>
          </div>
          <h3 class="text-white text-[clamp(1rem,1.3vw,1.15rem)] font-semibold mb-2">You're Stuck on Referrals Alone.</h3>
          <p class="text-white/50 text-[0.88rem] leading-[1.65]">Business is good when referrals come in, but it's feast or famine. You have no predictable pipeline and no way to control your growth.</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ========== SOLUTION ========== -->
  <section class="section--blue section--textured" id="solution">
    <div class="container text-center">
      <div class="max-w-[700px] mx-auto">
        <h2 class="mb-6">SEO That Actually Puts Your Phone to Work.</h2>
        <p class="mx-auto mb-8" style="text-align:center;max-width:55ch;">
          We don't do confusing reports or vanity metrics. We build a search presence that makes your business the first call when someone in your market needs what you do. More visibility. More calls. More revenue. Every month.
        </p>
        <a href="/contact" class="btn btn--white">Let's Talk About Your SEO</a>
      </div>
    </div>
  </section>


  <!-- ========== SERVICE PILLARS ========== -->
  <section id="services">
    <div class="container">
      <div class="text-center mb-[clamp(40px,5vw,64px)]">
        <div class="inline-flex items-center gap-2 bg-[rgba(24,119,242,0.15)] text-[var(--color-blue)] border border-[rgba(24,119,242,0.25)] rounded-full px-4 py-1.5 text-[0.78rem] font-semibold mb-4">
          <span class="w-2 h-2 rounded-full bg-[var(--color-blue)]"></span>
          What's Included
        </div>
        <h2 class="mb-4">A Complete SEO System.<br/>Not Just Keywords.</h2>
        <p class="subheadline mx-auto">Every piece of the puzzle, handled. From technical foundations to content that converts.</p>
      </div>
      <div class="grid grid-cols-3 gap-[clamp(16px,2vw,24px)] max-[900px]:grid-cols-2 max-[600px]:grid-cols-1">
        {services.map((svc) => (
          <a href={svc.link} class="group card flex flex-col no-underline transition-all duration-300 hover:border-[rgba(24,119,242,0.3)]">
            <div class="w-12 h-12 flex items-center justify-center rounded-[var(--radius-sm)] bg-[var(--color-blue-faded)] text-[var(--color-blue)] mb-5">
              <Fragment set:html={svc.icon} />
            </div>
            <h3 class="text-[clamp(1rem,1.3vw,1.15rem)] font-semibold mb-2">{svc.name}</h3>
            <p class="text-[0.88rem] leading-[1.65] text-[var(--color-text-secondary)] flex-1 mb-4">{svc.description}</p>
            <span class="inline-flex items-center gap-1.5 text-[0.85rem] font-semibold text-[var(--color-blue)] transition-[gap] duration-200 group-hover:gap-2.5">
              Learn More
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>


  <!-- ========== PROCESS ========== -->
  <section class="section--soft" id="process">
    <div class="container">
      <div class="seo-process__layout">
        <div class="seo-process__left">
          <div class="inline-flex items-center gap-2 bg-[rgba(24,119,242,0.15)] text-[var(--color-blue)] border border-[rgba(24,119,242,0.25)] rounded-full px-4 py-1.5 text-[0.78rem] font-semibold mb-4">
            <span class="w-2 h-2 rounded-full bg-[var(--color-blue)]"></span>
            Our Process
          </div>
          <h2 class="mb-4">How We Get<br/>You Ranking.</h2>
          <p class="subheadline mb-8">A proven, repeatable system that turns search visibility into qualified leads for your business.</p>
          <button class="btn seo-cta-open">Get Started With a Free Audit</button>
        </div>
        <div class="seo-process__right">
          {processSteps.map((step, i) => (
            <div class="seo-process__step">
              <div class="seo-process__marker">
                <span class="seo-process__number">{step.num}</span>
                {i < processSteps.length - 1 && <div class="seo-process__line"></div>}
              </div>
              <div class="seo-process__content">
                <h3 class="text-[clamp(1.05rem,1.4vw,1.25rem)] font-semibold mb-2">{step.title}</h3>
                <p class="text-[var(--color-text-secondary)] text-[0.92rem] leading-[1.65]">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ========== RESULTS ========== -->
  <section class="seo-results relative overflow-hidden" id="results">
    <div class="absolute w-[900px] h-[900px] rounded-full bg-[radial-gradient(circle,rgba(24,119,242,0.05)_0%,transparent_70%)] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
    <div class="container relative z-[1]">
      <!-- Header -->
      <div class="text-center mb-[clamp(48px,6vw,72px)]">
        <div class="inline-flex items-center gap-2 bg-[rgba(24,119,242,0.15)] text-[var(--color-blue)] border border-[rgba(24,119,242,0.25)] rounded-full px-4 py-1.5 text-[0.78rem] font-semibold mb-4">
          <span class="w-2 h-2 rounded-full bg-[var(--color-blue)]"></span>
          Proven Results
        </div>
        <h2 class="text-white mb-4">What Working With Us Actually Looks Like.</h2>
      </div>

      <!-- What You Actually Get -->
      <div class="grid grid-cols-3 gap-[clamp(16px,2vw,24px)] mb-[clamp(48px,6vw,72px)] max-[600px]:grid-cols-1">
        <div class="bg-white/[0.04] border border-white/[0.08] rounded-[var(--radius-lg)] p-[clamp(24px,2.5vw,32px)] transition-all duration-300 hover:bg-white/[0.07] hover:border-white/[0.15]">
          <div class="w-10 h-10 flex items-center justify-center rounded-[var(--radius-sm)] bg-[rgba(24,119,242,0.1)] text-[var(--color-blue)] mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
          </div>
          <h3 class="text-white text-[clamp(1rem,1.3vw,1.15rem)] font-semibold mb-2">Monthly Video Reviews</h3>
