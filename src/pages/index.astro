  );

  // Plan heading — typewriter effect
  (() => {
    const el = document.getElementById('planTypewriter');
    if (!el) return;
    const text = 'Zero Guesswork.';
    let hasPlayed = false;

    ScrollTrigger.create({
      trigger: '#plan',
      start: 'top 70%',
      onEnter: () => {
        if (hasPlayed) return;
        hasPlayed = true;
        let i = 0;
        const interval = setInterval(() => {
          el.textContent = text.slice(0, i + 1);
          i++;
          if (i >= text.length) {
            clearInterval(interval);
            setTimeout(() => el.classList.add('plan__typewriter--done'), 1200);
          }
        }, 60);
      },
    });
  })();

  // Plan steps — stagger up
  gsap.fromTo('.plan__step',
    { y: 30, opacity: 0 },
