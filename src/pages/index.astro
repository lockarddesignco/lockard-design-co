      margin-bottom: 16px;
    }
    .hero__sub {
      font-size: 0.85rem;
      line-height: 1.5;
      margin-bottom: 24px;
      color: var(--color-text-secondary);
      max-width: 340px;
    }
    .hero__actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      width: 100%;
    }
    .hero__actions .btn {
      width: 100%;
      text-align: center;
      padding: 14px 12px;
      font-size: 0.82rem;
      white-space: nowrap;
    }
    .hero__actions .btn--outline {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(10px);
