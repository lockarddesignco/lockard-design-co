<script>


  // Industry tags — random glow
  (() => {
    const tags = document.querySelectorAll('.industries__tag');
    if (!tags.length) return;
    let lastIdx = -1;

    function lightRandom() {
      let idx;
      do {
        idx = Math.floor(Math.random() * tags.length);
      } while (idx === lastIdx);
      lastIdx = idx;

      tags[idx].classList.add('industries__tag--lit');
      setTimeout(() => tags[idx].classList.remove('industries__tag--lit'), 800);
    }

    // Light one up every 1.2s
    setInterval(lightRandom, 1200);
    // Start one immediately
    setTimeout(lightRandom, 500);
  })();

  // Hero typewriter
  (() => {
    const el = document.getElementById('heroTypewriter');
    if (!el) return;
    const base = "Your Website Isn't";
    let i = 0;

    setTimeout(() => {
      // Type out the base text
      const interval = setInterval(() => {
        el.textContent = base.slice(0, i + 1);
        i++;
        if (i >= base.length) {
          clearInterval(interval);
          // Type the emoji "period"
          setTimeout(() => {
            el.textContent = base + '\u{1F629}';
            // Pause, then backspace the emoji
            setTimeout(() => {
              el.textContent = base;
              // Type the real period
              setTimeout(() => {
                el.textContent = base + '.';
                setTimeout(() => el.classList.add('hero-typewriter--done'), 1500);
              }, 150);
            }, 600);
          }, 70);
        }
      }, 70);
    }, 600);
  })();

  // Lightning bolt cursor follower
  (() => {
    const isMobile = window.matchMedia('(pointer: coarse)').matches;
    if (isMobile) return;

    const BOLT_SVG = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`;

    const bolt = document.createElement('div');
    bolt.innerHTML = BOLT_SVG;
    bolt.style.cssText = `
      position: fixed;
      pointer-events: none;
      z-index: 9999;
      width: 28px;
      height: 28px;
      color: #1877F2;
      filter: drop-shadow(0 0 6px rgba(24, 119, 242, 0.4));
      transform: translate(4px, 4px);
      will-change: transform;
      left: 0;
      top: 0;
    `;
    document.body.appendChild(bolt);

    // Hide default cursor
    document.documentElement.style.cursor = 'none';

    // Restore cursor on interactive elements
    const style = document.createElement('style');
    style.textContent = `
      *, *::before, *::after {
        cursor: none !important;
      }
    `;
    document.head.appendChild(style);

    let mouseX = -100, mouseY = -100;

    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      bolt.style.transition = 'none';
      bolt.style.transform = `translate(${mouseX + 4}px, ${mouseY + 4}px) rotate(${rotation}deg)`;

      // Swap color over blue/dark sections
      const el = document.elementFromPoint(mouseX, mouseY);
      if (el) {
        const overHeader = false;

        // Check if mouse is in the triangle arrow zone
        const arrowSection = el.closest('.section--has-arrow');
        let inTriangle = false;
        if (arrowSection) {
          const rect = arrowSection.getBoundingClientRect();
          const relX = mouseX - rect.left;
          const centerX = rect.width / 2;
          const relY = mouseY - rect.top;
          // Triangle is 120px wide (60px each side) and 40px tall at top of section
          if (relY < 40) {
            const triHalfWidth = 60 * (1 - relY / 40);
            if (Math.abs(relX - centerX) < triHalfWidth) {
              inTriangle = true;
            }
          }
        }

        const isDark = el.closest('.problem, .footer, .section--dark, .industries') || inTriangle;
        const isLight = !isDark && el.closest('.section--blue, .section--textured:not(.industries), .topbar, .footer__cta-banner');

        // Flame detection
        const wasInPlan = inPlan;
        inPlan = !!el.closest('.plan, .industries, .problem, .header');

        if (inPlan) {
          bolt.style.color = '#1877F2';
          bolt.style.filter = 'drop-shadow(0 0 12px rgba(24,119,242,0.8)) drop-shadow(0 0 24px rgba(255,140,0,0.4))';
          const now = performance.now();
          if (now - lastFlameSpawn > 25) {
            lastFlameSpawn = now;
            for (let k = 0; k < 3; k++) spawnFlame(mouseX + 14, mouseY + 14);
            if (!flameRunning) { flameRunning = true; requestAnimationFrame(tickFlames); }
          }
        } else if (isLight) {
          bolt.style.color = '#000';
          bolt.style.filter = 'drop-shadow(0 0 6px rgba(0, 0, 0, 0.3))';
        } else {
          bolt.style.color = '#1877F2';
          bolt.style.filter = 'drop-shadow(0 0 6px rgba(24, 119, 242, 0.4))';
        }
      }
    });

    document.addEventListener('mouseleave', () => {
      bolt.style.opacity = '0';
    });

    document.addEventListener('mouseenter', () => {
      bolt.style.opacity = '1';
    });

    // Spin 360 on click
    let rotation = 0;
    document.addEventListener('click', () => {
      rotation += 360;
      bolt.style.transition = 'transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1)';
      bolt.style.transform = `translate(${mouseX + 4}px, ${mouseY + 4}px) rotate(${rotation}deg)`;
    });

    // === Electric flames in Plan section ===
    const POOL_SIZE = 50;
    const flamePool = [] as HTMLDivElement[];
    const flames = [] as {el: HTMLDivElement, x: number, y: number, vx: number, vy: number, life: number, maxLife: number, size: number, hue: number}[];
    let flamePoolIdx = 0;
    let flameRunning = false;
    let lastFlameSpawn = 0;
    let inPlan = false;

    for (let i = 0; i < POOL_SIZE; i++) {
      const p = document.createElement('div');
      p.style.cssText = 'position:fixed;left:0;top:0;pointer-events:none;z-index:99999;border-radius:50%;will-change:transform,opacity;opacity:0;';
      document.body.appendChild(p);
      flamePool.push(p);
    }

    function spawnFlame(x: number, y: number) {
      const el = flamePool[flamePoolIdx % POOL_SIZE];
      flamePoolIdx++;
      const angle = Math.random() * Math.PI * 2;
      const speed = 0.5 + Math.random() * 2;
      const size = 3 + Math.random() * 6;
      const maxLife = 20 + Math.random() * 25;
      const hue = Math.random() < 0.6 ? 200 + Math.random() * 30 : 20 + Math.random() * 30;
      el.style.width = size + 'px';
      el.style.height = size + 'px';
      el.style.opacity = '1';
      flames.push({ el, x: x + (Math.random()-0.5)*10, y: y + (Math.random()-0.5)*10, vx: Math.cos(angle)*speed, vy: -Math.abs(Math.sin(angle)*speed) - 1.5, life: 0, maxLife, size, hue });
    }

    function tickFlames() {
      for (let i = flames.length - 1; i >= 0; i--) {
        const f = flames[i];
        f.life++;
        f.x += f.vx;
        f.y += f.vy;
        f.vy -= 0.03;
        const t = f.life / f.maxLife;
        const op = t < 0.2 ? t / 0.2 : 1 - (t - 0.2) / 0.8;
        const sc = 1 - t * 0.5;
        f.el.style.transform = `translate(${f.x}px,${f.y}px) scale(${sc})`;
        f.el.style.opacity = String(Math.max(0, op * 0.8));
        f.el.style.background = `radial-gradient(circle, hsla(${f.hue},100%,65%,0.9), hsla(${f.hue},100%,50%,0) 70%)`;
        f.el.style.boxShadow = `0 0 ${f.size}px hsla(${f.hue},100%,60%,${op*0.5})`;
        if (f.life >= f.maxLife) { f.el.style.opacity = '0'; flames.splice(i, 1); }
      }
      if (flames.length > 0 || inPlan) { requestAnimationFrame(tickFlames); } else { flameRunning = false; }
    }
  })();

  // Success items — activate on scroll
  (() => {
    const items = document.querySelectorAll('.success__item');
    if (!items.length) return;

    const activate = () => {
      const zone = window.innerHeight * 0.45;
      let closest: Element | null = null;
      let closestDist = Infinity;

      items.forEach((item) => {
        const rect = item.getBoundingClientRect();
        const center = rect.top + rect.height / 2;
        const dist = Math.abs(center - zone);
        if (dist < closestDist) {
          closestDist = dist;
          closest = item;
        }
      });

      items.forEach((item) => {
        item.classList.toggle('is-active', item === closest);
      });
    };

    window.addEventListener('scroll', activate, { passive: true });
    activate();
  })();
</script>

<!-- Solution rain effect -->
<script>
  (() => {
    const canvas = document.querySelector('.solution__rain') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const drops: { x: number; y: number; len: number; speed: number; opacity: number }[] = [];
    const DROP_COUNT = 120;

    function resize() {
      const dpr = window.devicePixelRatio || 1;
      const rect = canvas.parentElement!.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      canvas.style.width = rect.width + 'px';
      canvas.style.height = rect.height + 'px';
      ctx.scale(dpr, dpr);
    }
    resize();
    window.addEventListener('resize', resize);

    for (let i = 0; i < DROP_COUNT; i++) {
      drops.push({
        x: Math.random() * 2000,
        y: Math.random() * 800,
        len: 15 + Math.random() * 25,
        speed: 2 + Math.random() * 4,
        opacity: 0.15 + Math.random() * 0.35,
      });
    }

    let running = false;

    function draw() {
      if (!running) return;
      const w = canvas.clientWidth;
      const h = canvas.clientHeight;
      ctx.clearRect(0, 0, w, h);

      for (const d of drops) {
        d.y += d.speed;
        if (d.y > h + d.len) {
          d.y = -d.len;
          d.x = Math.random() * w;
        }
        ctx.beginPath();
        ctx.moveTo(d.x, d.y);
        ctx.lineTo(d.x, d.y + d.len);
        ctx.strokeStyle = `rgba(255, 255, 255, ${d.opacity})`;
        ctx.lineWidth = 1;
        ctx.stroke();
      }
      requestAnimationFrame(draw);
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting && !running) {
          running = true;
          draw();
        } else if (!entry.isIntersecting) {
          running = false;
        }
      });
    }, { threshold: 0 });

    observer.observe(canvas.parentElement!);
  })();
</script>

