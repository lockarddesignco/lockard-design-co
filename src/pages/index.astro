    }
    .hero__stat {
      padding: 14px 8px;
      gap: 0;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      background: none;
      border: none;
      border-radius: 0;
      border-right: 1px solid var(--color-rule);
    }
    .hero__stat:last-child {
      border-right: none;
    }
    .hero__stat:hover {
      background: rgba(255, 255, 255, 0.04);
      transform: none;
      box-shadow: none;
    }
    .hero__stat strong {
      font-size: 1rem;
      font-weight: 800;
      line-height: 1;
      margin-bottom: 2px;
    }
    .hero__stat span {
      font-size: 0.55rem;
      line-height: 1.2;
      letter-spacing: 0.02em;
    }
    .hero__stat-stars {
      margin-bottom: 2px;
    }
    .hero__stat-stars svg {
      width: 12px;
      height: 12px;
    }
    .hero__scroll-hint {
      display: none;
    }
  }


  /* ========== PROBLEM ========== */
  .problem {
    padding-top: clamp(80px, 10vw, 140px);
    padding-bottom: calc(clamp(80px, 10vw, 140px) + 50px);
    margin-bottom: -50px;
    background: #0a0a14;
    color: #fff;
    position: relative;
    overflow: hidden;
    z-index: 2;
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 50px), 50% 100%, 0 calc(100% - 50px));
  }

  .problem__lamp-glow {
    position: absolute;
    top: -40px;
    right: -20px;
    width: 450px;
    height: 450px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(245, 190, 70, 0.4) 0%, rgba(245, 190, 70, 0.15) 35%, rgba(245, 190, 70, 0.05) 55%, transparent 70%);
    pointer-events: none;
    z-index: 2;
    animation: lamp-pulse 3s ease-in-out infinite;
  }

  @keyframes lamp-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  .problem__lamp {
    position: absolute;
    top: 10px;
    right: 20px;
    width: clamp(150px, 15vw, 228px);
    z-index: 3;
    pointer-events: none;
  }


  .problem__header {
    margin-bottom: clamp(56px, 7vw, 80px);
    position: relative;
    z-index: 2;
  }

  .problem__header h2 {
    margin-bottom: 0;
    color: #fff;
    font-size: clamp(2rem, 3.5vw, 3rem);
  }

  .problem__header .hero__badge {
    background: rgba(24, 119, 242, 0.15);
    color: var(--color-blue);
    border: 1px solid rgba(24, 119, 242, 0.25);
  }

  .problem__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(20px, 3vw, 32px);
    text-align: left;
    position: relative;
    z-index: 2;
  }

  .problem__card {
    padding: clamp(32px, 3vw, 40px);
    position: relative;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    backdrop-filter: blur(10px);
    transition: all 0.35s ease;
  }

  .problem__card:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(24, 119, 242, 0.3);
    transform: translateY(-4px);
  }

  .problem__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .problem__number {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 800;
    background: linear-gradient(135deg, rgba(24, 119, 242, 0.9), rgba(24, 119, 242, 0.4));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    font-family: var(--font-display);
  }

  .problem__icon-wrap {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(24, 119, 242, 0.12);
    border: 1px solid rgba(24, 119, 242, 0.2);
    display: grid;
    place-items: center;
    color: var(--color-blue);
  }

  .problem__card h3 {
    margin-bottom: 12px;
    font-size: clamp(1.15rem, 1.5vw, 1.3rem);
    color: #fff;
  }

  .problem__card p {
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.75;
    font-size: 0.92rem;
  }

  @media (max-width: 768px) {
    .problem__grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .problem__lamp {
      width: clamp(80px, 12vw, 120px);
      top: 5px;
      right: 5px;
      opacity: 0.6;
    }
    .problem__lamp-glow {
      width: 200px;
      height: 200px;
      top: -30px;
      right: -30px;
      opacity: 0.5;
    }
    .problem__header {
      position: relative;
      z-index: 4;
    }
  }


  /* ========== INDUSTRIES ========== */
  .industries {
    padding-top: var(--section-gap);
    padding-bottom: calc(var(--section-gap) + 50px);
    margin-bottom: -50px;
    background: #0a0a14;
    color: #fff;
    position: relative;
    z-index: 2;
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 50px), 50% 100%, 0 calc(100% - 50px));
  }

  .industries__layout {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(48px, 6vw, 100px);
    align-items: center;
  }

  .industries h2 {
    color: #fff;
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    margin-bottom: 16px;
  }

  .industries__sub {
    color: rgba(255, 255, 255, 0.45);
    font-size: clamp(0.95rem, 1.1vw, 1.05rem);
    line-height: 1.7;
    margin-bottom: 32px;
    max-width: 40ch;
  }

  .industries__count {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .industries__number {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 800;
    line-height: 1;
    background: linear-gradient(135deg, var(--color-blue), #60a5fa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .industries__label {
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.04em;
    line-height: 1.3;
  }

  .industries__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .industries__tag {
    padding: 10px 20px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.8);
    transition: all 0.25s ease;
    cursor: default;
  }

  .industries__tag:hover,
  .industries__tag--lit {
    background: rgba(24, 119, 242, 0.12);
    border-color: rgba(24, 119, 242, 0.3);
    color: #fff;
    box-shadow: 0 0 20px rgba(24, 119, 242, 0.15);
  }

  .industries__cta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .industries__cta p {
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.35);
    margin: 0;
  }

  .industries__cta a {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-blue);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .industries__cta a:hover {
    color: #60a5fa;
  }

  @media (max-width: 768px) {
    .industries__layout {
      grid-template-columns: 1fr;
    }

    .industries__left {
      text-align: center;
    }

    .industries__sub {
      margin-inline: auto;
    }

    .industries__count {
      justify-content: center;
    }

    .industries__tags {
      justify-content: center;
    }
  }


  /* ========== SOLUTION ========== */
  .section--dark {
    background: #0a0a14;
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  .section--dark::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 200px 200px;
    pointer-events: none;
    z-index: 0;
  }

  .section--dark::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(24, 119, 242, 0.06) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 50%, rgba(24, 119, 242, 0.04) 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  .section--dark > * {
    position: relative;
    z-index: 1;
  }

  .section--dark h2 {
    color: #fff;
  }

  .section--dark p {
    color: rgba(255, 255, 255, 0.85);
  }

  /* ========== SECTION ARROWS ========== */
  .problem__arrow {
    position: relative;
    width: 100%;
    height: 40px;
    margin-top: clamp(40px, 6vw, 80px);
    background: #0a0a14;
    clip-path: polygon(0 0, 100% 0, 50% 100%, 0 0);
    z-index: 3;
  }

  .section--textured {
    position: relative;
    overflow: hidden;
  }

  .section--textured::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("/images/noise.png");
    background-repeat: repeat;
    background-size: 200px 200px;
    pointer-events: none;
    z-index: 0;
    opacity: 0.35;
    mix-blend-mode: overlay;
  }

  .section--textured.industries::after {
    mix-blend-mode: screen;
    opacity: 0.12;
    filter: invert(1);
  }

  .section--textured > * {
    position: relative;
    z-index: 1;
  }

  .section--blue {
    background: var(--color-blue);
    color: #fff;
  }

  .section--blue h2 {
    color: #fff;
  }

  .section--blue p {
    color: rgba(255, 255, 255, 0.85);
  }

  .solution {
    position: relative;
    padding-bottom: clamp(80px, 10vw, 140px);
    overflow: hidden;
  }

  .solution__rain {
    position: absolute !important;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0 !important;
    opacity: 0.25;
  }

  .solution__palm {
    position: absolute !important;
    left: -5%;
    bottom: -20%;
    height: 130%;
    opacity: 0.1;
    mix-blend-mode: multiply;
    pointer-events: none;
    z-index: 0 !important;
    transform-origin: bottom center;
    animation: solution-palm-sway 6s ease-in-out infinite;
  }

  @keyframes solution-palm-sway {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(1.5deg); }
    75% { transform: rotate(-1.5deg); }
  }

  .solution h2 {
    margin-bottom: clamp(20px, 3vw, 32px);
  }

  .solution p {
    font-size: clamp(1.05rem, 1.3vw, 1.2rem);
    line-height: 1.8;
    max-width: 60ch;
  }


  /* ========== GUIDE ========== */
  .guide {
    position: relative;
    background-color: var(--color-bg-soft);
    overflow: hidden;
    padding-bottom: calc(clamp(80px, 10vw, 140px) + 50px);
    margin-bottom: -50px;
    z-index: 2;
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 50px), 50% 100%, 0 calc(100% - 50px));
  }

  .guide__dots {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .guide__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: clamp(40px, 6vw, 80px);
    align-items: center;
  }

  .guide__content h2 {
    margin-bottom: clamp(16px, 2vw, 24px);
  }

  .guide__content p {
    font-size: clamp(1rem, 1.2vw, 1.1rem);
    line-height: 1.8;
    margin-bottom: 12px;
  }

  .guide__image img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    object-fit: cover;
    aspect-ratio: 1 / 1;
  }

  /* Scrolling Gallery */

  .gallery-fade {
    position: absolute;
    left: 0;
    right: 0;
    height: 80px;
    z-index: 10;
    pointer-events: none;
  }

  .gallery-fade--top {
    top: 0;
    background: linear-gradient(to bottom, var(--color-bg), transparent);
  }

  .gallery-fade--bottom {
    bottom: 0;
    background: linear-gradient(to top, var(--color-bg), transparent);
  }

  .gallery-col {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-sm);
  }

  .gallery-scroll {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .gallery-scroll--up {
    animation: galleryScrollUp 30s linear infinite;
  }

  .gallery-scroll--down {
    animation: galleryScrollDown 30s linear infinite;
  }

  @keyframes galleryScrollUp {
    0% { transform: translateY(0); }
    100% { transform: translateY(-50%); }
  }

  @keyframes galleryScrollDown {
    0% { transform: translateY(-50%); }
    100% { transform: translateY(0); }
  }

  .gallery-item {
    flex-shrink: 0;
    aspect-ratio: 3 / 4;
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .guide {
      clip-path: none;
      margin-bottom: 0;
      padding-bottom: var(--section-gap);
    }
    .guide__inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .guide__image img {
      max-width: 280px;
      margin-inline: auto;
    }
    .guide__actions {
      justify-content: center;
    }
    .guide__gallery {
      height: 400px;
      max-width: 100%;
    }
  }


  /* ========== PLAN ========== */
  .plan h2 {
    margin-bottom: 8px;
  }

  .plan {
    background: #0a0a14;
    color: #fff;
  }

  .plan__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(60px, 8vw, 120px);
    align-items: start;
  }

  .plan__left h2 {
    color: #fff;
    font-size: clamp(2.25rem, 4vw, 3.25rem);
    line-height: 1.1;
    margin-bottom: 20px;
  }

  .plan__typewriter {
    display: inline;
    border-right: 3px solid var(--color-blue);
    animation: plan-blink 0.7s step-end infinite;
  }

  .plan__typewriter--done {
    border-right-color: transparent;
    animation: none;
  }

  @keyframes plan-blink {
    50% { border-right-color: transparent; }
  }

  .plan__desc {
    color: rgba(255, 255, 255, 0.75);
    font-size: clamp(1rem, 1.2vw, 1.1rem);
    line-height: 1.7;
    margin-bottom: 36px;
    max-width: 40ch;
  }

  .plan__left .btn {
    background: #fff;
    color: #0a0a14;
    border-color: #fff;
  }

  .plan__left .btn:hover {
    background: rgba(255, 255, 255, 0.9);
    border-color: rgba(255, 255, 255, 0.9);
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(255, 255, 255, 0.15);
  }

  .plan__timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .plan__step {
    display: flex;
    gap: clamp(20px, 2.5vw, 32px);
    align-items: stretch;
  }

  .plan__marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 48px;
  }

  .plan__number {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-blue);
    background: rgba(24, 119, 242, 0.12);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    flex-shrink: 0;
    border: 1px solid rgba(24, 119, 242, 0.25);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                background 0.5s ease,
                color 0.5s ease,
                border-color 0.5s ease,
                box-shadow 0.5s ease;
  }

  .plan__step.is-active .plan__number {
    transform: scale(1.35);
    background: var(--color-blue);
    color: #fff;
    border-color: var(--color-blue);
    box-shadow: 0 0 24px rgba(24, 119, 242, 0.45), 0 0 60px rgba(24, 119, 242, 0.15);
  }

  .plan__step h3,
  .plan__step p {
    transition: color 0.5s ease, opacity 0.5s ease;
  }

  .plan__step.is-active h3 {
    color: #fff;
  }

  .plan__step.is-active p {
    color: rgba(255, 255, 255, 0.7);
  }

  .plan__line {
    width: 1px;
    flex: 1;
    background: linear-gradient(180deg, rgba(24, 119, 242, 0.4), rgba(24, 119, 242, 0.05));
    margin-top: 8px;
  }

  .plan__content {
    padding-bottom: clamp(36px, 4vw, 52px);
  }

  .plan__step:last-child .plan__content {
    padding-bottom: 0;
  }

  .plan__step h3 {
    color: #fff;
    font-size: clamp(1.2rem, 1.6vw, 1.4rem);
    margin-bottom: 8px;
    padding-top: 10px;
  }

  .plan__step p {
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.93rem;
    line-height: 1.75;
    max-width: 42ch;
  }

  @media (max-width: 768px) {
    .plan__layout {
      grid-template-columns: 1fr;
      gap: clamp(40px, 6vw, 60px);
    }

    .plan__left {
      text-align: center;
    }

    .plan__desc {
      margin-inline: auto;
    }
  }


  /* ========== SUCCESS ========== */
  .success {
    position: relative;
    z-index: 3;
    padding-bottom: calc(var(--section-gap) + 50px);
    margin-bottom: -50px;
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 50px), 50% 100%, 0 calc(100% - 50px));
  }

  .success__layout {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(48px, 8vw, 100px);
    align-items: start;
  }

  .success__left {
    position: sticky;
    top: clamp(120px, 15vw, 180px);
    order: 2;
  }

  .success__left h2 {
    margin-bottom: 20px;
  }

  .success__left .subheadline {
    margin-bottom: clamp(28px, 4vw, 40px);
  }

  .success__right {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .success__item {
    display: flex;
    gap: clamp(16px, 2vw, 24px);
    padding: clamp(20px, 3vw, 28px) 0;
    padding-left: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    opacity: 0.4;
    transform: scale(1);
    transition: opacity 0.4s ease, transform 0.4s ease, padding-left 0.4s ease;
  }

  .success__item.is-active {
    opacity: 1;
    transform: scale(1.03);
    padding-left: 16px;
  }

  .success__item:first-child {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .success__num {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw, 2.75rem);
    font-weight: 800;
    line-height: 1;
    color: rgba(255, 255, 255, 0.15);
    flex-shrink: 0;
    width: 48px;
    padding-top: 2px;
    transition: color 0.4s ease;
  }

  .success__item.is-active .success__num {
    color: rgba(255, 255, 255, 0.75);
  }

  .success__item-content p {
    font-size: clamp(0.95rem, 1.3vw, 1.1rem);
    line-height: 1.65;
    max-width: none;
  }

  .success__item-content em {
    font-style: italic;
    color: #FFFFFF;
  }

  .success__closer {
    margin-top: clamp(48px, 6vw, 72px);
    padding-top: clamp(32px, 4vw, 48px);
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    text-align: center;
  }

  .success__closer p {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.2vw, 1.75rem);
    font-weight: 600;
    line-height: 1.4;
    max-width: 700px;
    margin-inline: auto;
    color: rgba(255, 255, 255, 0.9);
  }

  .success__cta-btn {
    margin-top: 8px;
  }

  @media (max-width: 768px) {
    .success__layout {
      grid-template-columns: 1fr;
      gap: clamp(32px, 5vw, 48px);
    }

    .success__left {
      text-align: center;
      position: static;
      order: 0;
    }

    .success__left .subheadline {
      margin-inline: auto;
    }
  }


  /* ========== GROWTH SYSTEM ========== */
  .growth {
    padding-top: var(--section-gap);
    padding-bottom: calc(var(--section-gap) + 50px);
    margin-bottom: -50px;
    background: #0a0a14;
    position: relative;
    z-index: 2;
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 50px), 50% 100%, 0 calc(100% - 50px));
    overflow: hidden;
  }

  .growth::before {
    content: "";
    position: absolute;
    width: 800px;
    height: 800px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(24, 119, 242, 0.12) 0%, transparent 70%);
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    pointer-events: none;
    z-index: 0;
  }

  .growth .container {
    position: relative;
    z-index: 1;
  }

  .growth__header {
    margin-bottom: clamp(48px, 6vw, 72px);
  }

  .growth__header h2 {
    color: #fff;
    margin-bottom: 16px;
  }

  .growth__header .subheadline {
    color: rgba(255, 255, 255, 0.6);
  }

  .growth__header .hero__badge {
    background: rgba(24, 119, 242, 0.15);
    color: var(--color-blue);
    border-color: rgba(24, 119, 242, 0.25);
  }

  .growth__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(20px, 2.5vw, 32px);
    align-items: end;
  }

  .growth__card {
    background: #fff;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-lg);
    padding: clamp(28px, 3vw, 40px);
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .growth__card:hover {
    box-shadow: 0 12px 40px rgba(24, 119, 242, 0.15);
    transform: translateY(-4px);
  }

  .growth__card--featured {
    background: var(--color-bg-blue);
    border-color: var(--color-bg-blue);
    color: #fff;
    box-shadow: 0 8px 32px rgba(24, 119, 242, 0.25);
    padding-top: clamp(48px, 5vw, 64px);
    padding-bottom: clamp(48px, 5vw, 64px);
    margin-bottom: -20px;
  }

  .growth__card--featured h3 {
    color: #fff;
  }

  .growth__card--featured .growth__solution {
    color: rgba(255, 255, 255, 0.8);
  }

  .growth__card--featured .growth__problem {
    color: rgba(255, 255, 255, 0.65);
    border-color: rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.08);
  }

  .growth__card--featured .growth__services span {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
    border-color: rgba(255, 255, 255, 0.2);
  }

  .growth__card--featured .growth__step {
    color: rgba(255, 255, 255, 0.2);
  }

  .growth__card--featured:hover {
    box-shadow: 0 16px 48px rgba(24, 119, 242, 0.35);
    transform: translateY(-6px);
  }

  .growth__card--featured .growth__cta {
    background: #fff;
    color: var(--color-blue);
    border-color: #fff;
  }

  .growth__card--featured .growth__cta:hover {
    background: rgba(255, 255, 255, 0.9);
    border-color: rgba(255, 255, 255, 0.9);
  }

  .growth__step {
    font-family: var(--font-display);
    font-size: clamp(3rem, 5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-blue);
    opacity: 0.5;
    line-height: 1;
    margin-bottom: 12px;
  }

  .growth__card h3 {
    font-size: clamp(1.25rem, 1.8vw, 1.5rem);
    margin-bottom: 16px;
  }

  .growth__problem {
    font-style: italic;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    padding: 16px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-sm);
    margin-bottom: 16px;
    line-height: 1.6;
  }

  .growth__solution {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: 20px;
    flex: 1;
  }

  .growth__services {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
  }

  .growth__services span {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 5px 12px;
    border-radius: var(--radius-full);
    background: var(--color-blue-faded);
    color: var(--color-blue);
    border: 1px solid rgba(24, 119, 242, 0.12);
  }

  .growth__cta {
    align-self: flex-start;
    margin-top: auto;
  }

  @media (max-width: 900px) {
    .growth__grid {
      grid-template-columns: 1fr;
      max-width: 500px;
      margin-inline: auto;
      gap: 24px;
    }
    .growth__card--featured {
      margin-bottom: 0;
    }
  }


  /* ========== SERVICES GRID ========== */
  .svcs {
    padding-top: var(--section-gap);
    padding-bottom: var(--section-gap);
    background: #0a0a14;
    position: relative;
    overflow: hidden;
  }

  .svcs::before {
    content: "";
    position: absolute;
    width: 900px;
    height: 900px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(24, 119, 242, 0.08) 0%, transparent 70%);
    bottom: -300px;
    left: 50%;
    transform: translateX(-50%);
    pointer-events: none;
  }

  .svcs .container {
    position: relative;
    z-index: 1;
  }

  .svcs__rule {
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
    margin-bottom: var(--section-gap);
  }

  .svcs__header {
    margin-bottom: clamp(48px, 6vw, 72px);
  }

  .svcs__header .hero__badge {
    background: rgba(24, 119, 242, 0.15);
    color: var(--color-blue);
    border: 1px solid rgba(24, 119, 242, 0.25);
  }

  .svcs__header h2 {
    color: #fff;
    margin-bottom: 16px;
  }

  .svcs__header .subheadline {
    color: rgba(255, 255, 255, 0.5);
  }

  .svcs__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(16px, 2vw, 24px);
  }

  .svcs__card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-lg);
    padding: clamp(24px, 2.5vw, 32px);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .svcs__card:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(24, 119, 242, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(24, 119, 242, 0.1);
  }

  .svcs__icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-sm);
    background: rgba(24, 119, 242, 0.1);
    color: var(--color-blue);
    margin-bottom: 20px;
  }

  .svcs__card h3 {
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    font-weight: 600;
    color: #fff;
    margin-bottom: 8px;
  }

  .svcs__card p {
    font-size: 0.88rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.5);
    flex: 1;
    margin-bottom: 20px;
  }

  .svcs__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-blue);
    margin-top: auto;
    transition: gap 0.2s ease;
  }

  .svcs__card:hover .svcs__link {
    gap: 10px;
  }

  .svcs__ctas {
    margin-top: clamp(40px, 5vw, 64px);
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  @media (max-width: 1024px) {
    .svcs__cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .svcs__cards {
      grid-template-columns: 1fr;
    }
  }


  /* ========== TESTIMONIALS — Marquee rows ========== */

  .testimonials__header {
    text-align: center;
    margin-bottom: clamp(40px, 5vw, 60px);
  }

  .testimonials__rating {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-full);
    padding: 8px 16px;
    margin-bottom: 24px;
  }

  .testimonials__stars-big {
    display: flex;
    gap: 1px;
  }

  .testimonials h2 {
    margin-bottom: 16px;
    font-size: clamp(2rem, 3.5vw, 2.75rem);
  }

  .testimonials__sub {
    color: var(--color-text-secondary);
    font-size: clamp(1rem, 1.2vw, 1.1rem);
    line-height: 1.6;
  }

  .testimonials__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-blue);
    text-decoration: none;
    transition: gap 0.3s ease;
  }

  .testimonials__cta:hover {
    gap: 12px;
  }

  /* Marquee wrapper */
  .testimonials__marquee-wrap {
    position: relative;
    overflow: hidden;
    margin-bottom: 20px;
  }

  .testimonials__fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: clamp(60px, 10vw, 160px);
    z-index: 2;
    pointer-events: none;
  }

  .testimonials__fade--left {
    left: 0;
    background: linear-gradient(to right, var(--color-bg) 0%, transparent 100%);
  }

  .testimonials__fade--right {
    right: 0;
    background: linear-gradient(to left, var(--color-bg) 0%, transparent 100%);
  }

  .testimonials__marquee {
    overflow: hidden;
  }

  .testimonials__track {
    display: flex;
    gap: 20px;
    width: max-content;
    animation: marquee-scroll 35s linear infinite;
  }

  @keyframes marquee-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Pause on hover */
  .testimonials__marquee-wrap:hover .testimonials__track {
    animation-play-state: paused;
  }

  .testimonial {
    background: var(--color-bg);
    border: 1px solid var(--color-rule);
    border-radius: 16px;
    padding: clamp(24px, 2.5vw, 32px);
    transition: all 0.3s ease;
    position: relative;
    flex-shrink: 0;
    width: clamp(300px, 30vw, 400px);
  }

  .testimonial::before {
    content: '';
    position: absolute;
    top: 0;
    left: 24px;
    width: 32px;
    height: 3px;
    background: var(--color-blue);
    border-radius: 0 0 3px 3px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .testimonial:hover {
    border-color: rgba(24, 119, 242, 0.25);
    box-shadow: 0 12px 40px rgba(24, 119, 242, 0.08);
    transform: translateY(-3px);
  }

  .testimonial:hover::before {
    opacity: 1;
  }

  .testimonial--featured {
    background: linear-gradient(135deg, #0F3460 0%, #1464CC 60%, #0F3460 100%);
    border-color: transparent;
    overflow: hidden;
  }

  .testimonial--featured::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("/images/noise.png");
    background-repeat: repeat;
    background-size: 200px 200px;
    pointer-events: none;
    opacity: 0.12;
    mix-blend-mode: overlay;
    z-index: 0;
  }

  .testimonial--featured p,
  .testimonial--featured cite {
    position: relative;
    z-index: 1;
  }

  .testimonial--featured::before {
    opacity: 0;
  }

  .testimonial--featured:hover {
    border-color: transparent;
    box-shadow: 0 12px 40px rgba(24, 119, 242, 0.3);
  }

  .testimonial p {
    font-size: 0.9rem;
    line-height: 1.75;
    margin-bottom: 16px;
    max-width: none;
    color: var(--color-text-secondary);
  }

  .testimonial cite {
    font-style: normal;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .testimonial cite strong {
    font-weight: 600;
    color: var(--color-text);
  }

  .testimonial cite span {
    color: var(--color-text-secondary);
    font-size: 0.75rem;
    opacity: 0.7;
  }

  .testimonial--featured p {
    color: #FFFFFF;
  }

  .testimonial--featured cite strong {
    color: #FFFFFF;
  }

  .testimonial--featured cite span {
    color: rgba(255, 255, 255, 0.6);
    opacity: 1;
  }

  @media (max-width: 900px) {
    .testimonials__header {
      text-align: center;
    }
  }


  /* ========== BADGE ========== */

  /* ========== MAP ========== */
  .map-section {
    width: 100%;
    line-height: 0;
    position: relative;
  }

  .map-section iframe {
    width: 100%;
    height: 450px;
    filter: grayscale(1) contrast(1.1);
    transition: filter 0.4s ease;
  }

  .map-section:hover iframe {
    filter: grayscale(0) contrast(1);
  }

  /* Floating business card */
  .map-card {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    z-index: 10;
    background: #0a0a14;
    border: none;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0;
    padding: clamp(32px, 3vw, 48px);
    width: clamp(300px, 26vw, 380px);
    box-shadow: 16px 0 48px rgba(0, 0, 0, 0.3);
    line-height: 1.5;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .map-card__logo {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .map-card__name {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .map-card__name strong {
    font-size: 0.95rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: 0.06em;
  }

  .map-card__name span {
    font-size: 0.65rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.4);
    letter-spacing: 0.12em;
  }

  .map-card__info {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 20px;
  }

  .map-card__row {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.8);
  }

  .map-card__row svg {
    flex-shrink: 0;
    color: var(--color-blue);
  }

  .map-card__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 10px 20px;
    background: var(--color-blue);
    color: #fff;
    border-radius: var(--radius-full);
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 600;
    transition: all 0.25s ease;
  }

  .map-card__btn:hover {
    background: var(--color-bg-blue-dark);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(24, 119, 242, 0.3);
  }

  .map-card__stars {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3px;
    margin-top: 14px;
  }

  .map-card__stars span {
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.4);
    margin-left: 6px;
  }

  @media (max-width: 600px) {
    .map-card {
      position: relative;
      top: 0;
      left: 0;
      width: 100%;
      border-radius: 0;
      border-left: 0;
      border-right: 0;
    }
  }


  /* ========== BLOG PREVIEW ========== */

  .blog-preview {
    padding: clamp(80px, 10vw, 140px) 0;
  }

  .blog-preview__header {
    margin-bottom: clamp(40px, 5vw, 64px);
  }

  .blog-preview__header h2 {
    font-size: clamp(2rem, 4vw, 3.25rem);
  }

  .blog-preview__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .blog-preview__card {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    border: 1px solid rgba(0, 0, 0, 0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .blog-preview__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
  }

  .blog-preview__img {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: linear-gradient(135deg, #e8e8e8 0%, #d4d4d4 100%);
  }

  .blog-preview__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .blog-preview__card:hover .blog-preview__img img {
    transform: scale(1.05);
  }

  .blog-preview__body {
    padding: 28px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .blog-preview__tag {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 12px;
  }

  .blog-preview__body h3 {
    font-size: clamp(1.05rem, 1.5vw, 1.25rem);
    line-height: 1.35;
    margin-bottom: 12px;
  }

  .blog-preview__body p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #666;
    flex: 1;
  }

  .blog-preview__read {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    margin-top: 16px;
    transition: gap 0.3s ease;
  }

  .blog-preview__card:hover .blog-preview__read {
    gap: 10px;
  }

  .blog-preview__cta {
    margin-top: clamp(40px, 5vw, 64px);
  }

  @media (max-width: 900px) {
    .blog-preview__grid {
      grid-template-columns: 1fr;
      max-width: 500px;
      margin: 0 auto;
    }
  }


  /* ========== FAQ ========== */
  .faq__layout {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(48px, 8vw, 100px);
    align-items: start;
  }

  .faq__left {
    position: sticky;
    top: clamp(120px, 15vw, 180px);
  }

  .faq__left h2 {
    margin-bottom: 16px;
  }

  .faq__left .subheadline {
    margin-bottom: clamp(24px, 3vw, 32px);
  }

  .faq__authority {
    margin-top: clamp(40px, 5vw, 56px);
    padding-top: clamp(32px, 4vw, 40px);
    border-top: 1px solid var(--color-rule);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(20px, 3vw, 28px);
  }

  .faq__authority-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .faq__authority-num {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 2.5vw, 2.25rem);
    font-weight: 800;
    line-height: 1;
    color: var(--color-blue);
  }

  .faq__authority-label {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    letter-spacing: 0.01em;
  }

  .faq__group {
    margin-bottom: clamp(32px, 4vw, 48px);
  }

  .faq__group:last-child {
    margin-bottom: 0;
  }

  .faq__group-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-blue);
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--color-blue);
  }

  .faq__item {
    border-bottom: 1px solid var(--color-rule);
  }

  .faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 0;
    font-family: var(--font-heading);
    font-size: clamp(0.95rem, 1.3vw, 1.1rem);
    font-weight: 600;
    color: var(--color-text);
    list-style: none;
    transition: color 0.2s ease;
  }

  .faq__question::-webkit-details-marker {
    display: none;
  }

  .faq__question::after {
    content: '+';
    font-size: 1.4rem;
    font-weight: 300;
    color: var(--color-blue);
    flex-shrink: 0;
    margin-left: 16px;
    transition: transform 0.3s ease;
  }

  .faq__item[open] .faq__question::after {
    content: '\2212';
    transform: rotate(180deg);
  }

  .faq__item[open] .faq__question {
    color: var(--color-blue);
  }

  .faq__answer {
    padding: 0 0 20px 0;
  }

  .faq__answer p {
    font-size: clamp(0.9rem, 1.2vw, 1rem);
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: none;
  }

  @media (max-width: 768px) {
    .faq__layout {
      grid-template-columns: 1fr;
      gap: clamp(32px, 5vw, 48px);
    }

    .faq__left {
      position: static;
      text-align: center;
    }

    .faq__left .subheadline {
      margin-inline: auto;
    }
  }


  /* ========== SOUND TOGGLE ========== */
  .sound-toggle {
    position: fixed;
    bottom: 28px;
    left: 28px;
    z-index: 900;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.25s ease;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
  }

  .sound-toggle:hover {
    transform: translateY(-1px);
    border-color: rgba(24, 119, 242, 0.3);
    color: rgba(255, 255, 255, 0.8);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.15);
  }

  .sound-toggle.is-playing {
    background: var(--color-blue);
    border-color: var(--color-blue);
    color: #fff;
    box-shadow: 0 4px 20px rgba(24, 119, 242, 0.35);
  }

  .sound-toggle.is-playing:hover {
    background: var(--color-bg-blue-dark);
    border-color: var(--color-bg-blue-dark);
    box-shadow: 0 6px 28px rgba(24, 119, 242, 0.45);
  }

  .sound-toggle__icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .sound-toggle__icon--on {
    display: none;
  }

  .sound-toggle.is-playing .sound-toggle__icon--off {
    display: none;
  }

  .sound-toggle.is-playing .sound-toggle__icon--on {
    display: block;
  }

  /* Adapt to light backgrounds */
  .sound-toggle--on-light {
    border-color: rgba(0, 0, 0, 0.1);
    background: rgba(0, 0, 0, 0.04);
    color: rgba(0, 0, 0, 0.4);
  }

  .sound-toggle--on-light:hover {
    border-color: rgba(24, 119, 242, 0.3);
    color: rgba(0, 0, 0, 0.6);
  }

