      scrollTrigger: { trigger: '.testimonials', start: 'top 85%', toggleActions: 'play none none none' },
      y: 0,
      opacity: 1,
      duration: 0.6,
    }
  );

</script>

<script>
  // Scroll-linked dot grid for Guide section
  (() => {
    const canvas = document.querySelector('.guide__dots') as HTMLCanvasElement;
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const SPACING = 28;
    const BASE_RADIUS = 0.8;
    const MAX_RADIUS = 2;
    const INFLUENCE = 120;
    const BASE_ALPHA = 0.04;
    const MAX_ALPHA = 0.18;

    let dots: { x: number; y: number }[] = [];
    let scrollProgress = 0;
    let running = false;
    let needsDraw = true;

    function resize() {
      const rect = canvas.parentElement!.getBoundingClientRect();
      const dpr = window.devicePixelRatio || 1;
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      canvas.style.width = rect.width + 'px';
      canvas.style.height = rect.height + 'px';
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      buildGrid(rect.width, rect.height);
    }

    function buildGrid(w: number, h: number) {
      dots = [];
      for (let x = SPACING / 2; x < w; x += SPACING) {
        for (let y = SPACING / 2; y < h; y += SPACING) {
          dots.push({ x, y });
        }
      }
    }

    function draw() {
      if (!running) return;
      if (!needsDraw) { requestAnimationFrame(draw); return; }
      needsDraw = false;

      const w = canvas.clientWidth;
      const h = canvas.clientHeight;
      ctx!.clearRect(0, 0, w, h);

      // Sweep zone moves left-to-right based on scroll progress
      const sweepX = scrollProgress * (w + INFLUENCE * 2) - INFLUENCE;

      for (const dot of dots) {
        const dx = dot.x - sweepX;
        const dy = dot.y - (h * 0.5);
        const dist = Math.sqrt(dx * dx + (dy * dy) * 0.3);

        const t = Math.max(0, 1 - dist / INFLUENCE);
        const r = BASE_RADIUS + (MAX_RADIUS - BASE_RADIUS) * t;
        const a = BASE_ALPHA + (MAX_ALPHA - BASE_ALPHA) * t;

        ctx!.beginPath();
        ctx!.arc(dot.x, dot.y, r, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(24, 119, 242, ${a})`;
        ctx!.fill();
      }

      requestAnimationFrame(draw);
    }

    function onScroll() {
      const section = canvas.parentElement!;
      const rect = section.getBoundingClientRect();
      const vh = window.innerHeight;
      const raw = (vh - rect.top) / (vh + rect.height);
      scrollProgress = Math.max(0, Math.min(1, raw));
      needsDraw = true;
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting && !running) {
          running = true;
          window.addEventListener('scroll', onScroll, { passive: true });
          onScroll();
          draw();
        } else if (!entry.isIntersecting) {
          running = false;
          window.removeEventListener('scroll', onScroll);
        }
      });
    }, { threshold: 0 });

    resize();
    observer.observe(canvas.parentElement!);

    let resizeTimer: number;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => {
        resize();
        needsDraw = true;
      }, 150);
    });
  })();
</script>

<script>
  // Floating CTA + Sidebar
  (() => {
    const btn = document.getElementById('floatCta');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebarOverlay');
    const closeBtn = document.getElementById('sidebarClose');
    if (!btn || !sidebar || !overlay || !closeBtn) return;

    function open() {
      sidebar.classList.add('sidebar--open');
      sidebar.setAttribute('aria-hidden', 'false');
      overlay.classList.add('sidebar-overlay--open');
      btn.classList.add('float-cta--hidden');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      sidebar.classList.remove('sidebar--open');
      sidebar.setAttribute('aria-hidden', 'true');
      overlay.classList.remove('sidebar-overlay--open');
      btn.classList.remove('float-cta--hidden');
      document.body.style.overflow = '';
    }

    btn.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    overlay.addEventListener('click', close);

    // Also open sidebar from the CTA section button
    const ctaPlanBtn = document.getElementById('ctaGetPlan');
    if (ctaPlanBtn) ctaPlanBtn.addEventListener('click', open);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  })();
</script>


<script>
  (() => {
    const footer = document.querySelector('.footer');
    const bolt = document.querySelector('.footer__logo-icon');
    if (!footer || !bolt) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          bolt.classList.remove('footer__logo-icon--flip');
          void bolt.offsetWidth;
          bolt.classList.add('footer__logo-icon--flip');
        }
      });
    }, { threshold: 0.2 });

    observer.observe(footer);
  })();
</script>

<script>
  // Background music toggle
  (() => {
    const btn = document.getElementById('soundToggle') as HTMLButtonElement;
    const audio = document.getElementById('bgMusic') as HTMLAudioElement;
    if (!btn || !audio) return;

    audio.volume = 0.3;

    btn.addEventListener('click', () => {
      if (audio.paused) {
        audio.play();
        btn.classList.add('is-playing');
      } else {
        audio.pause();
        btn.classList.remove('is-playing');
      }
    });
  })();

  // Detect background color behind sound toggle and adapt styling
  (() => {
    const toggle = document.querySelector('.sound-toggle') as HTMLElement;
    if (!toggle) return;

    const lightSelectors = '.guide, .growth, .blog-preview, .testimonials, .faq, .section--soft';

    function checkBackground() {
      const rect = toggle.getBoundingClientRect();
      const midX = rect.left + rect.width / 2;
      const midY = rect.top + rect.height / 2;

      toggle.style.pointerEvents = 'none';
      toggle.style.visibility = 'hidden';
      const el = document.elementFromPoint(midX, midY);
      toggle.style.visibility = '';
      toggle.style.pointerEvents = '';

      if (el) {
        const onLight = !!el.closest(lightSelectors);
        toggle.classList.toggle('sound-toggle--on-light', onLight);
      }
    }

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(() => {
          checkBackground();
          ticking = false;
        });
      }
    }, { passive: true });

    checkBackground();
  })();
</script>

