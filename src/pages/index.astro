          <a href="https://wa.me/18567702456" class="topbar__social" aria-label="WhatsApp" target="_blank" rel="noopener noreferrer">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== MAIN NAV (STICKY) ========== -->
  <header class="header" id="header">
    <div class="container-full header__inner">
      <a href="/" class="header__logo" aria-label="Lockard Design Co. Home">
        <strong>LOCKARD</strong> DESIGN CO.
      </a>
      <nav class="header__nav" aria-label="Main navigation">
        <ul class="header__menu">
          <li class="header__menu-item has-mega">
            <button class="header__menu-link" aria-expanded="false" aria-haspopup="true">
              Services
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <!-- MEGA MENU -->
            <div class="mega" aria-hidden="true">
              <div class="container-full mega__inner">
                <div class="mega__col">
                  <h4 class="mega__heading">Web Design</h4>
                  <ul class="mega__links">
                    <li><a href="#" class="mega__link">Custom Website Design</a></li>
                    <li><a href="#" class="mega__link">Website Redesign</a></li>
                    <li><a href="#" class="mega__link">Landing Pages</a></li>
                    <li><a href="#" class="mega__link">E-Commerce</a></li>
                  </ul>
                </div>
                <div class="mega__col">
                  <h4 class="mega__heading">SEO & Growth</h4>
                  <ul class="mega__links">
                    <li><a href="#" class="mega__link">Local SEO</a></li>
                    <li><a href="#" class="mega__link">National SEO</a></li>
                    <li><a href="#" class="mega__link">Google Business Profile</a></li>
                    <li><a href="#" class="mega__link">Content Strategy</a></li>
                  </ul>
                </div>
                <div class="mega__col">
                  <h4 class="mega__heading">Ongoing Support</h4>
                  <ul class="mega__links">
                    <li><a href="#" class="mega__link">Website Management</a></li>
                    <li><a href="#" class="mega__link">Monthly Reporting</a></li>
                    <li><a href="#" class="mega__link">Performance Monitoring</a></li>
                    <li><a href="#" class="mega__link">Security & Updates</a></li>
                  </ul>
                </div>
                <div class="mega__col mega__cta-col">
                  <div class="mega__cta-card">
                    <h4 class="mega__heading">Not Sure Where to Start?</h4>
                    <p>Get a free growth plan tailored to your business.</p>
                    <a href="#contact" class="btn" style="margin-top:12px; font-size:0.8rem; padding:10px 20px;">Get Your Free Plan</a>
                  </div>
                </div>
              </div>
            </div>
          </li>
          <li class="header__menu-item has-mega">
            <button class="header__menu-link" aria-expanded="false" aria-haspopup="true">
              About Us
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="mega" aria-hidden="true">
              <div class="container-full mega__inner" style="grid-template-columns: 1fr 1fr 1fr;">
                <div class="mega__col">
                  <h4 class="mega__heading">Who We Are</h4>
                  <ul class="mega__links">
                    <li><a href="#about" class="mega__link">Meet the Founder</a></li>
                    <li><a href="#" class="mega__link">Our Story</a></li>
                    <li><a href="#" class="mega__link">Why Lockard Design Co.</a></li>
                  </ul>
                </div>
                <div class="mega__col">
                  <h4 class="mega__heading">Our Process</h4>
                  <ul class="mega__links">
                    <li><a href="#plan" class="mega__link">How It Works</a></li>
                    <li><a href="#success" class="mega__link">What You Get</a></li>
                    <li><a href="#testimonials" class="mega__link">Client Results</a></li>
                  </ul>
                </div>
                <div class="mega__col mega__cta-col">
                  <div class="mega__cta-card">
                    <h4 class="mega__heading">Work With Us</h4>
                    <p>See if we're the right fit for your business.</p>
                    <a href="#contact" class="btn" style="margin-top:12px; font-size:0.8rem; padding:10px 20px;">Let's Talk</a>
                  </div>
                </div>
              </div>
            </div>
          </li>
          <li class="header__menu-item"><a href="#testimonials" class="header__menu-link">Results</a></li>
          <li class="header__menu-item"><a href="#" class="header__menu-link">Resources</a></li>
        </ul>
      </nav>
      <div class="header__actions">
        <a href="#contact" class="btn header__cta">Get Your Growth Plan</a>
      </div>
    </div>
  </header>


  <!-- ========== HERO ========== -->
  <section class="hero" id="hero">
    <div class="container hero__inner">
      <div class="hero__content">
        <div class="hero__badge">Web Design & SEO for Service Businesses</div>
        <h1>Your Business is Great. <span class="text-blue">Your Website Isn't.</span></h1>
        <p class="subheadline hero__sub">
          For established service businesses, a generic website and unpredictable marketing isn't just embarrassing — it's a cap on your growth. We build the websites and growth systems that turn expert local companies into dominant regional players.
        </p>
        <div class="hero__actions">
          <a href="#contact" class="btn">Get Your Free Growth Plan</a>
          <a href="#plan" class="btn btn--outline">See How It Works</a>
        </div>
      </div>
      <div class="hero__image">
        <img
          src="/images/hero-sunset.jpg"
          alt="Will and partner at sunset — the team behind Lockard Design Co."
          width="520"
          height="520"
          loading="eager"
        />
      </div>
    </div>
  </section>


  <!-- ========== PROBLEM ========== -->
  <section class="problem section--soft" id="problem">
    <div class="container text-center">
      <h2>Does This Sound Familiar?</h2>
      <div class="problem__grid">
        <div class="problem__card card">
          <div class="problem__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="9" x2="15" y2="15"/><line x1="15" y1="9" x2="9" y2="15"/></svg>
          </div>
          <h3>Your Website is an Embarrassment.</h3>
          <p>
            You're a professional, but your website looks like it was built a decade ago. It doesn't reflect the quality of your work and you hesitate to even put it on your business card.
          </p>
        </div>
        <div class="problem__card card">
          <div class="problem__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </div>
          <h3>Your Marketing is a Black Box.</h3>
          <p>
            You're paying an agency (or you were), but you have no idea what they're actually doing. You get confusing reports, but the phone isn't ringing any more than it was before.
          </p>
        </div>
        <div class="problem__card card">
          <div class="problem__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3>Your Growth Has Plateaued.</h3>
          <p>
            You're stuck at the same revenue level, working harder than ever. You know you need to grow to the next level, but you don't have a predictable way to get there.
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ========== SOLUTION ========== -->
  <section class="solution section--blue" id="solution">
    <div class="container text-center">
      <h2>It's Time to Own Your Lead Flow.</h2>
      <p class="mx-auto" style="text-align:center;">
        We don't just build websites; we build growth systems. We believe that a great service business deserves a predictable stream of high-quality leads that they own and control. No more renting attention from HomeAdvisor or wondering if your marketing is working. We build the asset, you own the results.
      </p>
      <a href="#contact" class="btn btn--white" style="margin-top: 40px;">Let's Talk About Your Growth</a>
    </div>
  </section>


  <!-- ========== GUIDE ========== -->
  <section class="guide" id="about">
    <div class="container guide__inner">
      <div class="guide__gallery">
        <div class="gallery-fade gallery-fade--top"></div>
        <div class="gallery-fade gallery-fade--bottom"></div>
        <div class="gallery-columns">
          <div class="gallery-col">
            <div class="gallery-scroll gallery-scroll--up">
              <div class="gallery-item"><img src="/images/gallery-1.jpg" alt="Custom website design project" loading="lazy" /></div>
              <div class="gallery-item"><img src="/images/gallery-2.jpg" alt="SEO results dashboard" loading="lazy" /></div>
              <div class="gallery-item"><img src="/images/gallery-3.jpg" alt="Client business growth" loading="lazy" /></div>
              <div class="gallery-item"><img src="/images/gallery-4.jpg" alt="Professional web design" loading="lazy" /></div>
              <div class="gallery-item"><img src="/images/gallery-1.jpg" alt="Custom website design project" loading="lazy" /></div>
              <div class="gallery-item"><img src="/images/gallery-2.jpg" alt="SEO results dashboard" loading="lazy" /></div>
              <div class="gallery-item"><img src="/images/gallery-3.jpg" alt="Client business growth" loading="lazy" /></div>
              <div class="gallery-item"><img src="/images/gallery-4.jpg" alt="Professional web design" loading="lazy" /></div>
            </div>
          </div>
          <div class="gallery-col">
            <div class="gallery-scroll gallery-scroll--down">
              <div class="gallery-item"><img src="/images/gallery-5.jpg" alt="Service business website" loading="lazy" /></div>
              <div class="gallery-item"><img src="/images/gallery-6.jpg" alt="Digital marketing strategy" loading="lazy" /></div>
              <div class="gallery-item"><img src="/images/gallery-7.jpg" alt="Local business online presence" loading="lazy" /></div>
              <div class="gallery-item"><img src="/images/gallery-8.jpg" alt="Website performance optimization" loading="lazy" /></div>
              <div class="gallery-item"><img src="/images/gallery-5.jpg" alt="Service business website" loading="lazy" /></div>
              <div class="gallery-item"><img src="/images/gallery-6.jpg" alt="Digital marketing strategy" loading="lazy" /></div>
              <div class="gallery-item"><img src="/images/gallery-7.jpg" alt="Local business online presence" loading="lazy" /></div>
              <div class="gallery-item"><img src="/images/gallery-8.jpg" alt="Website performance optimization" loading="lazy" /></div>
            </div>
          </div>
        </div>
      </div>
      <div class="guide__content">
        <div class="hero__badge">Meet the Founder</div>
        <h2>We Build Growth Systems for Service Businesses Like Yours.</h2>
        <p>
          Lockard Design Co. is a US-based digital agency that works exclusively with established B2B and home service companies. We're not a big, faceless firm. You'll work directly with our founder, Will, to build a system that delivers real, measurable results.
        </p>
        <p>
          We've helped companies double their revenue, expand their service area, and finally get the owner out of the day-to-day.
        </p>
        <a href="#contact" class="btn" style="margin-top: 24px;">Work With Will</a>
      </div>
    </div>
  </section>


  <!-- ========== PLAN ========== -->
  <section class="plan section--soft" id="plan">
    <div class="container text-center">
      <h2>Your Path to Predictable Growth</h2>
      <p class="subheadline mx-auto" style="text-align:center; margin-bottom: clamp(48px, 6vw, 80px);">Three steps. No confusion. Just results.</p>
      <div class="plan__steps">
        <div class="plan__step card">
          <span class="plan__number">01</span>
          <h3>Get Your Custom Growth Plan</h3>
          <p>
            We'll start with a free, no-obligation strategy session to understand your business and your goals. We'll deliver a clear plan showing you exactly how to get there.
          </p>
        </div>
        <div class="plan__step card">
          <span class="plan__number">02</span>
          <h3>We Build Your Growth Engine</h3>
          <p>
            We'll build you a world-class website and install our proven SEO and lead management system. You'll have a professional online presence that converts visitors into leads.
          </p>
        </div>
        <div class="plan__step card">
          <span class="plan__number">03</span>
          <h3>You Dominate Your Market</h3>
          <p>
            With your new growth engine running, you'll see a consistent flow of high-quality leads, allowing you to scale your business, increase your profits, and achieve your long-term goals.
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ========== SUCCESS ========== -->
  <section class="success" id="success">
    <div class="container success__inner text-center">
      <h2>Imagine a Year From Now...</h2>
      <ul class="success__list">
        <li>Your phone is ringing with high-quality leads, not tire-kickers.</li>
        <li>You're bidding on bigger, more profitable jobs.</li>
        <li>You're recognized as the go-to expert in your market.</li>
        <li>You're working <em>on</em> the business, not <em>in</em> it.</li>
        <li>You're finally in control of your growth.</li>
      </ul>
    </div>
  </section>


  <!-- ========== TESTIMONIALS ========== -->
  <section class="testimonials section--soft" id="testimonials">
    <div class="container text-center">
      <h2>Don't Just Take Our Word For It.</h2>
      <div class="testimonials__grid">

        <blockquote class="testimonial card">
          <div class="testimonial__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>
            "Will and his team have been a contributing factor in our growth over the past 18 months. Can't thank him and his team enough! Let's go!!"
          </p>
          <cite>
            <strong>Jared Brown</strong>
          </cite>
        </blockquote>

        <blockquote class="testimonial card">
          <div class="testimonial__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>
            "Will is a master of his craft. His skillset is so broad and his approach so unbiased that we've solved problems we didn't know we had. Can't think of anyone else I'd rather work with."
          </p>
          <cite>
            <strong>Silvio Dobrovat</strong>
          </cite>
        </blockquote>

        <blockquote class="testimonial card">
          <div class="testimonial__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>
            "Will and his team made my vision come to life with my website. They took their time and paid close attention to every detail and made recommendations that I didn't consider prior. They really exceeded my expectations."
          </p>
          <cite>
            <strong>Dawn O'Brien</strong>
          </cite>
        </blockquote>

        <blockquote class="testimonial card">
          <div class="testimonial__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>
            "He's passionate about what he does and really takes the time to understand his customers. He listens, asks good questions, and makes sure you feel confident in your decisions. He's also very dependable."
          </p>
          <cite>
            <strong>Andrea S.</strong>
            <span>Google Local Guide</span>
          </cite>
        </blockquote>

        <blockquote class="testimonial card">
          <div class="testimonial__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>
            "Will overdelivers and understands websites from a marketer's point of view. I see most businesses using websites as a business card vs one designed to collect and nurture leads. Highly recommend."
          </p>
          <cite>
            <strong>Adam Maggio</strong>
          </cite>
        </blockquote>

        <blockquote class="testimonial card">
          <div class="testimonial__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>
            "I work with Lockard Design on a consistent basis because they consistently deliver quality work. Anybody looking for a website or Local SEO should take a look at Will and his team."
          </p>
          <cite>
            <strong>Richard Burner</strong>
          </cite>
        </blockquote>

      </div>
    </div>
  </section>


  <!-- ========== BADGE ========== -->
  <section class="badge-section">
    <div class="container text-center">
      <img
        src="/images/designrush-badge.png"
        alt="Top New Jersey Web Design Agencies 2025 — DesignRush"
        width="180"
        height="180"
        loading="lazy"
      />
    </div>
  </section>


  <!-- ========== FINAL CTA ========== -->
  <section class="cta-final section--blue" id="contact">
    <div class="container text-center">
      <h2>Ready to Own Your Growth?</h2>
      <p class="mx-auto" style="text-align:center;">
        Schedule a free strategy session and we'll build you a custom growth plan. No obligation, no pitch — just a clear path to predictable growth.
      </p>
      <div class="cta-final__actions">
        <a href="tel:+18567702456" class="btn btn--white">Call (856) 770-2456</a>
        <a href="mailto:will@lockarddesignco.com" class="btn btn--white-outline">Email Us</a>
      </div>
    </div>
  </section>


  <!-- ========== FOOTER ========== -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__brand">
        <span class="footer__logo">Lockard Design Co.</span>
        <p class="footer__address">
