          </a>
          <a href="https://linkedin.com/in/willlockard" class="topbar__social" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://instagram.com/lockarddesignco" class="topbar__social" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          </a>
          <a href="https://wa.me/18567702456" class="topbar__social" aria-label="WhatsApp" target="_blank" rel="noopener noreferrer">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- ========== MAIN NAV (STICKY) ========== -->
  <header class="header" id="header">
    <div class="container-full header__inner">
      <a href="/" class="header__logo" aria-label="Lockard Design Co. Home">
        <img src="/images/logo.svg" alt="" class="header__logo-icon" width="42" height="42" />
        <span class="header__logo-text">
          <span class="header__logo-name">LOCKARD</span>
          <span class="header__logo-sub">DESIGN CO.</span>
        </span>
      </a>
      <nav class="header__nav" aria-label="Main navigation">
        <ul class="header__menu">
          <li class="header__menu-item has-mega">
            <button class="header__menu-link" aria-expanded="false" aria-haspopup="true">
              Services
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <!-- MEGA MENU -->
            <div class="mega" aria-hidden="true">
              <div class="container-full mega__inner">
                <div class="mega__col">
                  <h4 class="mega__heading">Web Design</h4>
                  <ul class="mega__links">
                    <li><a href="#" class="mega__link">Custom Website Design</a></li>
                    <li><a href="#" class="mega__link">Website Redesign</a></li>
                    <li><a href="#" class="mega__link">Landing Pages</a></li>
                    <li><a href="#" class="mega__link">E-Commerce</a></li>
                  </ul>
                </div>
                <div class="mega__col">
                  <h4 class="mega__heading">SEO & Growth</h4>
                  <ul class="mega__links">
                    <li><a href="#" class="mega__link">Local SEO</a></li>
                    <li><a href="#" class="mega__link">National SEO</a></li>
                    <li><a href="#" class="mega__link">Google Business Profile</a></li>
                    <li><a href="#" class="mega__link">Content Strategy</a></li>
                  </ul>
                </div>
                <div class="mega__col">
                  <h4 class="mega__heading">Ongoing Support</h4>
                  <ul class="mega__links">
                    <li><a href="#" class="mega__link">Website Management</a></li>
                    <li><a href="#" class="mega__link">Monthly Reporting</a></li>
                    <li><a href="#" class="mega__link">Performance Monitoring</a></li>
                    <li><a href="#" class="mega__link">Security & Updates</a></li>
                  </ul>
                </div>
                <div class="mega__col mega__cta-col">
                  <div class="mega__cta-card">
                    <h4 class="mega__heading">Not Sure Where to Start?</h4>
                    <p>Get a free growth plan tailored to your business.</p>
                    <a href="#contact" class="btn" style="margin-top:12px; font-size:0.8rem; padding:10px 20px;">Get Your Free Plan</a>
                  </div>
                </div>
              </div>
            </div>
          </li>
          <li class="header__menu-item has-mega">
            <button class="header__menu-link" aria-expanded="false" aria-haspopup="true">
              About Us
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="mega" aria-hidden="true">
              <div class="container-full mega__inner" style="grid-template-columns: 1fr 1fr 1fr;">
                <div class="mega__col">
                  <h4 class="mega__heading">Who We Are</h4>
                  <ul class="mega__links">
                    <li><a href="#about" class="mega__link">Meet the Founder</a></li>
                    <li><a href="#" class="mega__link">Our Story</a></li>
                    <li><a href="#" class="mega__link">Why Lockard Design Co.</a></li>
                  </ul>
                </div>
                <div class="mega__col">
                  <h4 class="mega__heading">Our Process</h4>
                  <ul class="mega__links">
                    <li><a href="#plan" class="mega__link">How It Works</a></li>
                    <li><a href="#success" class="mega__link">What You Get</a></li>
                    <li><a href="#testimonials" class="mega__link">Client Results</a></li>
                  </ul>
                </div>
                <div class="mega__col mega__cta-col">
                  <div class="mega__cta-card">
                    <h4 class="mega__heading">Work With Us</h4>
                    <p>See if we're the right fit for your business.</p>
                    <a href="#contact" class="btn" style="margin-top:12px; font-size:0.8rem; padding:10px 20px;">Let's Talk</a>
                  </div>
                </div>
              </div>
            </div>
          </li>
          <li class="header__menu-item"><a href="#testimonials" class="header__menu-link">Results</a></li>
          <li class="header__menu-item"><a href="#" class="header__menu-link">Resources</a></li>
        </ul>
      </nav>
      <div class="header__actions">
        <a href="#contact" class="header__cta">Get Your Growth Plan</a>
      </div>
    </div>
  </header>


  <!-- ========== HERO ========== -->
  <section class="hero" id="hero">
    <div class="container hero__inner">
      <div class="hero__content">
        <div class="hero__badge">Web Design & SEO for Service Businesses</div>
        <h1>Your Business is Great. <span class="text-blue">Your Website Isn't.</span></h1>
        <p class="subheadline hero__sub">
          For established service businesses, a generic website and unpredictable marketing isn't just embarrassing — it's a cap on your growth. We build the websites and growth systems that turn expert local companies into dominant regional players.
        </p>
        <div class="hero__actions">
          <a href="#contact" class="btn">Get Your Free Growth Plan</a>
          <a href="#plan" class="btn btn--outline">See How It Works</a>
        </div>
      </div>
      <div class="hero__gallery">
        <div class="gallery-fade gallery-fade--top"></div>
        <div class="gallery-fade gallery-fade--bottom"></div>
        <div class="gallery-columns">
          <div class="gallery-col">
            <div class="gallery-scroll gallery-scroll--up">
              <div class="gallery-item"><img src="/images/gallery-1.jpg" alt="Custom website design project" loading="eager" /></div>
              <div class="gallery-item"><img src="/images/gallery-2.jpg" alt="SEO results dashboard" loading="eager" /></div>
              <div class="gallery-item"><img src="/images/gallery-3.jpg" alt="Client business growth" loading="eager" /></div>
              <div class="gallery-item"><img src="/images/gallery-4.jpg" alt="Professional web design" loading="eager" /></div>
              <div class="gallery-item"><img src="/images/gallery-1.jpg" alt="Custom website design project" loading="eager" /></div>
              <div class="gallery-item"><img src="/images/gallery-2.jpg" alt="SEO results dashboard" loading="eager" /></div>
              <div class="gallery-item"><img src="/images/gallery-3.jpg" alt="Client business growth" loading="eager" /></div>
              <div class="gallery-item"><img src="/images/gallery-4.jpg" alt="Professional web design" loading="eager" /></div>
            </div>
          </div>
          <div class="gallery-col">
            <div class="gallery-scroll gallery-scroll--down">
              <div class="gallery-item"><img src="/images/gallery-5.jpg" alt="Service business website" loading="eager" /></div>
              <div class="gallery-item"><img src="/images/gallery-6.jpg" alt="Digital marketing strategy" loading="eager" /></div>
              <div class="gallery-item"><img src="/images/gallery-7.jpg" alt="Local business online presence" loading="eager" /></div>
              <div class="gallery-item"><img src="/images/gallery-8.jpg" alt="Website performance optimization" loading="eager" /></div>
              <div class="gallery-item"><img src="/images/gallery-5.jpg" alt="Service business website" loading="eager" /></div>
              <div class="gallery-item"><img src="/images/gallery-6.jpg" alt="Digital marketing strategy" loading="eager" /></div>
              <div class="gallery-item"><img src="/images/gallery-7.jpg" alt="Local business online presence" loading="eager" /></div>
              <div class="gallery-item"><img src="/images/gallery-8.jpg" alt="Website performance optimization" loading="eager" /></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ========== PROBLEM ========== -->
  <section class="problem section--soft" id="problem">
    <div class="container text-center">
      <h2>Does This Sound Familiar?</h2>
      <div class="problem__grid">
        <div class="problem__card card">
          <div class="problem__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="9" x2="15" y2="15"/><line x1="15" y1="9" x2="9" y2="15"/></svg>
          </div>
          <h3>Your Website is an Embarrassment.</h3>
          <p>
            You're a professional, but your website looks like it was built a decade ago. It doesn't reflect the quality of your work and you hesitate to even put it on your business card.
          </p>
        </div>
        <div class="problem__card card">
          <div class="problem__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </div>
          <h3>Your Marketing is a Black Box.</h3>
          <p>
            You're paying an agency (or you were), but you have no idea what they're actually doing. You get confusing reports, but the phone isn't ringing any more than it was before.
          </p>
        </div>
        <div class="problem__card card">
          <div class="problem__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3>Your Growth Has Plateaued.</h3>
          <p>
            You're stuck at the same revenue level, working harder than ever. You know you need to grow to the next level, but you don't have a predictable way to get there.
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ========== INDUSTRIES ========== -->
  <section class="industries" id="industries">
    <div class="container text-center">
      <h2>Proud partner to service businesses across <span class="text-blue">20+ industries.</span></h2>
      <div class="industries__grid">
        <a href="#" class="industries__card">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          <span>HVAC</span>
        </a>
        <a href="#" class="industries__card">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
          <span>Plumbing</span>
        </a>
        <a href="#" class="industries__card">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a4 4 0 00-8 0v2"/></svg>
          <span>Roofing</span>
        </a>
        <a href="#" class="industries__card">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <span>Electrical</span>
        </a>
        <a href="#" class="industries__card">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 22h20"/><path d="M6 22V4a2 2 0 012-2h8a2 2 0 012 2v18"/><path d="M10 6h4M10 10h4M10 14h4"/></svg>
          <span>Construction</span>
        </a>
        <a href="#" class="industries__card">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M8 12l2 2 4-4"/></svg>
          <span>Painting</span>
        </a>
        <a href="#" class="industries__card">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
          <span>Landscaping</span>
        </a>
        <a href="#" class="industries__card">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          <span>Transport</span>
        </a>
        <a href="#" class="industries__card">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          <span>Remodeling</span>
        </a>
        <a href="#" class="industries__card">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          <span>Lawn Care</span>
        </a>
        <a href="#" class="industries__card">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
          <span>Security</span>
        </a>
        <a href="#" class="industries__card">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
          <span>Cleaning</span>
        </a>
      </div>
      <a href="#" class="industries__link">See All Industries &rarr;</a>
    </div>
  </section>


  <!-- ========== SOLUTION ========== -->
  <section class="solution section--blue" id="solution">
    <div class="container text-center">
      <h2>It's Time to Own Your Lead Flow.</h2>
      <p class="mx-auto" style="text-align:center;">
        We don't just build websites; we build growth systems. We believe that a great service business deserves a predictable stream of high-quality leads that they own and control. No more renting attention from HomeAdvisor or wondering if your marketing is working. We build the asset, you own the results.
      </p>
      <a href="#contact" class="btn btn--white" style="margin-top: 40px;">Let's Talk About Your Growth</a>
    </div>
  </section>


  <!-- ========== GUIDE ========== -->
  <section class="guide" id="about">
    <div class="container guide__inner">
      <div class="guide__image">
        <img
          src="/images/hero-sunset.jpg"
          alt="Will Lockard — founder of Lockard Design Co."
          width="520"
          height="520"
          loading="lazy"
        />
      </div>
      <div class="guide__content">
        <div class="hero__badge">Meet the Founder</div>
        <h2>We Build Growth Systems for Service Businesses Like Yours.</h2>
        <p>
          Lockard Design Co. is a US-based digital agency that works exclusively with established B2B and home service companies. We're not a big, faceless firm. You'll work directly with our founder, Will, to build a system that delivers real, measurable results.
        </p>
        <p>
          We've helped companies double their revenue, expand their service area, and finally get the owner out of the day-to-day.
