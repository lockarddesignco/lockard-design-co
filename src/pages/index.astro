    padding-bottom: 40px;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: right center;
    opacity: 0.15;
    filter: saturate(0.3);
    transform: scaleX(-1);
  }


  .hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .hero__content {
    padding-bottom: 0;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-blue);
    background: var(--color-blue-faded);
    padding: 8px 18px;
    border-radius: var(--radius-full);
    margin-bottom: 16px;
    border: 1px solid rgba(24, 119, 242, 0.12);
  }

  .hero__badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-blue);
    animation: hero-pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes hero-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.8); }
  }

  .hero h1 {
    margin-bottom: clamp(12px, 1.5vw, 16px);
    font-size: clamp(2.75rem, 5vw, 4rem);
  }

  /* Hero typewriter */
  .hero-typewriter {
    border-right: 3px solid var(--color-blue);
    animation: hero-blink 0.7s step-end infinite;
  }

  .hero-typewriter--done {
    border-right-color: transparent;
    animation: none;
  }

  @keyframes hero-blink {
    50% { border-right-color: transparent; }
  }

  .hero__sub {
    margin-bottom: clamp(16px, 2vw, 24px);
  }

  .hero__actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn--lg {
    padding: 16px 36px;
    font-size: 1rem;
  }

  .hero__stats {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: clamp(20px, 2.5vw, 32px);
  }

  .hero__stat {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-full);
    text-decoration: none;
    color: inherit;
    line-height: 1.3;
    transition: all 0.25s ease;
    cursor: pointer;
  }

  .hero__stat:hover {
    background: rgba(255, 255, 255, 0.95);
    border-color: rgba(24, 119, 242, 0.2);
    box-shadow: 0 4px 16px rgba(24, 119, 242, 0.08);
    transform: translateY(-2px);
  }

  .hero__stat-stars {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .hero__stat strong {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  .hero__stat span {
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .hero__scroll-hint {
    position: absolute;
    bottom: clamp(24px, 3vw, 40px);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    z-index: 1;
    text-decoration: none;
    cursor: pointer;
  }

  .hero__scroll-hint span {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-secondary);
    transition: color 0.3s ease;
  }

  .hero__scroll-hint:hover span {
    color: var(--color-blue);
  }

  .hero__scroll-bolt {
    animation: hero-bolt-bounce 2s ease-in-out infinite;
    filter: drop-shadow(0 2px 8px rgba(56, 137, 255, 0.3));
    transition: filter 0.3s ease;
  }

  .hero__scroll-hint:hover .hero__scroll-bolt {
    filter: drop-shadow(0 4px 16px rgba(56, 137, 255, 0.5));
  }

  @keyframes hero-bolt-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  .hero__gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    align-items: start;
  }

  .gallery-col:first-child {
    height: 520px;
  }

  .gallery-col:last-child {
    height: 520px;
    margin-top: 80px;
  }

  @media (max-width: 768px) {
    .hero__bg img {
      opacity: 0.08;
