---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Lockard Design Co. — Websites & Growth Systems for Service Businesses">

  <!-- ========== TOP BAR ========== -->
  <div class="topbar">
    <div class="container-full topbar__inner">
      <div class="topbar__left">
        <a href="tel:+18567702456" class="topbar__item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          (856) 770-2456
        </a>
        <span class="topbar__divider"></span>
        <span class="topbar__item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Turnersville, NJ
        </span>
        <span class="topbar__divider"></span>
        <span class="topbar__item topbar__tagline">Growing local companies Coast to Coast</span>
      </div>
      <div class="topbar__right">
        <a href="mailto:will@lockarddesignco.com" class="topbar__item">will@lockarddesignco.com</a>
        <span class="topbar__divider"></span>
        <div class="topbar__socials">
          <a href="https://facebook.com/lockarddesignco" class="topbar__social" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
