  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Only animate a few key sections — keep it subtle

  // Problem cards — stagger in (use fromTo so initial state is explicit)
  gsap.fromTo('.problem__card',
    { y: 40, opacity: 0 },
