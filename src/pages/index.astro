<style>
  /* ========== FULL-WIDTH CONTAINER ========== */
  .container-full {
    width: 100%;
    max-width: 1400px;
    margin-inline: auto;
    padding-inline: clamp(20px, 4vw, 48px);
  }

  /* ========== TOP BAR ========== */
  .topbar {
    background-color: var(--color-bg-blue);
    color: var(--color-text-on-blue);
    font-size: 0.78rem;
    padding-block: 8px;
  }

  .topbar__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .topbar__left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .topbar__item {
    display: flex;
    align-items: center;
    gap: 6px;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    transition: color 0.2s;
  }

  a.topbar__item:hover {
    color: #FFFFFF;
  }

  .topbar__divider {
    width: 1px;
    height: 14px;
    background: rgba(255, 255, 255, 0.3);
  }

  .topbar__right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .topbar__socials {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .topbar__social {
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    transition: color 0.2s;
  }

  .topbar__social:hover {
    color: #FFFFFF;
  }

  .topbar__tagline {
    font-style: italic;
    color: rgba(255, 255, 255, 0.75);
  }

  @media (max-width: 640px) {
    .topbar__right { display: none; }
    .topbar__tagline { display: none; }
  }

  /* ========== MAIN HEADER ========== */
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: rgba(13, 13, 13, 0.97);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding-block: 0;
  }

  .header__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 64px;
    gap: 24px;
  }

  .header__logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: #FFFFFF;
    white-space: nowrap;
  }

  .header__logo-icon {
    width: 42px;
    height: 42px;
    flex-shrink: 0;
  }

  .header__logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .header__logo-name {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: #FFFFFF;
  }

  .header__logo-sub {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 1px;
  }

  /* ========== NAV MENU ========== */
  .header__menu {
    display: flex;
    list-style: none;
    gap: 0;
    height: 64px;
    align-items: stretch;
  }

  .header__menu-item {
    position: relative;
    display: flex;
    align-items: center;
  }

  .header__menu-link {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.7);
    padding: 0 20px;
    height: 100%;
    border: none;
    background: none;
    cursor: pointer;
    font-family: inherit;
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  .header__menu-link:hover {
    color: #FFFFFF;
    background-color: rgba(255, 255, 255, 0.06);
  }

  /* ========== MEGA MENU ========== */
  .mega {
    position: fixed;
    top: 64px;
    left: 0;
    right: 0;
    width: 100vw;
    background: #FFFFFF;
    border-top: 3px solid var(--color-blue);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.08);
    padding: 32px 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: opacity 0.25s ease, transform 0.25s ease, visibility 0.25s;
    z-index: 200;
  }

  .has-mega:hover .mega,
  .has-mega:focus-within .mega {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .mega__inner {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 32px;
  }

  .mega__heading {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text);
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--color-rule);
  }

  .mega__links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .mega__link {
    font-size: 0.88rem;
    font-weight: 400;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 4px 0;
    transition: color 0.2s ease;
  }

  .mega__link:hover {
    color: var(--color-blue);
  }

  .mega__cta-col {
    display: flex;
    align-items: stretch;
  }

  .mega__cta-card {
    background: var(--color-bg-soft);
    border-radius: var(--radius-md);
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: 100%;
  }

  .mega__cta-card p {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-top: 8px;
  }

  /* ========== HEADER ACTIONS ========== */
  .header__actions {
    display: flex;
    align-items: center;
    gap: 20px;
  }

