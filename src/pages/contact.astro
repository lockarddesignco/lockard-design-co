---
import BlogLayout from '../layouts/BlogLayout.astro';
---

<BlogLayout
  title="Contact — Lockard Design Co."
  description="Get in touch with Lockard Design Co. Schedule a free strategy session and get a custom growth plan for your service business."
>

  <!-- ========== HERO ========== -->
  <section class="contact-hero section--blue section--textured">
    <div class="container">
      <div class="contact-hero__inner">
        <div class="contact-hero__text">
          <h1>Let's Build<br/>Something Great.</h1>
          <p>Schedule a free strategy session and get a custom growth plan for your business. No obligation, no pitch — just clarity.</p>
        </div>
        <div class="contact-hero__quick">
          <a href="tel:+18567702456" class="contact-hero__action">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            <div>
              <strong>(856) 770-2456</strong>
              <span>Mon - Fri, 9am - 6pm</span>
            </div>
          </a>
          <a href="mailto:hello@lockarddesignco.com" class="contact-hero__action">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <div>
              <strong>hello@lockarddesignco.com</strong>
              <span>We reply within 24 hours</span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FORM SECTION ========== -->
  <section class="contact-form-section">
    <div class="container">
      <div class="contact-grid">

        <!-- FORM -->
        <div class="contact-form-card">
          <div class="contact-form-card__header">
            <img src="/images/logo.svg" alt="" width="36" height="36" />
            <div>
              <strong>Get Your Free Growth Plan</strong>
              <p>Tell us about your business and we'll build you a custom roadmap.</p>
            </div>
          </div>
          <form class="cf" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thank-you/contact/">
            <input type="hidden" name="form-name" value="contact" />
            <p class="sr-only"><label>Don't fill this out: <input name="bot-field" /></label></p>

            <div class="cf__field">
              <label for="c-name">Full Name</label>
              <input type="text" id="c-name" name="name" required placeholder="John Smith" />
            </div>
            <div class="cf__row">
              <div class="cf__field">
                <label for="c-email">Email</label>
                <input type="email" id="c-email" name="email" required placeholder="john@company.com" />
              </div>
              <div class="cf__field">
                <label for="c-phone">Phone</label>
                <input type="tel" id="c-phone" name="phone" placeholder="(555) 123-4567" />
              </div>
            </div>
            <div class="cf__row">
              <div class="cf__field">
                <label for="c-company">Company Name</label>
                <input type="text" id="c-company" name="company" placeholder="Your Business Name" />
              </div>
              <div class="cf__field">
                <label for="c-industry">Industry</label>
                <input type="text" id="c-industry" name="industry" placeholder="HVAC, Plumbing, etc." />
              </div>
            </div>
            <div class="cf__field">
              <label for="c-website">Current Website (if any)</label>
              <input type="text" id="c-website" name="website" placeholder="yoursite.com" pattern="[a-zA-Z0-9][-a-zA-Z0-9]*\.[a-zA-Z]{2,}.*" title="Enter a website like yoursite.com" />
            </div>

            <fieldset class="cf__checkboxes">
              <legend>What can we help with?</legend>
              <div class="cf__checks-grid">
                <label class="cf__check"><input type="checkbox" name="help" value="Generate Leads" /><span>Generate Leads</span></label>
                <label class="cf__check"><input type="checkbox" name="help" value="Increase Revenue" /><span>Increase Revenue</span></label>
                <label class="cf__check"><input type="checkbox" name="help" value="New Website" /><span>New Website</span></label>
                <label class="cf__check"><input type="checkbox" name="help" value="Rank In Google" /><span>Rank In Google</span></label>
                <label class="cf__check"><input type="checkbox" name="help" value="AI Visibility" /><span>AI Visibility</span></label>
                <label class="cf__check"><input type="checkbox" name="help" value="Social Media" /><span>Social Media</span></label>
              </div>
            </fieldset>

            <div class="cf__field">
              <label for="c-goals">Anything else we should know?</label>
              <textarea id="c-goals" name="goals" rows="4" placeholder="Tell us about your business and what you're looking to achieve..."></textarea>
            </div>

            <button type="submit" class="cf__submit">
              <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              Get My Free Growth Plan
            </button>
          </form>
        </div>

        <!-- SIDEBAR -->
        <div class="contact-side">
          <div class="contact-side__founder">
            <img src="/images/will-founder.jpg" alt="Will Lockard" class="contact-side__photo" loading="lazy" />
            <div class="contact-side__bio">
              <h3>Will Lockard</h3>
              <span>Founder, Lockard Design Co.</span>
              <p>"Every strategy session starts with understanding your business. I'll personally review your situation and give you a straight answer on what it'll take to grow."</p>
            </div>
          </div>

          <div class="contact-side__trust">
            <div class="contact-side__trust-item">
              <div class="contact-side__stars">
                <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              </div>
              <strong>5.0</strong>
              <span>on Google</span>
            </div>
            <div class="contact-side__trust-item">
              <strong>100's</strong>
              <span>businesses served</span>
            </div>
            <div class="contact-side__trust-item">
              <strong>25+</strong>
              <span>industries</span>
            </div>
          </div>

          <div class="contact-side__social">
            <a href="https://facebook.com/lockarddesignco" target="_blank" rel="noopener noreferrer" aria-label="Facebook"><svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg></a>
            <a href="https://linkedin.com/in/willlockard" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a>
            <a href="https://instagram.com/lockarddesignco" target="_blank" rel="noopener noreferrer" aria-label="Instagram"><svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg></a>
            <a href="https://wa.me/16098703758" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp"><svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg></a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ========== WHAT HAPPENS NEXT ========== -->
  <section class="contact-steps">
    <div class="container">
      <h2 class="contact-steps__heading">What Happens After You Reach Out</h2>
      <p class="contact-steps__sub">No surprises. Here's exactly what to expect.</p>
      <div class="contact-steps__grid">
        <div class="contact-steps__item">
          <div class="contact-steps__number">1</div>
          <h3>We Talk</h3>
          <p>A quick 15-minute call to understand your business, your goals, and what's standing in your way.</p>
        </div>
        <div class="contact-steps__connector">
          <svg width="40" height="12" viewBox="0 0 40 12" fill="none"><path d="M0 6h32m0 0l-6-5m6 5l-6 5" stroke="var(--color-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="contact-steps__item">
          <div class="contact-steps__number">2</div>
          <h3>We Build Your Plan</h3>
          <p>We audit your current presence and build a custom growth roadmap with clear next steps and expected outcomes.</p>
        </div>
        <div class="contact-steps__connector">
          <svg width="40" height="12" viewBox="0 0 40 12" fill="none"><path d="M0 6h32m0 0l-6-5m6 5l-6 5" stroke="var(--color-blue)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="contact-steps__item">
          <div class="contact-steps__number">3</div>
          <h3>You Decide</h3>
          <p>Review the plan on your own time. No pressure, no follow-up calls every 48 hours. The plan is yours to keep either way.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TESTIMONIALS ========== -->
  <section class="contact-reviews">
    <div class="container">
      <h2 class="contact-reviews__heading">What Our Clients Say</h2>
      <div class="contact-reviews__grid">
        <div class="contact-reviews__card">
          <div class="contact-reviews__stars">
            <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <p class="contact-reviews__quote">"Will took the time to actually understand our business before recommending anything. The website he built us pays for itself every month in new leads."</p>
          <div class="contact-reviews__author">
            <strong>Mike R.</strong>
            <span>Owner, Building & Air Mechanical</span>
          </div>
        </div>
        <div class="contact-reviews__card">
          <div class="contact-reviews__stars">
            <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <p class="contact-reviews__quote">"Fast, responsive, and always thinking about what's best for our bottom line. Lockard Design Co. is the real deal."</p>
          <div class="contact-reviews__author">
            <strong>Alvin P.</strong>
            <span>Owner, Cutting Edge Painting</span>
          </div>
        </div>
        <div class="contact-reviews__card">
          <div class="contact-reviews__stars">
            <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg viewBox="0 0 24 24" fill="#F5A623" width="16" height="16"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <p class="contact-reviews__quote">"We went from barely showing up on Google to ranking #1 for our top keywords. The ROI has been incredible."</p>
          <div class="contact-reviews__author">
            <strong>Danny E.</strong>
            <span>Owner, East Coast Transport</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="faq section--soft" id="faq">
    <div class="container">
      <div class="faq__layout">
        <div class="faq__left">
          <h2>Frequently Asked<br>Questions</h2>
          <p class="subheadline">Everything you need to know before we get started.</p>
          <a href="#" class="btn" onclick="document.querySelector('.contact-form-card').scrollIntoView({behavior:'smooth'});return false;">Still Have Questions? Let's Talk</a>

          <div class="faq__authority">
            <div class="faq__authority-item">
              <span class="faq__authority-num">100's</span>
              <span class="faq__authority-label">Websites Launched</span>
            </div>
            <div class="faq__authority-item">
              <span class="faq__authority-num">25+</span>
              <span class="faq__authority-label">Industries Served</span>
            </div>
            <div class="faq__authority-item">
              <span class="faq__authority-num">5.0</span>
              <span class="faq__authority-label">Google Rating</span>
            </div>
            <div class="faq__authority-item">
              <span class="faq__authority-num">100%</span>
              <span class="faq__authority-label">Satisfaction Guarantee</span>
            </div>
          </div>
        </div>
        <div class="faq__right">
          <div class="faq__group">
            <h3 class="faq__group-title">Investment & Value</h3>
            <details class="faq__item">
              <summary class="faq__question">What does the free growth plan include?</summary>
              <div class="faq__answer"><p>We review your current website, SEO presence, and competitive landscape. You get a custom report with specific, actionable recommendations — not a generic template. It's yours to keep whether you work with us or not.</p></div>
            </details>
            <details class="faq__item">
              <summary class="faq__question">How much does a website cost?</summary>
              <div class="faq__answer"><p>Our web design projects typically range from $2,500 to $18,000 depending on complexity, number of pages, and custom functionality. We'll give you a clear quote after understanding your needs — no surprises.</p></div>
            </details>
            <details class="faq__item">
              <summary class="faq__question">Do I own my website?</summary>
              <div class="faq__answer"><p>100%. You own everything — the design, the code, the content, the domain. If you ever decide to leave, you take it all with you. No hostage situations.</p></div>
            </details>
          </div>
          <div class="faq__group">
            <h3 class="faq__group-title">Process & Timelines</h3>
            <details class="faq__item">
              <summary class="faq__question">How long does a project take?</summary>
              <div class="faq__answer"><p>Most websites launch within 4-8 weeks. SEO campaigns typically start showing measurable results within 90 days. We'll give you a realistic timeline during our first conversation.</p></div>
            </details>
            <details class="faq__item">
              <summary class="faq__question">How much of my time is required?</summary>
              <div class="faq__answer"><p>About 2-3 hours for the initial strategy session, then 30-60 minutes per week for feedback. We've engineered the process to minimize your involvement while keeping you in the loop on every decision that matters.</p></div>
            </details>
          </div>
          <div class="faq__group">
            <h3 class="faq__group-title">Trust & Fit</h3>
            <details class="faq__item">
              <summary class="faq__question">Do you work with businesses outside New Jersey?</summary>
              <div class="faq__answer"><p>Yes. Approximately 70% of our clients are located outside our immediate area. We're a remote-first company with a refined process for collaborating with businesses across the United States.</p></div>
            </details>
            <details class="faq__item">
              <summary class="faq__question">What industries do you specialize in?</summary>
              <div class="faq__answer"><p>We work primarily with service businesses — HVAC, plumbing, electrical, roofing, construction, painting, landscaping, and other trades. We understand your customers because we've spent years studying what makes them pick up the phone.</p></div>
            </details>
            <details class="faq__item">
              <summary class="faq__question">What makes you different from other agencies?</summary>
              <div class="faq__answer"><p>You work directly with the founder, not a junior account manager. We measure success by your leads and revenue, not vanity metrics. And we offer a 100% Design Satisfaction Guarantee — unlimited revisions during the mockup phase until you're completely happy.</p></div>
            </details>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FINAL CTA ========== -->
  <section class="cta-final section--blue">
