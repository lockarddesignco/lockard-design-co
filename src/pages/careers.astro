---
import BlogLayout from '../layouts/BlogLayout.astro';
---

<BlogLayout
  title="Careers — Lockard Design Co."
  description="Join the Lockard Design Co. team. We're looking for talented, driven people who want to do work that actually matters. View open positions and apply today."
>

  <!-- ========== HERO ========== -->
  <section class="section--blue section--textured py-[clamp(100px,14vw,180px)_clamp(60px,8vw,100px)] text-center">
    <div class="container">
      <div class="max-w-[720px] mx-auto">
        <h1 class="font-[var(--font-display)] text-[clamp(2.4rem,5.5vw,4rem)] font-extrabold tracking-tight leading-[1.1] mb-5 text-white">Join the Team</h1>
        <p class="text-[clamp(1rem,1.8vw,1.2rem)] leading-[1.7] text-white/85 max-w-[600px] mx-auto">We're building something big. If you're talented, driven, and want to do work that actually matters — we want to hear from you.</p>
      </div>
    </div>
  </section>

  <!-- ========== WHY WORK HERE ========== -->
  <section class="section--soft section-padding">
    <div class="container">
      <div class="text-center max-w-[600px] mx-auto mb-[clamp(40px,5vw,64px)]">
        <h2 class="mb-3">Why Lockard Design Co.</h2>
        <p class="text-[1.05rem] leading-[1.7] text-[var(--color-text-secondary)]">We do meaningful work for real businesses — and we take care of the people who make it happen.</p>
      </div>
      <div class="grid grid-cols-4 gap-6 max-[900px]:grid-cols-2 max-[540px]:grid-cols-1">
        <div class="bg-white rounded-[var(--radius-lg)] p-[clamp(28px,3vw,40px)] border border-[var(--color-rule)] transition-all duration-200 hover:-translate-y-1 hover:shadow-[0_12px_32px_rgba(0,0,0,0.06)]">
          <div class="w-14 h-14 rounded-[var(--radius-md)] bg-[var(--color-bg-soft)] grid place-items-center mb-5 text-[var(--color-bg-blue)]">
            <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3 class="text-[1.15rem] font-bold text-[var(--color-text)] mb-2.5">Remote-First</h3>
          <p class="text-[0.92rem] leading-[1.7] text-[var(--color-text-secondary)]">Work from anywhere. We care about what you deliver, not where you sit. Our team is distributed and asynchronous by default.</p>
        </div>
        <div class="bg-white rounded-[var(--radius-lg)] p-[clamp(28px,3vw,40px)] border border-[var(--color-rule)] transition-all duration-200 hover:-translate-y-1 hover:shadow-[0_12px_32px_rgba(0,0,0,0.06)]">
          <div class="w-14 h-14 rounded-[var(--radius-md)] bg-[var(--color-bg-soft)] grid place-items-center mb-5 text-[var(--color-bg-blue)]">
            <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h3 class="text-[1.15rem] font-bold text-[var(--color-text)] mb-2.5">Real Impact</h3>
          <p class="text-[0.92rem] leading-[1.7] text-[var(--color-text-secondary)]">Your work directly grows businesses. No vanity metrics, no busywork. Every project you touch drives real revenue for real companies.</p>
        </div>
        <div class="bg-white rounded-[var(--radius-lg)] p-[clamp(28px,3vw,40px)] border border-[var(--color-rule)] transition-all duration-200 hover:-translate-y-1 hover:shadow-[0_12px_32px_rgba(0,0,0,0.06)]">
          <div class="w-14 h-14 rounded-[var(--radius-md)] bg-[var(--color-bg-soft)] grid place-items-center mb-5 text-[var(--color-bg-blue)]">
            <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="text-[1.15rem] font-bold text-[var(--color-text)] mb-2.5">No Corporate BS</h3>
          <p class="text-[0.92rem] leading-[1.7] text-[var(--color-text-secondary)]">Small team, big autonomy. No layers of management, no pointless meetings. You own your work and have a direct line to leadership.</p>
        </div>
        <div class="bg-white rounded-[var(--radius-lg)] p-[clamp(28px,3vw,40px)] border border-[var(--color-rule)] transition-all duration-200 hover:-translate-y-1 hover:shadow-[0_12px_32px_rgba(0,0,0,0.06)]">
          <div class="w-14 h-14 rounded-[var(--radius-md)] bg-[var(--color-bg-soft)] grid place-items-center mb-5 text-[var(--color-bg-blue)]">
            <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <h3 class="text-[1.15rem] font-bold text-[var(--color-text)] mb-2.5">Always Learning</h3>
          <p class="text-[0.92rem] leading-[1.7] text-[var(--color-text-secondary)]">We work with cutting-edge tools and technology. You'll stay sharp, grow your skill set, and never feel like you're falling behind.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== OPEN POSITIONS ========== -->
  <section class="section-padding">
    <div class="container">
      <div class="text-center max-w-[600px] mx-auto mb-[clamp(40px,5vw,64px)]">
        <h2 class="mb-3">Open Positions</h2>
        <p class="text-[1.05rem] leading-[1.7] text-[var(--color-text-secondary)]">We're growing and looking for people who want to do their best work.</p>
      </div>
      <div class="flex flex-col gap-4 max-w-[820px] mx-auto">
        <div class="flex items-center justify-between gap-8 bg-white border border-[var(--color-rule)] rounded-[var(--radius-lg)] p-[clamp(24px,3vw,36px)] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(0,0,0,0.06)] max-[640px]:flex-col max-[640px]:items-start max-[640px]:gap-5">
          <div class="flex-1">
            <h3 class="text-[1.2rem] font-bold text-[var(--color-text)] mb-2.5">SEO Specialist</h3>
            <div class="flex gap-2 mb-3">
              <span class="inline-block text-[0.75rem] font-semibold uppercase tracking-[0.05em] text-[var(--color-bg-blue)] bg-[rgba(24,119,242,0.08)] px-3 py-1 rounded-md">Full-time</span>
              <span class="inline-block text-[0.75rem] font-semibold uppercase tracking-[0.05em] text-[var(--color-bg-blue)] bg-[rgba(24,119,242,0.08)] px-3 py-1 rounded-md">Remote</span>
            </div>
            <p class="text-[0.95rem] leading-[1.6] text-[var(--color-text-secondary)]">Manage and grow organic search campaigns for our portfolio of service business clients.</p>
          </div>
          <a href="mailto:hello@lockarddesignco.com?subject=Application%3A%20SEO%20Specialist" class="btn shrink-0 whitespace-nowrap max-[640px]:w-full max-[640px]:text-center">Apply Now</a>
        </div>
        <div class="flex items-center justify-between gap-8 bg-white border border-[var(--color-rule)] rounded-[var(--radius-lg)] p-[clamp(24px,3vw,36px)] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(0,0,0,0.06)] max-[640px]:flex-col max-[640px]:items-start max-[640px]:gap-5">
          <div class="flex-1">
            <h3 class="text-[1.2rem] font-bold text-[var(--color-text)] mb-2.5">Web Designer / Developer</h3>
            <div class="flex gap-2 mb-3">
              <span class="inline-block text-[0.75rem] font-semibold uppercase tracking-[0.05em] text-[var(--color-bg-blue)] bg-[rgba(24,119,242,0.08)] px-3 py-1 rounded-md">Contract</span>
              <span class="inline-block text-[0.75rem] font-semibold uppercase tracking-[0.05em] text-[var(--color-bg-blue)] bg-[rgba(24,119,242,0.08)] px-3 py-1 rounded-md">Remote</span>
            </div>
            <p class="text-[0.95rem] leading-[1.6] text-[var(--color-text-secondary)]">Design and build high-converting websites on our Astro + Netlify stack.</p>
          </div>
          <a href="mailto:hello@lockarddesignco.com?subject=Application%3A%20Web%20Designer%20%2F%20Developer" class="btn shrink-0 whitespace-nowrap max-[640px]:w-full max-[640px]:text-center">Apply Now</a>
        </div>
        <div class="flex items-center justify-between gap-8 bg-white border border-[var(--color-rule)] rounded-[var(--radius-lg)] p-[clamp(24px,3vw,36px)] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(0,0,0,0.06)] max-[640px]:flex-col max-[640px]:items-start max-[640px]:gap-5">
          <div class="flex-1">
            <h3 class="text-[1.2rem] font-bold text-[var(--color-text)] mb-2.5">Content Writer</h3>
            <div class="flex gap-2 mb-3">
              <span class="inline-block text-[0.75rem] font-semibold uppercase tracking-[0.05em] text-[var(--color-bg-blue)] bg-[rgba(24,119,242,0.08)] px-3 py-1 rounded-md">Part-time</span>
              <span class="inline-block text-[0.75rem] font-semibold uppercase tracking-[0.05em] text-[var(--color-bg-blue)] bg-[rgba(24,119,242,0.08)] px-3 py-1 rounded-md">Remote</span>
            </div>
            <p class="text-[0.95rem] leading-[1.6] text-[var(--color-text-secondary)]">Create strategic blog content and landing page copy that ranks and converts.</p>
          </div>
          <a href="mailto:hello@lockarddesignco.com?subject=Application%3A%20Content%20Writer" class="btn shrink-0 whitespace-nowrap max-[640px]:w-full max-[640px]:text-center">Apply Now</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== GENERAL APPLICATION CTA ========== -->
  <section class="section--blue section--textured py-[clamp(60px,8vw,100px)] text-center">
    <div class="container">
      <div class="max-w-[600px] mx-auto">
        <h2 class="text-white mb-4">Don't See a Role That Fits?</h2>
        <p class="text-[clamp(1rem,1.8vw,1.15rem)] leading-[1.7] text-white/85 mb-8">We're always looking for talented people. Send us your info and tell us what you're great at.</p>
        <a href="mailto:hello@lockarddesignco.com?subject=General%20Application%20%E2%80%94%20Lockard%20Design%20Co." class="btn bg-white text-[var(--color-bg-blue)] border-white text-[0.95rem] py-4 px-9 hover:bg-transparent hover:text-white hover:border-white">Get in Touch</a>
      </div>
    </div>
  </section>

</BlogLayout>
