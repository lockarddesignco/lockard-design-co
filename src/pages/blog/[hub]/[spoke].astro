---
import BlogLayout from '../../../layouts/BlogLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const spokes = await getCollection('blog-spokes', ({ data }) => !data.draft);
  const hubs = await getCollection('blog-hubs', ({ data }) => !data.draft);

  return spokes.map(spoke => {
    // Extract spoke slug from id (e.g., "local-seo/local-seo-checklist" -> "local-seo-checklist")
    const spokeSlug = spoke.id.split('/').pop() || spoke.id;
    const parentHub = hubs.find(h => h.data.silo === spoke.data.silo);

    return {
      params: {
        hub: spoke.data.hubSlug,
        spoke: spokeSlug,
      },
      props: { spoke, parentHub },
    };
  });
}

const { spoke, parentHub } = Astro.props;
const { Content, headings } = await render(spoke);

// Get next spoke data if specified
let nextSpokeData = null;
if (spoke.data.nextSpoke) {
  const allSpokes = await getCollection('blog-spokes', ({ data }) => !data.draft);
  const next = allSpokes.find(s =>
    s.data.silo === spoke.data.silo &&
    (s.id.split('/').pop() === spoke.data.nextSpoke || s.id === spoke.data.nextSpoke)
  );
  if (next) {
    nextSpokeData = {
      title: next.data.title,
      href: `/blog/${spoke.data.hubSlug}/${next.id.split('/').pop()}/`,
      description: next.data.description.slice(0, 120),
    };
  }
}

const hubTitle = parentHub?.data.title || spoke.data.hubSlug;
const hubHref = `/blog/${spoke.data.hubSlug}/`;

const formattedDate = spoke.data.publishDate.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<BlogLayout
  title={spoke.data.titleTag}
  description={spoke.data.description}
>

  <!-- Breadcrumbs (placeholder — component coming in Phase 2) -->
  <nav class="text-[0.82rem] text-[var(--color-text-secondary)] pt-[clamp(140px,18vw,200px)] pb-4">
    <div class="container">
      <a href="/" class="text-[var(--color-blue)] no-underline hover:underline">Home</a>
      <span class="mx-2">&gt;</span>
      <a href="/blog/" class="text-[var(--color-blue)] no-underline hover:underline">Blog</a>
      <span class="mx-2">&gt;</span>
      <a href={hubHref} class="text-[var(--color-blue)] no-underline hover:underline">{hubTitle}</a>
      <span class="mx-2">&gt;</span>
      <span>{spoke.data.title}</span>
    </div>
  </nav>

  <article class="pb-[var(--spacing-section)]">
    <div class="container max-w-[780px] mx-auto">

      <h1 class="mb-4">{spoke.data.title}</h1>
      <p class="text-[var(--color-text-secondary)] text-[0.9rem] mb-4">
        By {spoke.data.author} · {formattedDate}
      </p>

      <!-- Guide badge -->
      <div class="inline-block text-[0.82rem] font-medium text-[var(--color-text-secondary)] bg-[var(--color-bg-soft)] border border-[var(--color-rule)] rounded-full px-4 py-1.5 mb-8">
        Part of the <a href={hubHref} class="text-[var(--color-blue)] no-underline font-semibold hover:underline">{hubTitle}</a> guide
      </div>

      <!-- Inline TOC -->
      {headings.filter(h => h.depth === 2).length > 0 && (
        <nav class="bg-[var(--color-bg-soft)] border border-[var(--color-rule)] rounded-[var(--radius-md)] p-6 mb-10">
          <h4 class="text-[0.85rem] font-bold uppercase tracking-[0.06em] text-[var(--color-text)] mb-3">In This Article</h4>
          <ol class="list-decimal list-inside flex flex-col gap-1.5">
            {headings.filter(h => h.depth === 2).map(h => (
              <li><a href={`#${h.slug}`} class="text-[0.88rem] text-[var(--color-text-secondary)] no-underline hover:text-[var(--color-blue)] transition-colors duration-200">{h.text}</a></li>
            ))}
          </ol>
        </nav>
      )}

      <!-- Content -->
      <div class="prose max-w-none">
        <Content />
      </div>

      <!-- Next Article / Back to Guide -->
      <div class="mt-16 pt-12 border-t border-[var(--color-rule)]">
        {nextSpokeData && (
          <a href={nextSpokeData.href} class="block p-6 border border-[var(--color-rule)] rounded-[var(--radius-md)] no-underline text-inherit transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(0,0,0,0.06)] hover:border-[var(--color-blue)] mb-4">
            <span class="text-[0.75rem] font-bold uppercase tracking-[0.08em] text-[var(--color-blue)] mb-2 block">Next in This Guide &rarr;</span>
            <h3 class="text-[1.1rem] font-bold text-[var(--color-text)] mb-1">{nextSpokeData.title}</h3>
            <p class="text-[0.85rem] text-[var(--color-text-secondary)] leading-[1.6]">{nextSpokeData.description}</p>
          </a>
        )}
        <a href={hubHref} class="inline-flex items-center gap-2 text-[0.88rem] font-semibold text-[var(--color-blue)] no-underline hover:underline">
          &larr; Back to {hubTitle}
        </a>
      </div>

    </div>
  </article>

</BlogLayout>

<style>
  .prose :global(h2) { font-size: clamp(1.4rem, 2.2vw, 1.75rem); font-weight: 700; line-height: 1.2; letter-spacing: -0.02em; margin-top: 2.5em; margin-bottom: 0.6em; color: var(--color-text); scroll-margin-top: 80px; }
  .prose :global(h3) { font-size: clamp(1.1rem, 1.5vw, 1.3rem); font-weight: 600; line-height: 1.3; margin-top: 2em; margin-bottom: 0.5em; color: var(--color-text); }
  .prose :global(p) { margin-bottom: 1.5em; color: var(--color-text-secondary); line-height: 1.8; font-size: clamp(0.95rem, 1.1vw, 1.05rem); }
  .prose :global(strong) { color: var(--color-text); font-weight: 600; }
  .prose :global(a) { color: var(--color-blue); text-decoration: underline; text-underline-offset: 3px; text-decoration-color: rgba(24, 119, 242, 0.3); transition: text-decoration-color 0.2s; }
  .prose :global(a:hover) { text-decoration-color: var(--color-blue); }
  .prose :global(ul), .prose :global(ol) { margin-bottom: 1.5em; padding-left: 1.5em; color: var(--color-text-secondary); line-height: 1.8; font-size: clamp(0.95rem, 1.1vw, 1.05rem); }
  .prose :global(li) { margin-bottom: 0.5em; }
  .prose :global(blockquote) { border-left: 3px solid var(--color-blue); padding-left: 24px; margin-block: 2em; font-style: italic; color: var(--color-text-secondary); }
  .prose :global(table) { width: 100%; border-collapse: collapse; margin-block: 2em; font-size: 0.9rem; }
  .prose :global(th) { text-align: left; padding: 12px 16px; background: var(--color-bg-soft); border: 1px solid var(--color-rule); font-weight: 600; color: var(--color-text); }
  .prose :global(td) { padding: 12px 16px; border: 1px solid var(--color-rule); color: var(--color-text-secondary); }
  .prose :global(hr) { border: none; border-top: 1px solid var(--color-rule); margin-block: 2.5em; }
  .prose :global(code) { background: var(--color-bg-soft); padding: 2px 6px; border-radius: 4px; font-size: 0.88em; }
</style>
