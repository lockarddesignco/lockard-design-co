---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Get related posts (same category, excluding current)
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.data.category === post.data.category && p.id !== post.id)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<BlogLayout
  title={`${post.data.title} — Lockard Design Co.`}
  description={post.data.description}
>

  <!-- ========== ARTICLE HEADER ========== -->
  <section class="article-header">
    <div class="container">
      <div class="article-header__breadcrumb">
        <a href="/blog">Blog</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
        <span>{post.data.category}</span>
      </div>
      <div class="article-header__meta">
        <span class="article-header__category">{post.data.category}</span>
        <span class="article-header__dot"></span>
        <span class="article-header__read">{post.data.readTime}</span>
      </div>
      <h1 class="article-header__title">{post.data.title}</h1>
      <p class="article-header__desc subheadline">{post.data.description}</p>
      <div class="article-header__author">
        <div class="article-header__avatar">WL</div>
        <div>
          <span class="article-header__author-name">{post.data.author}</span>
          <span class="article-header__date">{formattedDate}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== ARTICLE BODY ========== -->
  <article class="article-body">
    <div class="container">
      <div class="article-body__grid">
        <div class="article-body__content prose">
          <Content />
        </div>
        <aside class="article-body__sidebar">
          <div class="sidebar-card sidebar-card--sticky">
            <div class="sidebar-card__inner">
              <h4 class="sidebar-card__title">Get Your Free Growth Plan</h4>
              <p class="sidebar-card__text">See how we can help your service business grow with a custom strategy session.</p>
              <a href="/contact" class="btn" style="width:100%; text-align:center;">Let's Talk</a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </article>

  <!-- ========== ARTICLE FOOTER / SHARE ========== -->
  <section class="article-footer-bar">
    <div class="container">
      <div class="article-footer-bar__inner">
        <a href="/blog" class="article-footer-bar__back">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          All Articles
        </a>
      </div>
    </div>
  </section>

  <!-- ========== RELATED POSTS ========== -->
  {relatedPosts.length > 0 && (
    <section class="related-posts">
      <div class="container">
        <h2 class="related-posts__heading">Keep Reading</h2>
        <div class="related-posts__grid">
          {relatedPosts.map(rp => (
            <a href={`/blog/${rp.id}`} class="post-card">
              <div class="post-card__top">
                <span class="post-card__category">{rp.data.category}</span>
                <span class="post-card__read">{rp.data.readTime}</span>
              </div>
              <h3 class="post-card__title">{rp.data.title}</h3>
              <p class="post-card__desc">{rp.data.description}</p>
              <div class="post-card__bottom">
                <div class="post-card__author">
                  <div class="post-card__avatar">WL</div>
                  <span class="post-card__author-name">{rp.data.author}</span>
                </div>
                <span class="post-card__date">
                  {rp.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </span>
              </div>
              <div class="post-card__glow"></div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ========== BOTTOM CTA ========== -->
  <section class="article-cta section--blue">
    <div class="container text-center">
      <h2>Ready to grow your business?</h2>
      <p class="subheadline mx-auto" style="color:rgba(255,255,255,0.85); margin-bottom: 28px;">
        Get a free strategy session and custom growth plan for your service business.
      </p>
      <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap;">
        <a href="tel:+18567702456" class="btn btn--white">Call (856) 770-2456</a>
        <a href="/contact" class="btn btn--outline" style="color:#fff; border-color:rgba(255,255,255,0.4);">Get Your Free Plan</a>
      </div>
    </div>
  </section>

</BlogLayout>


<style>
  /* ========== ARTICLE HEADER ========== */
  .article-header {
    padding-top: clamp(180px, 22vw, 240px);
    padding-bottom: clamp(40px, 5vw, 64px);
    background: linear-gradient(180deg, var(--color-bg-soft) 0%, var(--color-bg) 100%);
  }

  .article-header__breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    margin-bottom: 24px;
  }

  .article-header__breadcrumb a {
    color: var(--color-blue);
    text-decoration: none;
    font-weight: 500;
    transition: opacity 0.2s;
  }

  .article-header__breadcrumb a:hover {
    opacity: 0.8;
  }

  .article-header__meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
    font-size: 0.82rem;
  }

  .article-header__category {
    color: var(--color-blue);
    font-weight: 600;
  }

  .article-header__dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-rule);
  }

  .article-header__read {
    color: var(--color-text-secondary);
  }

  .article-header__title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
    max-width: 22ch;
  }

  .article-header__desc {
    margin-bottom: 32px;
    max-width: 60ch;
  }

  .article-header__author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .article-header__avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--color-blue);
    color: #FFFFFF;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .article-header__author-name {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .article-header__date {
    display: block;
    font-size: 0.82rem;
    color: var(--color-text-secondary);
  }

  /* ========== ARTICLE BODY ========== */
  .article-body {
    padding-bottom: clamp(40px, 5vw, 64px);
  }

  .article-body__grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: clamp(40px, 5vw, 80px);
    align-items: start;
  }

  @media (max-width: 1024px) {
    .article-body__grid {
      grid-template-columns: 1fr;
    }
    .article-body__sidebar {
      display: none;
    }
  }

  /* ========== PROSE (ARTICLE CONTENT) ========== */
  .prose {
    max-width: 72ch;
  }

  .prose :global(h2) {
    font-size: clamp(1.4rem, 2.2vw, 1.75rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-top: 2.5em;
    margin-bottom: 0.6em;
    color: var(--color-text);
  }

  .prose :global(h3) {
    font-size: clamp(1.1rem, 1.5vw, 1.3rem);
    font-weight: 600;
    line-height: 1.3;
    margin-top: 2em;
    margin-bottom: 0.5em;
    color: var(--color-text);
  }

  .prose :global(p) {
    margin-bottom: 1.5em;
    color: var(--color-text-secondary);
    line-height: 1.8;
    font-size: clamp(0.95rem, 1.1vw, 1.05rem);
  }

  .prose :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .prose :global(a) {
    color: var(--color-blue);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(24, 119, 242, 0.3);
    transition: text-decoration-color 0.2s;
  }

  .prose :global(a:hover) {
    text-decoration-color: var(--color-blue);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1.5em;
    padding-left: 1.5em;
    color: var(--color-text-secondary);
    line-height: 1.8;
    font-size: clamp(0.95rem, 1.1vw, 1.05rem);
  }

  .prose :global(li) {
    margin-bottom: 0.5em;
  }

  .prose :global(li strong) {
    color: var(--color-text);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-blue);
    padding-left: 24px;
    margin-block: 2em;
    font-style: italic;
    color: var(--color-text-secondary);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-rule);
    margin-block: 2.5em;
  }

  .prose :global(code) {
    background: var(--color-bg-soft);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.88em;
  }

  /* ========== SIDEBAR ========== */
  .sidebar-card--sticky {
    position: sticky;
    top: 160px;
  }

  .sidebar-card__inner {
    background: var(--color-bg-soft);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-md);
    padding: 32px;
  }

  .sidebar-card__title {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--color-text);
  }

  .sidebar-card__text {
    font-size: 0.88rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 20px;
  }

  /* ========== ARTICLE FOOTER BAR ========== */
  .article-footer-bar {
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    padding-block: 20px;
  }

  .article-footer-bar__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .article-footer-bar__back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-blue);
    text-decoration: none;
    transition: gap 0.2s;
  }

  .article-footer-bar__back:hover {
    gap: 12px;
  }

  /* ========== RELATED POSTS ========== */
  .related-posts {
    padding-block: var(--section-gap);
    background: var(--color-bg-soft);
  }

  .related-posts__heading {
    margin-bottom: clamp(24px, 3vw, 40px);
  }

  .related-posts__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--grid-gap);
  }

  @media (max-width: 640px) {
    .related-posts__grid {
      grid-template-columns: 1fr;
    }
  }

  /* Reuse post-card styles from blog index */
  .post-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-md);
    padding: clamp(24px, 3vw, 36px);
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.35s ease, transform 0.35s ease, border-color 0.35s ease;
    overflow: hidden;
  }

  .post-card:hover {
    box-shadow: 0 12px 40px rgba(24, 119, 242, 0.08);
    transform: translateY(-4px);
    border-color: rgba(24, 119, 242, 0.2);
  }

  .post-card__glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-blue), #3B5FE6);
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .post-card:hover .post-card__glow {
    opacity: 1;
  }

  .post-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .post-card__category {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-blue);
    background: var(--color-blue-faded);
    padding: 4px 12px;
    border-radius: var(--radius-full);
  }

  .post-card__read {
    font-size: 0.78rem;
    color: var(--color-text-secondary);
  }

  .post-card__title {
    font-size: clamp(1.05rem, 1.5vw, 1.25rem);
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 10px;
    color: var(--color-text);
    transition: color 0.2s;
  }

  .post-card:hover .post-card__title {
    color: var(--color-blue);
  }

  .post-card__desc {
    font-size: 0.88rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin-bottom: 24px;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 16px;
    border-top: 1px solid var(--color-rule-light);
  }

  .post-card__author {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .post-card__avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-blue);
    color: #FFFFFF;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 700;
  }

  .post-card__author-name {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .post-card__date {
    font-size: 0.78rem;
    color: var(--color-text-secondary);
  }

  /* ========== BOTTOM CTA ========== */
  .article-cta {
    padding-block: var(--section-gap);
  }

  .article-cta h2 {
    color: #FFFFFF;
    margin-bottom: 12px;
  }

</style>
