---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featuredPost = posts.find(p => p.data.featured) || posts[0];
const categories = ['All', 'Web Design', 'SEO', 'Business Growth', 'Industry Insights', 'Case Studies'];
---

<BlogLayout
  title="Blog — Lockard Design Co."
  description="Insights, strategies, and guides for service businesses looking to grow online. Expert advice on web design, SEO, and business growth."
>

  <!-- ========== BLOG HERO ========== -->
  <section class="blog-hero section--blue section--textured" id="blogHero">
    <div class="container blog-hero__content">
      <div class="blog-hero__badge">
        <span class="blog-hero__badge-dot"></span>
        Insights & Strategies
      </div>
      <h1 class="blog-hero__title">
        The Growth<br/>Playbook
      </h1>
      <p class="blog-hero__subtitle">
        Real strategies for real businesses. No fluff, no theory — just proven
        tactics that help service companies grow their revenue.
      </p>
    </div>
  </section>

  <!-- ========== FEATURED POST ========== -->
  <section class="blog-featured">
    <div class="container">
      <a href={`/blog/${featuredPost.id}`} class="featured-card">
        <div class="featured-card__content">
          <div class="featured-card__meta">
            <span class="featured-card__badge">Featured</span>
            <span class="featured-card__category">{featuredPost.data.category}</span>
            <span class="featured-card__dot"></span>
            <span class="featured-card__read">{featuredPost.data.readTime}</span>
          </div>
          <h2 class="featured-card__title">{featuredPost.data.title}</h2>
          <p class="featured-card__desc">{featuredPost.data.description}</p>
          <div class="featured-card__bottom">
            <div class="featured-card__author">
              <div class="featured-card__avatar">WL</div>
              <div>
                <span class="featured-card__author-name">{featuredPost.data.author}</span>
                <span class="featured-card__date">
                  {featuredPost.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                </span>
              </div>
            </div>
            <span class="featured-card__cta">
              Read Article
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </div>
        </div>
        <div class="featured-card__visual">
          <div class="featured-card__graphic">
            <div class="featured-card__icon-wrap">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                <path d="M2 17l10 5 10-5"/>
                <path d="M2 12l10 5 10-5"/>
              </svg>
            </div>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- ========== LATEST ARTICLES — horizontal scroll ========== -->
  <section class="blog-carousel-section">
    <div class="container">
      <div class="blog-carousel__header">
        <h2 class="blog-carousel__heading">Latest Articles</h2>
        <div class="blog-carousel__arrows">
          <button class="blog-carousel__arrow blog-carousel__arrow--prev" id="carouselPrev" aria-label="Previous">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          </button>
          <button class="blog-carousel__arrow blog-carousel__arrow--next" id="carouselNext" aria-label="Next">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </div>
      </div>
    </div>
    <div class="blog-carousel__track-wrap">
      <div class="blog-carousel__track" id="carouselTrack">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="post-card" data-category={post.data.category}>
            <div class="post-card__top">
              <span class="post-card__category">{post.data.category}</span>
              <span class="post-card__read">{post.data.readTime}</span>
            </div>
            <h3 class="post-card__title">{post.data.title}</h3>
            <p class="post-card__desc">{post.data.description}</p>
            <div class="post-card__bottom">
              <div class="post-card__author">
                <div class="post-card__avatar">WL</div>
                <span class="post-card__author-name">{post.data.author}</span>
              </div>
              <span class="post-card__date">
                {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </span>
            </div>
            <div class="post-card__glow"></div>
          </a>
        ))}
      </div>
    </div>
    <div class="container">
      <div class="blog-carousel__view-all-wrap">
        <button class="blog-carousel__view-all" id="viewAllBtn">
          View All Articles
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- ========== EXPANDED ALL ARTICLES (hidden by default) ========== -->
  <section class="blog-all" id="blogAll" aria-hidden="true">
    <div class="container">
      <div class="blog-filter__bar" id="filterBar">
        {categories.map((cat, i) => (
          <button class={`blog-filter__btn ${i === 0 ? 'is-active' : ''}`} data-category={cat}>{cat}</button>
        ))}
      </div>
      <div class="blog-grid" id="blogGrid">
        {posts.map((post, index) => (
          <a href={`/blog/${post.id}`} class="post-card post-card--grid" data-category={post.data.category} style={`--delay: ${index * 0.08}s`}>
            <div class="post-card__top">
              <span class="post-card__category">{post.data.category}</span>
              <span class="post-card__read">{post.data.readTime}</span>
            </div>
            <h3 class="post-card__title">{post.data.title}</h3>
            <p class="post-card__desc">{post.data.description}</p>
            <div class="post-card__bottom">
              <div class="post-card__author">
                <div class="post-card__avatar">WL</div>
                <span class="post-card__author-name">{post.data.author}</span>
              </div>
              <span class="post-card__date">
                {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </span>
            </div>
            <div class="post-card__glow"></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== NEWSLETTER CTA (textured blue section) ========== -->
  <section class="blog-cta section--blue">
    <div class="container text-center">
      <h2 class="blog-cta__heading">Get growth strategies delivered to your inbox</h2>
      <p class="blog-cta__text subheadline mx-auto" style="color: rgba(255,255,255,0.85);">
        Join 500+ service business owners who get our best insights every week. No spam. Unsubscribe anytime.
      </p>
      <form class="blog-cta__form" name="newsletter" method="POST" data-netlify="true" netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="newsletter" />
        <p class="sr-only"><label>Don't fill this out: <input name="bot-field" /></label></p>
        <div class="blog-cta__input-group">
          <input type="email" name="email" required placeholder="Enter your email" class="blog-cta__input" />
          <button type="submit" class="btn btn--white">Subscribe</button>
        </div>
      </form>
    </div>
  </section>

</BlogLayout>


<style>
  /* ========== TEXTURED BLUE SECTION ========== */
  .section--blue {
    background: var(--color-blue);
    color: #fff;
  }

  .section--textured {
    position: relative;
    overflow: hidden;
  }

  .section--textured::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("/images/noise.png");
    background-repeat: repeat;
    background-size: 200px 200px;
    pointer-events: none;
    z-index: 0;
    opacity: 0.35;
    mix-blend-mode: overlay;
  }

  .section--textured > * {
    position: relative;
    z-index: 1;
  }

  /* ========== BLOG HERO ========== */
  .blog-hero {
    position: relative;
    padding-top: clamp(160px, 20vw, 220px);
    padding-bottom: clamp(48px, 6vw, 72px);
    overflow: hidden;
  }

  .blog-hero__content {
    position: relative;
    z-index: 1;
  }

  .blog-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #FFFFFF;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 8px 16px;
    border-radius: var(--radius-full);
    margin-bottom: 24px;
  }

  .blog-hero__badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #FFFFFF;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }

  .blog-hero__title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
    color: #FFFFFF;
  }

  .blog-hero__subtitle {
    max-width: 50ch;
    color: rgba(255, 255, 255, 0.85);
    font-size: clamp(1.05rem, 1.4vw, 1.25rem);
    line-height: 1.7;
  }

  /* ========== FEATURED CARD ========== */
  .blog-featured { padding-bottom: clamp(40px, 5vw, 60px); }

  .featured-card {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 0;
    background: var(--color-bg);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.4s ease, transform 0.4s ease;
  }

  .featured-card:hover {
    box-shadow: 0 16px 48px rgba(24, 119, 242, 0.1);
    transform: translateY(-4px);
  }

  .featured-card__content {
    padding: clamp(32px, 4vw, 56px);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .featured-card__meta { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; font-size: 0.8rem; }
  .featured-card__badge { background: var(--color-blue); color: #FFFFFF; padding: 4px 12px; border-radius: var(--radius-full); font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.04em; }
  .featured-card__category { color: var(--color-blue); font-weight: 600; }
  .featured-card__dot { width: 4px; height: 4px; border-radius: 50%; background: var(--color-rule); }
  .featured-card__read { color: var(--color-text-secondary); }
  .featured-card__title { font-size: clamp(1.4rem, 2.5vw, 2rem); font-weight: 700; line-height: 1.2; letter-spacing: -0.02em; margin-bottom: 12px; color: var(--color-text); }
  .featured-card__desc { font-size: 0.95rem; color: var(--color-text-secondary); line-height: 1.7; margin-bottom: 28px; }
  .featured-card__bottom { display: flex; align-items: center; justify-content: space-between; gap: 16px; }
  .featured-card__author { display: flex; align-items: center; gap: 12px; }
  .featured-card__avatar { width: 40px; height: 40px; border-radius: 50%; background: var(--color-blue); color: #FFFFFF; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700; }
  .featured-card__author-name { display: block; font-size: 0.85rem; font-weight: 600; color: var(--color-text); }
  .featured-card__date { display: block; font-size: 0.78rem; color: var(--color-text-secondary); }
  .featured-card__cta { display: inline-flex; align-items: center; gap: 6px; font-size: 0.85rem; font-weight: 600; color: var(--color-blue); transition: gap 0.25s ease; }
  .featured-card:hover .featured-card__cta { gap: 10px; }

  .featured-card__visual {
    background: linear-gradient(135deg, #1877F2 0%, #3B5FE6 60%, #1464CC 100%);
    display: flex; align-items: center; justify-content: center;
    min-height: 300px; position: relative; overflow: hidden;
  }
  .featured-card__visual::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 30% 70%, rgba(255,255,255,0.1) 0%, transparent 60%); }
  .featured-card__graphic { position: relative; z-index: 1; }
  .featured-card__icon-wrap {
    width: 120px; height: 120px; border-radius: 24px;
    background: rgba(255,255,255,0.12); backdrop-filter: blur(12px);
    display: flex; align-items: center; justify-content: center;
    color: #FFFFFF; border: 1px solid rgba(255,255,255,0.15);
  }

  @media (max-width: 768px) {
    .featured-card { grid-template-columns: 1fr; }
    .featured-card__visual { min-height: 200px; order: -1; }
  }

  /* ========== HORIZONTAL CAROUSEL ========== */
  .blog-carousel-section { padding-bottom: clamp(32px, 4vw, 48px); }

  .blog-carousel__header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: clamp(20px, 3vw, 32px);
  }

  .blog-carousel__heading {
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .blog-carousel__arrows { display: flex; gap: 8px; }

  .blog-carousel__arrow {
    width: 44px; height: 44px; border-radius: 50%;
    border: 1px solid var(--color-rule); background: var(--color-bg);
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    color: var(--color-text); transition: all 0.2s;
  }

  .blog-carousel__arrow:hover {
    background: var(--color-blue); border-color: var(--color-blue); color: #FFFFFF;
  }

  .blog-carousel__track-wrap {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 3%, black 97%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 3%, black 97%, transparent 100%);
  }

  .blog-carousel__track {
    display: flex;
    gap: var(--grid-gap);
    padding-inline: var(--container-pad);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .blog-carousel__track::-webkit-scrollbar { display: none; }

  .blog-carousel__track .post-card {
    flex: 0 0 calc((min(var(--container-max), 100vw) - var(--container-pad) * 2 - var(--grid-gap) * 2) / 3);
    scroll-snap-align: start;
    min-width: 320px;
  }

  @media (max-width: 1024px) {
    .blog-carousel__track .post-card {
      flex: 0 0 calc(50vw - var(--container-pad) - var(--grid-gap) / 2);
    }
  }

  @media (max-width: 640px) {
    .blog-carousel__track .post-card {
      flex: 0 0 calc(85vw);
    }
  }

  /* ========== VIEW ALL BUTTON ========== */
  .blog-carousel__view-all-wrap {
    display: flex;
    justify-content: center;
    padding-top: clamp(24px, 3vw, 40px);
    padding-bottom: clamp(8px, 2vw, 16px);
  }

  .blog-carousel__view-all {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-blue);
    background: var(--color-blue-faded);
    border: 1px solid rgba(24, 119, 242, 0.15);
    border-radius: var(--radius-full);
    padding: 14px 32px;
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .blog-carousel__view-all:hover {
    background: var(--color-blue);
    color: #FFFFFF;
    border-color: var(--color-blue);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(24, 119, 242, 0.3);
  }

  .blog-carousel__view-all svg {
    transition: transform 0.3s ease;
  }

  .blog-carousel__view-all.is-open svg {
    transform: rotate(180deg);
  }

  /* ========== EXPANDED ALL ARTICLES ========== */
  .blog-all {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.6s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.4s ease;
    opacity: 0;
  }

  .blog-all.is-open {
    max-height: 3000px;
    opacity: 1;
    padding-bottom: var(--section-gap);
  }

  .blog-filter__bar {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    padding-bottom: clamp(24px, 3vw, 40px);
    -webkit-overflow-scrolling: touch;
  }

  .blog-filter__bar::-webkit-scrollbar { display: none; }

  .blog-filter__btn {
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 600;
    padding: 10px 24px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-rule);
    background: var(--color-bg);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .blog-filter__btn:hover { border-color: var(--color-blue); color: var(--color-blue); }
  .blog-filter__btn.is-active { background: var(--color-blue); border-color: var(--color-blue); color: #FFFFFF; }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--grid-gap);
  }

  @media (max-width: 1024px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .blog-grid { grid-template-columns: 1fr; } }

  /* ========== POST CARD (shared) ========== */
  .post-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-md);
    padding: clamp(24px, 3vw, 36px);
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.35s ease, transform 0.35s ease, border-color 0.35s ease;
    overflow: hidden;
  }

  .post-card:hover {
    box-shadow: 0 12px 40px rgba(24, 119, 242, 0.08);
    transform: translateY(-4px);
    border-color: rgba(24, 119, 242, 0.2);
  }

  .post-card__glow {
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--color-blue), #3B5FE6);
    opacity: 0; transition: opacity 0.35s ease;
  }

  .post-card:hover .post-card__glow { opacity: 1; }

  .post-card__top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }

  .post-card__category {
    font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
    color: var(--color-blue); background: var(--color-blue-faded);
    padding: 4px 12px; border-radius: var(--radius-full);
  }

  .post-card__read { font-size: 0.78rem; color: var(--color-text-secondary); }

  .post-card__title {
    font-size: clamp(1.05rem, 1.5vw, 1.25rem); font-weight: 700; line-height: 1.3;
    letter-spacing: -0.01em; margin-bottom: 10px; color: var(--color-text); transition: color 0.2s;
  }

  .post-card:hover .post-card__title { color: var(--color-blue); }

  .post-card__desc {
    font-size: 0.88rem; color: var(--color-text-secondary); line-height: 1.65;
    margin-bottom: 24px; flex: 1;
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  }

  .post-card__bottom {
    display: flex; align-items: center; justify-content: space-between;
    padding-top: 16px; border-top: 1px solid var(--color-rule-light);
  }

  .post-card__author { display: flex; align-items: center; gap: 8px; }

  .post-card__avatar {
    width: 32px; height: 32px; border-radius: 50%; background: var(--color-blue);
    color: #FFFFFF; display: flex; align-items: center; justify-content: center;
    font-size: 0.65rem; font-weight: 700;
  }

  .post-card__author-name { font-size: 0.8rem; font-weight: 600; color: var(--color-text); }
  .post-card__date { font-size: 0.78rem; color: var(--color-text-secondary); }

  .post-card--grid.is-hidden { display: none; }

  .post-card--grid {
    animation: card-in 0.5s ease both;
    animation-delay: var(--delay);
  }

  @keyframes card-in {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ========== NEWSLETTER CTA (textured blue) ========== */
  .blog-cta { padding-block: var(--section-gap); }
  .blog-cta__heading { color: #FFFFFF; margin-bottom: 12px; }
  .blog-cta__text { margin-bottom: 32px; }
  .blog-cta__form { max-width: 480px; margin-inline: auto; }

  .blog-cta__input-group {
    display: flex; gap: 8px;
    background: rgba(255,255,255,0.12); border-radius: var(--radius-full);
    padding: 6px 6px 6px 24px;
    border: 1px solid rgba(255,255,255,0.2);
    transition: border-color 0.2s, background 0.2s;
  }

  .blog-cta__input-group:focus-within { border-color: rgba(255,255,255,0.5); background: rgba(255,255,255,0.16); }

  .blog-cta__input {
    flex: 1; background: none; border: none; outline: none;
    color: #FFFFFF; font-family: var(--font-body); font-size: 0.9rem;
  }

  .blog-cta__input::placeholder { color: rgba(255,255,255,0.5); }

  @media (max-width: 480px) {
    .blog-cta__input-group { flex-direction: column; border-radius: var(--radius-md); padding: 12px; }
  }

  /* ========== TEXTURED OVERLAY (exact homepage) ========== */
  .section--blue-only {
    position: relative;
    overflow: hidden;
  }

  .section--blue-only::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("/images/noise.png");
    background-repeat: repeat;
    background-size: 200px 200px;
    pointer-events: none;
    z-index: 0;
    opacity: 0.35;
    mix-blend-mode: overlay;
  }

  .section--blue-only > * {
    position: relative;
    z-index: 1;
  }
</style>


<script>

  // ========== CAROUSEL SCROLL ==========
  const track = document.getElementById('carouselTrack');
  const prevBtn = document.getElementById('carouselPrev');
  const nextBtn = document.getElementById('carouselNext');

  if (track && prevBtn && nextBtn) {
    const getScrollAmount = () => {
      const card = track.querySelector('.post-card') as HTMLElement;
      if (!card) return 400;
      return card.offsetWidth + parseInt(getComputedStyle(track).gap || '24');
    };

    prevBtn.addEventListener('click', () => {
      track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', () => {
      track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
    });
  }

  // ========== VIEW ALL EXPAND ==========
  const viewAllBtn = document.getElementById('viewAllBtn');
  const blogAll = document.getElementById('blogAll');

  if (viewAllBtn && blogAll) {
    viewAllBtn.addEventListener('click', () => {
      const isOpen = blogAll.classList.toggle('is-open');
      blogAll.setAttribute('aria-hidden', String(!isOpen));
      viewAllBtn.classList.toggle('is-open', isOpen);

      if (isOpen) {
        setTimeout(() => {
          blogAll.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 100);
      }
    });
  }

  // ========== CATEGORY FILTER ==========
  const filterBar = document.getElementById('filterBar');
  const grid = document.getElementById('blogGrid');

  if (filterBar && grid) {
    const buttons = filterBar.querySelectorAll('.blog-filter__btn');
    const cards = grid.querySelectorAll('.post-card--grid');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        const category = btn.getAttribute('data-category');

        cards.forEach((card, i) => {
          const cardCategory = card.getAttribute('data-category');
          if (category === 'All' || cardCategory === category) {
            card.classList.remove('is-hidden');
            (card as HTMLElement).style.animationDelay = `${i * 0.06}s`;
          } else {
            card.classList.add('is-hidden');
          }
        });
      });
    });
  }
</script>
