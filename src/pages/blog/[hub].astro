---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const hubs = await getCollection('blog-hubs', ({ data }) => !data.draft);
  return hubs.map(hub => ({
    params: { hub: hub.data.silo },
    props: { hub },
  }));
}

const { hub } = Astro.props;
const { Content, headings } = await render(hub);

// Get all spokes in this silo
const allSpokes = await getCollection('blog-spokes', ({ data }) => !data.draft);
const siloSpokes = allSpokes
  .filter(s => s.data.silo === hub.data.silo)
  .sort((a, b) => a.data.publishDate.getTime() - b.data.publishDate.getTime());

const spokeLinks = siloSpokes.map(s => ({
  title: s.data.title,
  href: `/blog/${hub.data.silo}/${s.id.split('/').pop()}/`,
  description: s.data.description,
}));

const formattedDate = hub.data.publishDate.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

const updatedDate = hub.data.updatedDate.toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<BlogLayout
  title={hub.data.titleTag}
  description={hub.data.description}
>

  <!-- Breadcrumbs (placeholder — component coming in Phase 2) -->
  <nav class="text-[0.82rem] text-[var(--color-text-secondary)] pt-[clamp(140px,18vw,200px)] pb-4">
    <div class="container">
      <a href="/" class="text-[var(--color-blue)] no-underline hover:underline">Home</a>
      <span class="mx-2">&gt;</span>
      <a href="/blog/" class="text-[var(--color-blue)] no-underline hover:underline">Blog</a>
      <span class="mx-2">&gt;</span>
      <span>{hub.data.title}</span>
    </div>
  </nav>

  <article class="pb-[var(--spacing-section)]">
    <div class="container">
      <div class="grid grid-cols-[1fr_320px] gap-[clamp(40px,5vw,80px)] items-start max-[1024px]:grid-cols-1">

        <!-- Main Content -->
        <div>
          <h1 class="mb-6">{hub.data.title}</h1>

          <!-- E-E-A-T Author Bar -->
          <div class="flex items-center gap-4 mb-8 p-4 bg-[var(--color-bg-soft)] border border-[var(--color-rule)] rounded-[var(--radius-md)]">
            <img
              src={hub.data.authorImage}
              alt={hub.data.author}
              width="56"
              height="56"
              class="rounded-full object-cover shrink-0"
              style="width:56px;height:56px;"
            />
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap">
                <a href={hub.data.authorLinkedIn} target="_blank" rel="noopener" class="text-[0.95rem] font-semibold text-[var(--color-text)] no-underline hover:text-[var(--color-blue)] transition-colors">{hub.data.author}</a>
                <span class="text-[0.78rem] text-[var(--color-text-secondary)]">·</span>
                <span class="text-[0.78rem] text-[var(--color-text-secondary)]">{hub.data.authorTitle}</span>
              </div>
              <div class="flex items-center gap-3 mt-1 text-[0.78rem] text-[var(--color-text-secondary)]">
                <span>Published {formattedDate}</span>
                {hub.data.updatedDate.getTime() !== hub.data.publishDate.getTime() && (
                  <span>· Updated {updatedDate}</span>
                )}
              </div>
            </div>
            <!-- Fact-checked badge -->
            <div class="hidden sm:flex items-center gap-1.5 shrink-0 text-[0.75rem] font-medium text-[var(--color-blue)] bg-[var(--color-bg)] border border-[var(--color-rule)] rounded-[var(--radius-full)] px-3 py-1.5">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              Fact-Checked
            </div>
          </div>

          <!-- Featured Hero Image -->
          {hub.data.featuredImage && (
            <figure class="mb-10">
              <img
                src={hub.data.featuredImage}
                alt={hub.data.featuredImageAlt}
                width="800"
                height="420"
                class="w-full rounded-[var(--radius-md)] border border-[var(--color-rule)]"
                loading="eager"
              />
            </figure>
          )}

          <div class="prose max-w-none">
            <Content />
          </div>

          <!-- FAQ Section (placeholder — component coming in Phase 2) -->
          {hub.data.faqs && hub.data.faqs.length > 0 && (
            <section class="mt-16 pt-12 border-t border-[var(--color-rule)]">
              <h2 class="mb-8">Frequently Asked Questions</h2>
              {hub.data.faqs.map(faq => (
                <details class="mb-4 border border-[var(--color-rule)] rounded-[var(--radius-md)] overflow-hidden">
                  <summary class="p-5 font-semibold text-[var(--color-text)] cursor-pointer hover:bg-[var(--color-bg-soft)]">{faq.question}</summary>
                  <div class="px-5 pb-5 text-[var(--color-text-secondary)] leading-[1.8]">{faq.answer}</div>
                </details>
              ))}
            </section>
          )}

          <!-- CTA Banner -->
          <section class="mt-16 p-[clamp(32px,4vw,48px)] bg-[var(--color-bg-blue)] rounded-[var(--radius-lg)] text-center relative overflow-hidden section--textured">
            <h2 class="text-white mb-3" style="font-size:clamp(1.4rem,2.5vw,1.85rem);">Stop Guessing. Start Ranking.</h2>
            <p class="text-white/85 text-[clamp(0.95rem,1.2vw,1.05rem)] leading-[1.7] max-w-[50ch] mx-auto mb-6">Get a free local SEO audit and find out exactly where your business stands — and what it'll take to reach the Map Pack.</p>
            <a href="/contact/" class="btn btn--white">Get Your Free Audit</a>
          </section>

          <!-- Related Guides (placeholder — component coming in Phase 2) -->
          {spokeLinks.length > 0 && (
            <section class="mt-16 pt-12 border-t border-[var(--color-rule)]">
              <h2 class="mb-8">All Articles in This Guide</h2>
              <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {spokeLinks.map(spoke => (
                  <a href={spoke.href} class="block p-6 border border-[var(--color-rule)] rounded-[var(--radius-md)] no-underline text-inherit transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(0,0,0,0.06)]">
                    <h3 class="text-[1rem] font-bold text-[var(--color-text)] mb-2">{spoke.title}</h3>
                    <p class="text-[0.85rem] text-[var(--color-text-secondary)] leading-[1.6] line-clamp-2">{spoke.description}</p>
                  </a>
                ))}
              </div>
            </section>
          )}
        </div>

        <!-- Sidebar (placeholder — TOC component coming in Phase 2) -->
        <aside class="max-[1024px]:hidden sticky top-32">
          <div class="bg-[var(--color-bg-soft)] border border-[var(--color-rule)] rounded-[var(--radius-md)] p-6">
            <h4 class="text-[0.85rem] font-bold uppercase tracking-[0.06em] text-[var(--color-text)] mb-4">In This Guide</h4>
            <nav class="flex flex-col gap-2">
              {headings.filter(h => h.depth === 2).map(h => (
                <a href={`#${h.slug}`} class="text-[0.85rem] text-[var(--color-text-secondary)] no-underline hover:text-[var(--color-blue)] transition-colors duration-200">{h.text}</a>
              ))}
            </nav>
            {spokeLinks.length > 0 && (
              <div class="mt-6 pt-6 border-t border-[var(--color-rule)]">
                <h4 class="text-[0.85rem] font-bold uppercase tracking-[0.06em] text-[var(--color-text)] mb-4">Articles in This Guide</h4>
                <nav class="flex flex-col gap-2">
                  {spokeLinks.map(spoke => (
                    <a href={spoke.href} class="text-[0.85rem] text-[var(--color-text-secondary)] no-underline hover:text-[var(--color-blue)] transition-colors duration-200">{spoke.title}</a>
                  ))}
                </nav>
              </div>
            )}
          </div>
        </aside>

      </div>
    </div>
  </article>

</BlogLayout>

<style>
  /* Prose styling for markdown content */
  .prose :global(h2) { font-size: clamp(1.4rem, 2.2vw, 1.75rem); font-weight: 700; line-height: 1.2; letter-spacing: -0.02em; margin-top: 2.5em; margin-bottom: 0.6em; color: var(--color-text); scroll-margin-top: 80px; }
  .prose :global(h3) { font-size: clamp(1.1rem, 1.5vw, 1.3rem); font-weight: 600; line-height: 1.3; margin-top: 2em; margin-bottom: 0.5em; color: var(--color-text); }
  .prose :global(p) { margin-bottom: 1.5em; color: var(--color-text-secondary); line-height: 1.8; font-size: clamp(0.95rem, 1.1vw, 1.05rem); }
  .prose :global(strong) { color: var(--color-text); font-weight: 600; }
  .prose :global(a) { color: var(--color-blue); text-decoration: underline; text-underline-offset: 3px; text-decoration-color: rgba(24, 119, 242, 0.3); transition: text-decoration-color 0.2s; }
  .prose :global(a:hover) { text-decoration-color: var(--color-blue); }
  .prose :global(ul), .prose :global(ol) { margin-bottom: 1.5em; padding-left: 1.5em; color: var(--color-text-secondary); line-height: 1.8; font-size: clamp(0.95rem, 1.1vw, 1.05rem); }
  .prose :global(li) { margin-bottom: 0.5em; }
  .prose :global(blockquote) { border-left: 3px solid var(--color-blue); padding-left: 24px; margin-block: 2em; font-style: italic; color: var(--color-text-secondary); }
  .prose :global(table) { width: 100%; border-collapse: collapse; margin-block: 2em; font-size: 0.9rem; }
  .prose :global(th) { text-align: left; padding: 12px 16px; background: var(--color-bg-soft); border: 1px solid var(--color-rule); font-weight: 600; color: var(--color-text); }
  .prose :global(td) { padding: 12px 16px; border: 1px solid var(--color-rule); color: var(--color-text-secondary); }
  .prose :global(hr) { border: none; border-top: 1px solid var(--color-rule); margin-block: 2.5em; }
  .prose :global(code) { background: var(--color-bg-soft); padding: 2px 6px; border-radius: 4px; font-size: 0.88em; }
  .prose :global(img) { width: 100%; height: auto; border-radius: var(--radius-md); border: 1px solid var(--color-rule); margin-block: 2em; }
</style>
