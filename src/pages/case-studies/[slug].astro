---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

export async function getStaticPaths() {
  const studies = await getCollection('case-studies');
  return studies
    .filter((s) => !s.data.draft)
    .map((study) => ({
      params: { slug: study.id },
      props: { study },
    }));
}

const { study } = Astro.props;
const d = study.data;
---

<BlogLayout title={d.titleTag} description={d.description}>

  <!-- ========== HERO ========== -->
  <section class="cs-hero">
    <div class="container cs-hero__inner">
      <div class="cs-hero__split">
        <div class="cs-hero__left">
          <div class="cs-hero__badge">
            <span class="cs-hero__dot"></span>
            Case Study
          </div>
          <h1 class="cs-hero__title">{d.title}</h1>
          <p class="cs-hero__sub">{d.description}</p>
          <div class="cs-hero__meta">
            <div class="cs-hero__meta-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <div><span class="cs-hero__meta-label">Client</span><span class="cs-hero__meta-value">{d.client}</span></div>
            </div>
            <div class="cs-hero__meta-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              <div><span class="cs-hero__meta-label">Industry</span><span class="cs-hero__meta-value">{d.industry}</span></div>
            </div>
            <div class="cs-hero__meta-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <div><span class="cs-hero__meta-label">Location</span><span class="cs-hero__meta-value">{d.location}</span></div>
            </div>
            <div class="cs-hero__meta-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <div><span class="cs-hero__meta-label">Timeline</span><span class="cs-hero__meta-value">{d.timeline}</span></div>
            </div>
          </div>
        </div>
        {d.siteScreenshot && (
          <div class="cs-hero__right">
            <div class="cs-hero__browser">
              <div class="cs-hero__browser-bar">
                <span class="cs-hero__browser-dot"></span>
                <span class="cs-hero__browser-dot"></span>
                <span class="cs-hero__browser-dot"></span>
                <span class="cs-hero__browser-url">buildingandair.com</span>
              </div>
              <img src={d.siteScreenshot} alt={d.siteScreenshotAlt || ''} width="1440" height="900" loading="eager" />
            </div>
          </div>
        )}
      </div>
    </div>
  </section>


  <!-- ========== STATS ========== -->
  <section class="cs-stats">
    <div class="container">
      <div class="cs-stats__grid">
        {d.stats.map((stat) => (
          <div class="cs-stats__card">
            <span class="cs-stats__number">{stat.value}</span>
            <span class="cs-stats__label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ========== CLIENT + PROBLEM ========== -->
  {d.clientSummary && d.problemItems && (
    <section class="cs-problem">
      <div class="container">
        <div class="cs-problem__layout">
          <div class="cs-problem__left">
            <div class="cs-hero__badge" style="margin-bottom: 20px;">
              <span class="cs-hero__dot"></span>
              The Client
            </div>
            <p class="cs-problem__summary">{d.clientSummary}</p>
          </div>
          <div class="cs-problem__right">
            <h2 class="cs-problem__heading">The Problem</h2>
            <div class="cs-problem__items">
              {d.problemItems.map((item, i) => (
                <div class="cs-problem__item">
                  <span class="cs-problem__num">{String(i + 1).padStart(2, '0')}</span>
                  <p>{item}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )}


  <!-- ========== WHAT WE BUILT ========== -->
  {d.architecture && (
    <section class="cs-built section--blue section--textured">
      <div class="container">
        <div class="cs-built__header">
          <h2>What We Built</h2>
          <p class="subheadline" style="color: rgba(255,255,255,0.75);">A 45-page custom site designed to compete with firms that have years of established authority — from day one.</p>
        </div>
        {d.siteScreenshots && d.siteScreenshots.length > 0 && (
          <div class="cs-marquee">
            <div class="cs-marquee__fade cs-marquee__fade--left"></div>
            <div class="cs-marquee__track">
              {[...d.siteScreenshots, ...d.siteScreenshots].map((shot) => (
                <div class="cs-marquee__slide">
                  <div class="cs-marquee__img-wrap">
                    <img src={shot.src} alt={shot.alt} width="720" height="450" loading="lazy" />
                  </div>
                  <span class="cs-marquee__label">{shot.label}</span>
                </div>
              ))}
            </div>
            <div class="cs-marquee__fade cs-marquee__fade--right"></div>
          </div>
        )}
        <div class="cs-built__grid">
          {d.architecture.map((item) => (
            <div class="cs-built__card">
              <span class="cs-built__count">{item.count}</span>
              <h3 class="cs-built__label">{item.label}</h3>
              <p class="cs-built__detail">{item.detail}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}


  <!-- ========== STRATEGY ========== -->
  {d.strategyPoints && (
    <section class="cs-strategy">
      <div class="container">
        <div class="cs-strategy__header">
          <div class="cs-hero__badge">
            <span class="cs-hero__dot"></span>
            Strategy
          </div>
          <h2>Design & Strategy Decisions</h2>
          <p class="subheadline">Every decision was made to position BAM as the lowest-risk choice for institutional buyers.</p>
        </div>
        <div class="cs-strategy__grid">
          {d.strategyPoints.map((point, i) => (
            <div class="cs-strategy__card">
              <div class="cs-strategy__top">
                <span class="cs-strategy__num">{String(i + 1).padStart(2, '0')}</span>
                <div class="cs-strategy__icon-wrap">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
              </div>
              <h3>{point.title}</h3>
              <p>{point.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}


  <!-- ========== QUOTABLE ========== -->
  {d.quotable && (
    <section class="cs-quote">
      <div class="container">
        <blockquote class="cs-quote__block">
          <span class="cs-quote__mark">&ldquo;</span>
          {d.quotable}
          <span class="cs-quote__mark">&rdquo;</span>
        </blockquote>
      </div>
    </section>
  )}


  <!-- ========== RANKINGS ========== -->
  {d.rankings && (
    <section class="cs-rankings">
      <div class="container">
        <div class="cs-rankings__header">
          <div class="cs-hero__badge">
            <span class="cs-hero__dot"></span>
            Results — 8 Weeks After Launch
          </div>
          <h2>Search Rankings</h2>
        </div>
        <div class="cs-rankings__table-wrap">
          <table class="cs-rankings__table">
            <thead>
              <tr>
                <th>Pos.</th>
                <th>Keyword</th>
                <th>Ranking URL</th>
              </tr>
            </thead>
            <tbody>
              {d.rankings.map((r) => (
                <tr class={r.position === '#1' || r.position === '#2' ? 'cs-rankings__top' : ''}>
                  <td>
                    <span class={`cs-rankings__pos ${parseInt(r.position.replace('#','')) <= 3 ? 'cs-rankings__pos--top3' : parseInt(r.position.replace('#','')) <= 10 ? 'cs-rankings__pos--page1' : 'cs-rankings__pos--page2'}`}>
                      {r.position}
                    </span>
                  </td>
                  <td>
                    <span class="cs-rankings__kw">{r.keyword}</span>
                    {r.note && <span class="cs-rankings__note">{r.note}</span>}
                  </td>
                  <td><code class="cs-rankings__url">{r.url}</code></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="cs-rankings__dist">
          <div class="cs-rankings__dist-item">
            <span class="cs-rankings__dist-num cs-rankings__pos--top3">5</span>
            <span>Top 3</span>
          </div>
          <div class="cs-rankings__dist-item">
            <span class="cs-rankings__dist-num cs-rankings__pos--page1">9</span>
            <span>Page 1</span>
          </div>
          <div class="cs-rankings__dist-item">
            <span class="cs-rankings__dist-num cs-rankings__pos--page2">4</span>
            <span>Striking Distance</span>
          </div>
        </div>
      </div>
    </section>
  )}


  <!-- ========== SERVICES DELIVERED ========== -->
  <section class="cs-services">
    <div class="container">
      <div class="cs-services__row">
        <span class="cs-services__label">Services Delivered</span>
        <div class="cs-services__tags">
          {d.services.map((s) => (
            <span class="cs-services__tag">{s}</span>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ========== CLOSING ========== -->
  {d.closingTitle && d.closingBody && (
    <section class="cs-closing">
      <div class="container">
        <div class="cs-closing__layout">
          <div class="cs-closing__left">
            <div class="cs-hero__badge">
              <span class="cs-hero__dot"></span>
              The Takeaway
            </div>
            <h2>{d.closingTitle}</h2>
            <div class="cs-closing__accent">
              <span class="cs-closing__accent-line"></span>
              <span class="cs-closing__accent-text">The build quality is the strategy.</span>
            </div>
          </div>
          <div class="cs-closing__right">
            <div class="cs-closing__card">
              <p>{d.closingBody}</p>
              <div class="cs-closing__stats-row">
                <div class="cs-closing__mini-stat">
                  <span class="cs-closing__mini-value">0.1</span>
                  <span class="cs-closing__mini-label">Domain Rating</span>
                </div>
                <div class="cs-closing__mini-stat">
                  <span class="cs-closing__mini-value">0</span>
                  <span class="cs-closing__mini-label">Links Built</span>
                </div>
                <div class="cs-closing__mini-stat">
                  <span class="cs-closing__mini-value">9</span>
                  <span class="cs-closing__mini-label">Page 1 Rankings</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}


  <!-- ========== CTA ========== -->
  <section class="cta-final section--blue">
    <div class="container text-center">
      <h2>Ready for Results Like This?</h2>
      <p class="mx-auto" style="text-align:center;">
        We build websites that rank — no shortcuts, no gimmicks. Let's talk about what we can build for you.
      </p>
      <div class="cta-final__actions">
        <a href="/contact/" class="btn btn--white">Start Your Project</a>
        <a href="/case-studies/" class="btn--white-outline">View More Case Studies</a>
      </div>
    </div>
  </section>

</BlogLayout>


<style>
  /* ══════════════════════════════
     HERO — split layout with browser mockup
     ══════════════════════════════ */
  .cs-hero {
    position: relative;
    background: #0a0a14;
    padding-top: clamp(260px, 28vh, 320px);
    padding-bottom: clamp(80px, 10vw, 140px);
    overflow: hidden;
  }
  .cs-hero__inner { position: relative; z-index: 1; }
  .cs-hero__split {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: clamp(40px, 5vw, 80px);
    align-items: center;
  }
  .cs-hero__left { text-align: left; }
  .cs-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    background: rgba(24, 119, 242, 0.15);
    border: 1px solid rgba(24, 119, 242, 0.25);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-blue);
  }
  .cs-hero__dot {
    width: 6px; height: 6px;
    background: var(--color-blue);
    border-radius: 50%;
    animation: cs-pulse 2s ease-in-out infinite;
  }
  @keyframes cs-pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }
  .cs-hero__logo {
    margin-top: clamp(16px, 2vw, 24px);
    margin-bottom: clamp(16px, 2vw, 24px);
  }
  .cs-hero__logo img {
    height: 40px;
    width: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }
  .cs-hero__logo img:hover { opacity: 1; }
  .cs-hero__title {
    color: #fff;
    font-size: clamp(1.8rem, 3.5vw, 2.75rem);
    margin-top: clamp(16px, 2vw, 24px);
    margin-bottom: clamp(16px, 2vw, 24px);
    line-height: 1.1;
  }
  .cs-hero__sub {
    color: rgba(255,255,255,0.5);
    font-size: clamp(0.95rem, 1.2vw, 1.1rem);
    line-height: 1.7;
    margin-bottom: clamp(32px, 4vw, 48px);
    max-width: none;
  }
  .cs-hero__meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .cs-hero__meta-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-md);
    transition: all 0.3s ease;
  }
  .cs-hero__meta-item:hover {
    background: rgba(255,255,255,0.07);
    border-color: rgba(24,119,242,0.3);
  }
  .cs-hero__meta-item svg { flex-shrink: 0; color: var(--color-blue); }
  .cs-hero__meta-item > div { display:flex; flex-direction:column; gap:1px; text-align:left; }
  .cs-hero__meta-label { font-size:0.6rem; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; color:rgba(255,255,255,0.3); }
  .cs-hero__meta-value { font-size:0.8rem; font-weight:600; color:#fff; white-space:nowrap; }

  /* Browser mockup with tilt */
  .cs-hero__right { position: relative; }
  .cs-hero__browser {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow: 0 24px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.04);
    transition: box-shadow 0.4s ease;
  }
  .cs-hero__browser-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: #1a1a2e;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .cs-hero__browser-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.12);
  }
  .cs-hero__browser-dot:first-child { background: #ff5f56; }
  .cs-hero__browser-dot:nth-child(2) { background: #ffbd2e; }
  .cs-hero__browser-dot:nth-child(3) { background: #27c93f; }
  .cs-hero__browser-url {
    margin-left: 8px;
    font-size: 0.7rem;
    font-weight: 500;
    color: rgba(255,255,255,0.3);
    background: rgba(255,255,255,0.04);
    padding: 4px 12px;
    border-radius: 6px;
    letter-spacing: 0.02em;
  }
  .cs-hero__browser img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media(max-width:900px){
    .cs-hero__split {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .cs-hero__left { text-align: center; }
    .cs-hero__meta {
      grid-template-columns: 1fr 1fr;
      max-width: 400px;
      margin-inline: auto;
    }
    .cs-hero__browser {
      max-width: 600px;
      margin-inline: auto;
    }
  }
  @media(max-width:480px){
    .cs-hero__meta { grid-template-columns: 1fr; }
  }


  /* ══════════════════════════════
     STATS — dark with big white numbers
     ══════════════════════════════ */
  .cs-stats {
    background: #0a0a14;
    padding-top: 0;
    padding-bottom: clamp(80px, 10vw, 120px);
  }
  .cs-stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(12px, 1.5vw, 20px);
  }
  .cs-stats__card {
    position: relative;
    overflow: hidden;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: var(--radius-md);
    padding: clamp(28px, 3vw, 44px) clamp(16px, 2vw, 24px);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: all 0.35s ease;
  }
  .cs-stats__card:hover {
    background: rgba(255,255,255,0.06);
    border-color: rgba(24,119,242,0.3);
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(24,119,242,0.12);
  }
  .cs-stats__number {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
    color: #fff;
    text-shadow: 0 0 40px rgba(24,119,242,0.3);
  }
  .cs-stats__label {
    font-size: clamp(0.7rem, 0.9vw, 0.85rem);
    font-weight: 600;
    color: rgba(255,255,255,0.4);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  @media(max-width:768px){
    .cs-stats__grid { grid-template-columns: repeat(2,1fr); }
  }


  /* ══════════════════════════════
     CLIENT + PROBLEM — sticky left, scrolling right
     ══════════════════════════════ */
  .cs-problem {
    padding-block: clamp(80px, 10vw, 140px);
  }
  .cs-problem__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 5vw, 80px);
    align-items: start;
  }
  .cs-problem__left {
    position: sticky;
    top: clamp(100px, 12vh, 140px);
    padding-top: clamp(20px, 3vw, 32px);
  }
  .cs-problem__summary {
    color: var(--color-text-secondary);
    line-height: 1.8;
    max-width: none;
  }
  .cs-problem__heading {
    margin-bottom: clamp(20px, 2.5vw, 32px);
  }
  .cs-problem__items { display: flex; flex-direction: column; gap: 16px; }
  .cs-problem__item {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding: 16px 20px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-md);
    transition: all 0.25s ease;
  }
  .cs-problem__item:hover {
    border-color: var(--color-blue);
    box-shadow: 0 4px 20px rgba(24,119,242,0.06);
  }
  .cs-problem__num {
    font-size: 0.7rem;
    font-weight: 800;
    color: var(--color-blue);
    background: rgba(24,119,242,0.08);
    min-width: 28px; height: 28px;
    display: flex; align-items:center; justify-content:center;
    border-radius: 8px;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .cs-problem__item p {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: none;
    margin: 0;
  }
  @media(max-width:768px){
    .cs-problem__layout { grid-template-columns: 1fr; }
    .cs-problem__left { position: static; }
  }


  /* ══════════════════════════════
     WHAT WE BUILT — blue with count cards
     ══════════════════════════════ */
  .cs-built {
    padding-block: clamp(80px, 10vw, 140px);
  }
  .cs-built__header {
    text-align: center;
    margin-bottom: clamp(40px, 5vw, 64px);
  }
  .cs-built__header h2 { margin-bottom: 16px; }

  /* Marquee */
  .cs-marquee {
    position: relative;
    margin-bottom: clamp(40px, 5vw, 64px);
    overflow: hidden;
  }
  .cs-marquee__track {
    display: flex;
    gap: 20px;
    animation: cs-scroll 40s linear infinite;
    width: max-content;
  }
  .cs-marquee__track:hover {
    animation-play-state: paused;
  }
  @keyframes cs-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .cs-marquee__slide {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: clamp(320px, 40vw, 520px);
  }
  .cs-marquee__img-wrap {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow: 0 12px 40px rgba(0,0,0,0.35);
    transition: all 0.35s ease;
  }
  .cs-marquee__img-wrap:hover {
    border-color: rgba(24,119,242,0.3);
    box-shadow: 0 16px 50px rgba(0,0,0,0.45);
    transform: translateY(-3px);
  }
  .cs-marquee__img-wrap img {
    width: 100%;
    height: auto;
    display: block;
  }
  .cs-marquee__label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255,255,255,0.35);
    text-align: center;
  }
  .cs-marquee__fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 80px;
    z-index: 2;
    pointer-events: none;
  }
  .cs-marquee__fade--left {
    left: 0;
    background: linear-gradient(to right, var(--color-bg-blue), transparent);
  }
  .cs-marquee__fade--right {
    right: 0;
    background: linear-gradient(to left, var(--color-bg-blue), transparent);
  }

  .cs-built__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(12px, 1.5vw, 20px);
  }
  .cs-built__card {
