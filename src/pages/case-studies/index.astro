---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

const studies = (await getCollection('case-studies'))
  .filter((s) => !s.data.draft)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<BlogLayout
  title="Case Studies — Lockard Design Co."
  description="Real results from real clients. See how we build websites that rank, convert, and grow businesses."
>

  <!-- ========== HERO ========== -->
  <section class="csi-hero">
    <div class="container">
      <div class="csi-hero__badge">
        <span class="csi-hero__dot"></span>
        Proof Over Promises
      </div>
      <h1 class="csi-hero__title">Case Studies</h1>
      <p class="csi-hero__sub">
        Real results from real clients. No fluff, no vanity metrics — just what we built, why we built it, and what happened next.
      </p>
    </div>
  </section>

  <!-- ========== CASE STUDY GRID ========== -->
  <section class="csi-grid-section">
    <div class="container">
      <div class="csi-grid">
        {studies.map((study) => (
          <a href={`/case-studies/${study.id}/`} class="csi-card">
            <div class="csi-card__top">
              <span class="csi-card__industry">{study.data.industry}</span>
              <span class="csi-card__timeline">{study.data.timeline}</span>
            </div>
            <h2 class="csi-card__title">{study.data.title}</h2>
            <p class="csi-card__desc">{study.data.description}</p>
            <div class="csi-card__stats">
              {study.data.stats.slice(0, 3).map((stat) => (
                <div class="csi-card__stat">
                  <span class="csi-card__stat-value">{stat.value}</span>
                  <span class="csi-card__stat-label">{stat.label}</span>
                </div>
              ))}
            </div>
            <span class="csi-card__link">
              Read Case Study
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </a>
        ))}
      </div>

      {studies.length === 0 && (
        <div class="csi-empty">
          <p>Case studies are on the way. Check back soon.</p>
        </div>
      )}
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="cta-final section--blue" id="contact">
    <div class="container text-center">
      <h2>Want Results Like These?</h2>
      <p class="mx-auto" style="text-align:center;">
        We build websites that rank — no shortcuts, no gimmicks. Let's talk about what we can build for you.
      </p>
      <div class="cta-final__actions">
        <a href="/contact/" class="btn btn--white">Start Your Project</a>
      </div>
    </div>
  </section>

</BlogLayout>

<style>
  /* ── Hero ── */
  .csi-hero {
    background: #0a0a14;
    padding-top: clamp(220px, 24vh, 300px);
    padding-bottom: clamp(60px, 8vw, 100px);
    text-align: center;
  }
  .csi-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    background: rgba(24, 119, 242, 0.15);
    border: 1px solid rgba(24, 119, 242, 0.25);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-blue);
    margin-bottom: clamp(20px, 3vw, 32px);
  }
  .csi-hero__dot {
    width: 6px;
    height: 6px;
    background: var(--color-blue);
    border-radius: 50%;
    animation: csi-pulse 2s ease-in-out infinite;
  }
  @keyframes csi-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
  .csi-hero__title {
    color: #fff;
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: clamp(16px, 2vw, 24px);
  }
  .csi-hero__sub {
    color: rgba(255, 255, 255, 0.6);
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    max-width: 540px;
    margin-inline: auto;
    line-height: 1.7;
  }

  /* ── Grid ── */
  .csi-grid-section {
    padding-block: clamp(60px, 8vw, 120px);
  }
  .csi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 420px), 1fr));
    gap: clamp(24px, 3vw, 32px);
  }

  /* ── Card ── */
  .csi-card {
    display: flex;
    flex-direction: column;
    padding: clamp(28px, 3vw, 40px);
    background: var(--color-bg);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.3s ease, transform 0.3s ease, border-color 0.3s ease;
  }
  .csi-card:hover {
    box-shadow: 0 8px 32px rgba(24, 119, 242, 0.08);
    transform: translateY(-2px);
    border-color: var(--color-blue);
  }
  .csi-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: clamp(16px, 2vw, 20px);
  }
  .csi-card__industry {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-blue);
  }
  .csi-card__timeline {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    padding: 3px 10px;
    background: var(--color-bg-soft);
    border-radius: var(--radius-full);
  }
  .csi-card__title {
    font-size: clamp(1.15rem, 1.6vw, 1.35rem);
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-text);
    margin-bottom: 12px;
  }
  .csi-card__desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: clamp(20px, 2.5vw, 28px);
    flex: 1;
  }
  .csi-card__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    padding-top: clamp(16px, 2vw, 20px);
    border-top: 1px solid var(--color-rule);
    margin-bottom: clamp(16px, 2vw, 24px);
  }
  .csi-card__stat {
    display: flex;
    flex-direction: column;
    text-align: center;
    gap: 2px;
  }
  .csi-card__stat-value {
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }
  .csi-card__stat-label {
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-secondary);
  }
  .csi-card__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-blue);
    transition: gap 0.2s ease;
  }
  .csi-card:hover .csi-card__link {
    gap: 10px;
  }

  .csi-empty {
    text-align: center;
    padding: 80px 0;
  }
  .csi-empty p {
    color: var(--color-text-secondary);
    margin-inline: auto;
  }

  /* ── CTA ── */
  .cta-final {
    padding-block: clamp(80px, 10vw, 160px);
    position: relative;
    overflow: hidden;
  }
  .cta-final::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("/images/noise.png");
    background-repeat: repeat;
    background-size: 200px 200px;
    pointer-events: none;
    z-index: 0;
    opacity: 0.35;
    mix-blend-mode: overlay;
  }
  .cta-final > * {
    position: relative;
    z-index: 1;
  }
  .cta-final h2 {
    margin-bottom: clamp(12px, 2vw, 24px);
  }
  .cta-final p {
    max-width: 50ch;
  }
  .cta-final__actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: clamp(28px, 4vw, 40px);
  }
</style>
