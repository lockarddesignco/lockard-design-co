---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

const studies = (await getCollection('case-studies'))
  .filter((s) => !s.data.draft)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<BlogLayout
  title="Case Studies — Lockard Design Co."
  description="Real results from real clients. See how we build websites that rank, convert, and grow businesses."
>

  <!-- ========== HERO ========== -->
  <section class="csi-hero">
    <div class="container">
      <div class="csi-hero__badge">
        <span class="csi-hero__dot"></span>
        Proof Over Promises
      </div>
      <h1 class="csi-hero__title">Our Work Speaks for Itself.</h1>
      <p class="csi-hero__sub">
        Every project below is a real business we partnered with — from strategy to launch to measurable results. You'll see the site we built, the rankings we earned, and the numbers that followed. This is what happens when the build quality is the strategy.
      </p>
    </div>
  </section>

  <!-- ========== SHOWCASE ========== -->
  {studies.map((study, i) => (
    <section class={`csi-showcase ${i % 2 === 0 ? '' : 'csi-showcase--alt'}`}>
      <div class="container">
        <a href={`/case-studies/${study.id}/`} class="csi-showcase__layout">
          <div class="csi-showcase__visual">
            {study.data.siteScreenshot ? (
              <div class="csi-showcase__browser">
                <div class="csi-showcase__browser-bar">
                  <span class="csi-showcase__dot" style="background:#ff5f56"></span>
                  <span class="csi-showcase__dot" style="background:#ffbd2e"></span>
                  <span class="csi-showcase__dot" style="background:#27c93f"></span>
                </div>
                <img src={study.data.siteScreenshot} alt={study.data.siteScreenshotAlt || ''} width="1440" height="900" loading="lazy" />
              </div>
            ) : (
              <div class="csi-showcase__placeholder">
                <span>Coming Soon</span>
              </div>
            )}
          </div>
          <div class="csi-showcase__content">
            <div class="csi-showcase__meta-row">
              <span class="csi-showcase__industry">{study.data.industry}</span>
              <span class="csi-showcase__divider"></span>
              <span class="csi-showcase__location">{study.data.location}</span>
            </div>
            <h2 class="csi-showcase__title">{study.data.client}</h2>
            <p class="csi-showcase__desc">{study.data.description}</p>
            <div class="csi-showcase__stats">
              {study.data.stats.map((stat) => (
                <div class="csi-showcase__stat">
                  <span class="csi-showcase__stat-value">{stat.value}</span>
                  <span class="csi-showcase__stat-label">{stat.label}</span>
                </div>
              ))}
            </div>
            <span class="csi-showcase__cta">
              View Full Case Study
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </div>
        </a>
      </div>
    </section>
  ))}

  {studies.length === 0 && (
    <section class="csi-empty-section">
      <div class="container">
        <p class="csi-empty">Case studies are on the way. Check back soon.</p>
      </div>
    </section>
  )}

  <!-- ========== CTA ========== -->
  <section class="cta-final section--blue" id="contact">
    <div class="container text-center">
      <h2>Want Results Like These?</h2>
      <p class="mx-auto" style="text-align:center;">
        We build websites that rank — no shortcuts, no gimmicks. Let's talk about what we can build for you.
      </p>
      <div class="cta-final__actions">
        <a href="/contact/" class="btn btn--white">Start Your Project</a>
      </div>
    </div>
  </section>

</BlogLayout>

<style>
  /* ══════════════════════════════
     HERO
     ══════════════════════════════ */
  .csi-hero {
    background: #0a0a14;
    padding-top: clamp(260px, 28vh, 320px);
    padding-bottom: clamp(60px, 8vw, 100px);
    text-align: center;
  }
  .csi-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    background: rgba(24, 119, 242, 0.15);
    border: 1px solid rgba(24, 119, 242, 0.25);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-blue);
    margin-bottom: clamp(20px, 3vw, 32px);
  }
  .csi-hero__dot {
    width: 6px; height: 6px;
    background: var(--color-blue);
    border-radius: 50%;
    animation: csi-pulse 2s ease-in-out infinite;
  }
  @keyframes csi-pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }
  .csi-hero__title {
    color: #fff;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    margin-bottom: clamp(16px, 2vw, 24px);
  }
  .csi-hero__sub {
    color: rgba(255, 255, 255, 0.55);
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    max-width: 540px;
    margin-inline: auto;
    line-height: 1.7;
  }

  /* ══════════════════════════════
     SHOWCASE — full-width alternating sections
     ══════════════════════════════ */
  .csi-showcase {
    padding-block: clamp(80px, 10vw, 140px);
    background: #0a0a14;
    border-top: 1px solid rgba(255,255,255,0.04);
  }
  .csi-showcase--alt {
    background: var(--color-bg);
    border-top: 1px solid var(--color-rule);
  }

  .csi-showcase__layout {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: clamp(40px, 5vw, 80px);
    align-items: center;
    text-decoration: none;
    color: inherit;
  }
  .csi-showcase--alt .csi-showcase__layout {
    direction: rtl;
  }
  .csi-showcase--alt .csi-showcase__layout > * {
    direction: ltr;
  }

  /* Browser mockup */
  .csi-showcase__visual {
    position: relative;
  }
  .csi-showcase__browser {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }
  .csi-showcase__layout:hover .csi-showcase__browser {
    transform: translateY(-6px);
    box-shadow: 0 28px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(24,119,242,0.15);
  }
  .csi-showcase--alt .csi-showcase__browser {
    border-color: var(--color-rule);
    box-shadow: 0 20px 60px rgba(0,0,0,0.1);
  }
  .csi-showcase--alt .csi-showcase__layout:hover .csi-showcase__browser {
    box-shadow: 0 28px 80px rgba(0,0,0,0.15), 0 0 0 1px rgba(24,119,242,0.15);
  }
  .csi-showcase__browser-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: #1a1a2e;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .csi-showcase--alt .csi-showcase__browser-bar {
    background: #f0f0f4;
    border-bottom: 1px solid var(--color-rule);
  }
  .csi-showcase__dot {
    width: 8px; height: 8px;
    border-radius: 50%;
  }
  .csi-showcase__browser img {
    width: 100%;
    height: auto;
    display: block;
  }
  .csi-showcase__placeholder {
    aspect-ratio: 16/10;
    background: rgba(255,255,255,0.03);
    border: 1px dashed rgba(255,255,255,0.1);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.2);
    font-size: 0.9rem;
    font-weight: 600;
  }

  /* Content */
  .csi-showcase__meta-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: clamp(12px, 1.5vw, 16px);
  }
  .csi-showcase__industry {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-blue);
  }
  .csi-showcase__divider {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: rgba(255,255,255,0.25);
  }
  .csi-showcase--alt .csi-showcase__divider {
    background: var(--color-text-secondary);
  }
  .csi-showcase__location {
    font-size: 0.72rem;
    font-weight: 500;
    color: rgba(255,255,255,0.4);
  }
  .csi-showcase--alt .csi-showcase__location {
    color: var(--color-text-secondary);
  }
  .csi-showcase__title {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    color: #fff;
    margin-bottom: clamp(12px, 1.5vw, 16px);
    line-height: 1.15;
  }
  .csi-showcase--alt .csi-showcase__title {
    color: var(--color-text);
  }
  .csi-showcase__desc {
    font-size: clamp(0.92rem, 1.1vw, 1rem);
    line-height: 1.7;
    color: rgba(255,255,255,0.5);
    margin-bottom: clamp(24px, 3vw, 36px);
    max-width: none;
  }
  .csi-showcase--alt .csi-showcase__desc {
    color: var(--color-text-secondary);
  }

  /* Stats row */
  .csi-showcase__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: clamp(24px, 3vw, 36px);
  }
  .csi-showcase__stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .csi-showcase__stat-value {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .csi-showcase--alt .csi-showcase__stat-value {
    color: var(--color-text);
  }
  .csi-showcase__stat-label {
    font-size: 0.62rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(255,255,255,0.35);
  }
  .csi-showcase--alt .csi-showcase__stat-label {
    color: var(--color-text-secondary);
  }

  /* CTA link */
  .csi-showcase__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-blue);
    transition: gap 0.25s ease;
  }
  .csi-showcase__layout:hover .csi-showcase__cta {
    gap: 14px;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .csi-showcase__layout {
      grid-template-columns: 1fr;
      gap: clamp(28px, 4vw, 40px);
    }
    .csi-showcase--alt .csi-showcase__layout {
      direction: ltr;
    }
    .csi-showcase__stats {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
  }

  .csi-empty-section {
    padding-block: clamp(60px, 8vw, 120px);
  }
  .csi-empty {
    text-align: center;
    color: var(--color-text-secondary);
    margin-inline: auto;
  }

  /* ══════════════════════════════
     CTA
     ══════════════════════════════ */
  .cta-final {
    padding-block: clamp(80px, 10vw, 160px);
    position: relative;
    overflow: hidden;
  }
  .cta-final::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("/images/noise.png");
    background-repeat: repeat;
    background-size: 200px 200px;
    pointer-events: none;
    z-index: 0;
    opacity: 0.35;
    mix-blend-mode: overlay;
  }
  .cta-final > * { position: relative; z-index: 1; }
  .cta-final h2 { margin-bottom: clamp(12px, 2vw, 24px); }
  .cta-final p { max-width: 50ch; }
  .cta-final__actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: clamp(28px, 4vw, 40px);
  }
</style>
