---
import BlogLayout from '../layouts/BlogLayout.astro';
---

<BlogLayout
  title="Portfolio — Lockard Design Co."
  description="Real results for real businesses. See how Lockard Design Co. helps service companies generate leads and revenue through web design, SEO, and growth systems."
>

  <!-- ========== HERO ========== -->
  <section class="section--blue section--textured pt-[clamp(160px,20vw,220px)] pb-[clamp(48px,6vw,72px)] text-center">
    <div class="container">
      <div class="max-w-[680px] mx-auto">
        <span class="inline-block text-[0.75rem] font-bold uppercase tracking-[0.1em] text-white/60 mb-3">Portfolio</span>
        <h1 class="text-white mb-4">Our Work</h1>
        <p class="text-white/85 text-[1.1rem] leading-[1.7] max-w-[52ch] mx-auto">Real results for real businesses. Every project is a growth system designed to generate leads and revenue.</p>
      </div>
    </div>
  </section>

  <!-- ========== FILTER BAR ========== -->
  <section class="py-8 border-b border-[var(--color-rule)] bg-[var(--color-bg)] sticky top-24 z-50">
    <div class="container">
      <div class="flex items-center gap-2.5 flex-wrap justify-center">
        <button class="inline-flex items-center px-[22px] py-2.5 rounded-full border border-[var(--color-bg-blue)] bg-[var(--color-bg-blue)] text-white text-[0.85rem] font-semibold cursor-pointer transition-all duration-200">All</button>
        <button class="inline-flex items-center px-[22px] py-2.5 rounded-full border border-[var(--color-rule)] bg-[var(--color-bg)] text-[var(--color-text-secondary)] text-[0.85rem] font-semibold cursor-pointer transition-all duration-200 hover:border-[var(--color-bg-blue)] hover:text-[var(--color-bg-blue)] hover:bg-[rgba(24,119,242,0.06)]">Web Design</button>
        <button class="inline-flex items-center px-[22px] py-2.5 rounded-full border border-[var(--color-rule)] bg-[var(--color-bg)] text-[var(--color-text-secondary)] text-[0.85rem] font-semibold cursor-pointer transition-all duration-200 hover:border-[var(--color-bg-blue)] hover:text-[var(--color-bg-blue)] hover:bg-[rgba(24,119,242,0.06)]">SEO</button>
        <button class="inline-flex items-center px-[22px] py-2.5 rounded-full border border-[var(--color-rule)] bg-[var(--color-bg)] text-[var(--color-text-secondary)] text-[0.85rem] font-semibold cursor-pointer transition-all duration-200 hover:border-[var(--color-bg-blue)] hover:text-[var(--color-bg-blue)] hover:bg-[rgba(24,119,242,0.06)]">Branding</button>
        <button class="inline-flex items-center px-[22px] py-2.5 rounded-full border border-[var(--color-rule)] bg-[var(--color-bg)] text-[var(--color-text-secondary)] text-[0.85rem] font-semibold cursor-pointer transition-all duration-200 hover:border-[var(--color-bg-blue)] hover:text-[var(--color-bg-blue)] hover:bg-[rgba(24,119,242,0.06)]">Automation</button>
      </div>
    </div>
  </section>

  <!-- ========== PROJECT GRID ========== -->
  <section class="section-padding">
    <div class="container">
      <div class="grid grid-cols-3 gap-[clamp(24px,3vw,36px)] max-[1024px]:grid-cols-2 max-[600px]:grid-cols-1">

        <article class="group bg-[var(--color-bg)] border border-[var(--color-rule)] rounded-[var(--radius-lg)] overflow-hidden transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_20px_48px_rgba(0,0,0,0.08)]">
          <div class="relative overflow-hidden">
            <div class="aspect-[16/10] w-full transition-transform duration-[400ms] group-hover:scale-[1.03]" style="background: linear-gradient(135deg, #1877F2, #3B5FE6);"></div>
          </div>
          <div class="p-[clamp(20px,3vw,28px)]">
            <span class="inline-block text-[0.72rem] font-bold uppercase tracking-[0.06em] text-[var(--color-bg-blue)] bg-[rgba(24,119,242,0.08)] px-3 py-[5px] rounded-full mb-3">Web Design + SEO</span>
            <h3 class="text-[1.15rem] font-extrabold text-[var(--color-text)] mb-1.5 tracking-tight">Building & Air</h3>
            <p class="text-[0.88rem] text-[var(--color-text-secondary)] leading-[1.6] mb-4">312% increase in organic traffic</p>
            <a href="#" class="inline-flex items-center gap-1.5 text-[0.85rem] font-semibold text-[var(--color-bg-blue)] no-underline transition-[gap] duration-200 hover:gap-2.5">
              View Case Study
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </article>

        <article class="group bg-[var(--color-bg)] border border-[var(--color-rule)] rounded-[var(--radius-lg)] overflow-hidden transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_20px_48px_rgba(0,0,0,0.08)]">
          <div class="relative overflow-hidden">
            <div class="aspect-[16/10] w-full transition-transform duration-[400ms] group-hover:scale-[1.03]" style="background: linear-gradient(135deg, #0F3460, #1A1A2E);"></div>
          </div>
          <div class="p-[clamp(20px,3vw,28px)]">
            <span class="inline-block text-[0.72rem] font-bold uppercase tracking-[0.06em] text-[var(--color-bg-blue)] bg-[rgba(24,119,242,0.08)] px-3 py-[5px] rounded-full mb-3">Web Design</span>
            <h3 class="text-[1.15rem] font-extrabold text-[var(--color-text)] mb-1.5 tracking-tight">East Coast Transport</h3>
            <p class="text-[0.88rem] text-[var(--color-text-secondary)] leading-[1.6] mb-4">Professional rebrand and 2X lead volume</p>
            <a href="#" class="inline-flex items-center gap-1.5 text-[0.85rem] font-semibold text-[var(--color-bg-blue)] no-underline transition-[gap] duration-200 hover:gap-2.5">
              View Case Study
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </article>

        <article class="group bg-[var(--color-bg)] border border-[var(--color-rule)] rounded-[var(--radius-lg)] overflow-hidden transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_20px_48px_rgba(0,0,0,0.08)]">
          <div class="relative overflow-hidden">
            <div class="aspect-[16/10] w-full transition-transform duration-[400ms] group-hover:scale-[1.03]" style="background: linear-gradient(135deg, #E74C3C, #C0392B);"></div>
          </div>
          <div class="p-[clamp(20px,3vw,28px)]">
            <span class="inline-block text-[0.72rem] font-bold uppercase tracking-[0.06em] text-[var(--color-bg-blue)] bg-[rgba(24,119,242,0.08)] px-3 py-[5px] rounded-full mb-3">Web Design + SEO</span>
            <h3 class="text-[1.15rem] font-extrabold text-[var(--color-text)] mb-1.5 tracking-tight">Cutting Edge Painting</h3>
            <p class="text-[0.88rem] text-[var(--color-text-secondary)] leading-[1.6] mb-4">From zero online presence to page 1</p>
            <a href="#" class="inline-flex items-center gap-1.5 text-[0.85rem] font-semibold text-[var(--color-bg-blue)] no-underline transition-[gap] duration-200 hover:gap-2.5">
              View Case Study
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </article>

        <article class="group bg-[var(--color-bg)] border border-[var(--color-rule)] rounded-[var(--radius-lg)] overflow-hidden transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_20px_48px_rgba(0,0,0,0.08)]">
          <div class="relative overflow-hidden">
            <div class="aspect-[16/10] w-full transition-transform duration-[400ms] group-hover:scale-[1.03]" style="background: linear-gradient(135deg, #2C3E50, #34495E);"></div>
          </div>
          <div class="p-[clamp(20px,3vw,28px)]">
            <span class="inline-block text-[0.72rem] font-bold uppercase tracking-[0.06em] text-[var(--color-bg-blue)] bg-[rgba(24,119,242,0.08)] px-3 py-[5px] rounded-full mb-3">Web Design</span>
            <h3 class="text-[1.15rem] font-extrabold text-[var(--color-text)] mb-1.5 tracking-tight">Popescu Kitchens</h3>
            <p class="text-[0.88rem] text-[var(--color-text-secondary)] leading-[1.6] mb-4">Luxury positioning drives $45K average project value</p>
            <a href="#" class="inline-flex items-center gap-1.5 text-[0.85rem] font-semibold text-[var(--color-bg-blue)] no-underline transition-[gap] duration-200 hover:gap-2.5">
              View Case Study
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </article>

        <article class="group bg-[var(--color-bg)] border border-[var(--color-rule)] rounded-[var(--radius-lg)] overflow-hidden transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_20px_48px_rgba(0,0,0,0.08)]">
          <div class="relative overflow-hidden">
            <div class="aspect-[16/10] w-full transition-transform duration-[400ms] group-hover:scale-[1.03]" style="background: linear-gradient(135deg, #8E44AD, #6C3483);"></div>
          </div>
          <div class="p-[clamp(20px,3vw,28px)]">
            <span class="inline-block text-[0.72rem] font-bold uppercase tracking-[0.06em] text-[var(--color-bg-blue)] bg-[rgba(24,119,242,0.08)] px-3 py-[5px] rounded-full mb-3">Web Design + AI</span>
            <h3 class="text-[1.15rem] font-extrabold text-[var(--color-text)] mb-1.5 tracking-tight">FastLane Bowling</h3>
            <p class="text-[0.88rem] text-[var(--color-text-secondary)] leading-[1.6] mb-4">AI-powered customer service chatbot</p>
            <a href="#" class="inline-flex items-center gap-1.5 text-[0.85rem] font-semibold text-[var(--color-bg-blue)] no-underline transition-[gap] duration-200 hover:gap-2.5">
              View Case Study
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </article>

        <article class="group bg-[var(--color-bg)] border border-[var(--color-rule)] rounded-[var(--radius-lg)] overflow-hidden transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_20px_48px_rgba(0,0,0,0.08)]">
          <div class="relative overflow-hidden">
            <div class="aspect-[16/10] w-full transition-transform duration-[400ms] group-hover:scale-[1.03]" style="background: linear-gradient(135deg, #27AE60, #1E8449);"></div>
          </div>
          <div class="p-[clamp(20px,3vw,28px)]">
            <span class="inline-block text-[0.72rem] font-bold uppercase tracking-[0.06em] text-[var(--color-bg-blue)] bg-[rgba(24,119,242,0.08)] px-3 py-[5px] rounded-full mb-3">SEO</span>
            <h3 class="text-[1.15rem] font-extrabold text-[var(--color-text)] mb-1.5 tracking-tight">Local Plumbing Co.</h3>
            <p class="text-[0.88rem] text-[var(--color-text-secondary)] leading-[1.6] mb-4">Dominating Google Maps in 3 months</p>
            <a href="#" class="inline-flex items-center gap-1.5 text-[0.85rem] font-semibold text-[var(--color-bg-blue)] no-underline transition-[gap] duration-200 hover:gap-2.5">
              View Case Study
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="section--blue section--textured section-padding text-center">
    <div class="container">
      <div class="max-w-[600px] mx-auto">
        <h2 class="text-white mb-4">Ready to Be Our Next Success Story?</h2>
        <p class="text-white/80 text-[1.05rem] leading-[1.7] mb-8">Let's talk about your business and build a growth plan that actually works.</p>
        <a href="/contact" class="btn bg-white text-[var(--color-bg-blue)] border-white text-[0.95rem] py-4 px-9 hover:bg-transparent hover:text-white hover:border-white">Get Your Free Growth Plan</a>
      </div>
    </div>
  </section>

</BlogLayout>
